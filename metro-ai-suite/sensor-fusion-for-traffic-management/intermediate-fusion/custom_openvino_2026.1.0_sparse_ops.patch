index 0000000000..fb29827cbe
--- /dev/null
+++ b/src/plugins/intel_gpu/src/plugin/transformations/eat_sparse_conv_output_fakequantize.hpp
@@ -0,0 +1,39 @@
+// Copyright (C) 2018-2026 Intel Corporation
+// SPDX-License-Identifier: Apache-2.0
+//
+
+#pragma once
+
+#include "openvino/pass/graph_rewrite.hpp"
+#include "openvino/core/visibility.hpp"
+
+namespace ov::intel_gpu {
+
+/// Records the downstream-side PTQ scale on each v15::SparseConvolution that
+/// feeds directly into another INT8-capable SparseConvolution (possibly
+/// through a trivial chain: Relu / Convert / MaxPool / Reshape — i.e. nothing
+/// that changes the per-tensor range).
+///
+/// Why: Path 1 optimisation — when two SparseConvs are connected through a
+/// single FakeQuantize edge, the producer can emit an int8 copy of its
+/// output quantised to the consumer's input scale. That lets the consumer
+/// skip its per-frame `quantize_fp16_to_int8` kernel launch entirely, and
+/// lets the producer skip its dequant (int32→fp16) write for that output
+/// path. Shaves the launch + global round-trip that dominates the small-
+/// layer wait time (see ov_sparse_convolution_int8_optimization.md §8.5).
+///
+/// Matching strategy (same as EatSparseConvInputFakeQuantize): match the
+/// producer SparseConvolution and walk its first output's consumer chain
+/// in the callback. Accepts FakeQuantize → SparseConvolution directly, or
+/// FakeQuantize → Relu → SparseConvolution (the post-NNCF IR structure
+/// for the subm3/subm4 main chain).
+///
+/// Must run BEFORE LPT, same as the input-side pass: LPT will decompose
+/// the FakeQuantize nodes we read from.
+class EatSparseConvOutputFakeQuantize : public ov::pass::MatcherPass {
+public:
