+//
+
+#pragma once
+
+#include <string>
+#include <vector>
+
+#include "primitive.hpp"
+
+namespace cldnn {
+
+/// @brief GPU primitive descriptor for SparseConvolution (SubMConv3d / SparseConv3d).
+///
+/// Inputs:
+///   0: input_features  [M_in, C_in]          f32
+///   1: input_coords    [M_in, 4]             i32
+///   2: weights         [K_vol, C_in, C_out]  f32
+///   3: bias            [C_out]               f32 (optional)
+///
+/// Outputs:
+///   0: output_features [M_out, C_out]        f32
+///   1: output_coords   [M_out, 4]            i32
+struct sparse_convolution : public primitive_base<sparse_convolution> {
+    CLDNN_DECLARE_PRIMITIVE(sparse_convolution)
+
+    sparse_convolution() : primitive_base("", {}) {}
+
+    sparse_convolution(const primitive_id& id,
+                       const std::vector<input_info>& inputs,
+                       std::vector<uint32_t> kernel_size,
+                       std::vector<uint32_t> stride,
+                       std::vector<uint32_t> padding,
+                       std::vector<uint32_t> dilation,
+                       bool subm,
+                       uint32_t out_channels,
+                       std::vector<uint32_t> input_spatial_shape,
+                       uint32_t in_channels = 0,
+                       std::vector<uint32_t> output_spatial_shape = {},
+                       std::string activation = "None",
+                       uint32_t output_bound = 0,
+                       std::string rulebook = "",
+                       float input_abs_max = 0.0f,
+                       float output_abs_max = 0.0f,
+                       std::string input_handoff_producer = "",
+                       size_t num_outputs = 2)
+        : primitive_base(id, inputs, num_outputs),
+          kernel_size(std::move(kernel_size)),
+          stride(std::move(stride)),
+          padding(std::move(padding)),
+          dilation(std::move(dilation)),
+          subm(subm),
+          out_channels(out_channels),
+          in_channels(in_channels),
+          input_spatial_shape(std::move(input_spatial_shape)),
+          output_spatial_shape(std::move(output_spatial_shape)),
+          activation(std::move(activation)),
+          output_bound(output_bound),
+          rulebook(std::move(rulebook)),
+          input_abs_max(input_abs_max),
+          output_abs_max(output_abs_max),
+          input_handoff_producer(std::move(input_handoff_producer)) {}
+
+    std::vector<uint32_t> kernel_size;
+    std::vector<uint32_t> stride;
+    std::vector<uint32_t> padding;
+    std::vector<uint32_t> dilation;
+    bool subm = false;
+    uint32_t out_channels = 0;
+    uint32_t in_channels = 0;
+    std::vector<uint32_t> input_spatial_shape;
+    std::vector<uint32_t> output_spatial_shape;
+    std::string activation = "None";
+    uint32_t output_bound = 0;
+    std::string rulebook;
+    // PTQ-calibrated symmetric per-tensor activation abs-max (set by the
+    // EatSparseConvInputFakeQuantize pass at compile time). 0.0f means
+    // "not set" — the SYCL kernel then reduces abs_max online per frame.
+    float input_abs_max = 0.0f;
+    // PTQ-calibrated output abs-max for the downstream FakeQuantize (Path 1).
+    // > 0 means the kernel should additionally emit an int8-quantised copy
+    // of its output to this scale so the next SparseConv can consume it
+    // directly, skipping its own fp16→int8 quantize kernel.
+    float output_abs_max = 0.0f;
+    // Path 1: friendly-name of the producer SparseConv whose int8 handoff
+    // we should consume. Empty = no handoff — run the normal quantize kernel.
+    std::string input_handoff_producer;
+
+    size_t hash() const override {
+        size_t seed = primitive::hash();
+        seed = hash_combine(seed, subm);
+        seed = hash_combine(seed, out_channels);
+        seed = hash_combine(seed, in_channels);
+        seed = hash_combine(seed, output_bound);
+        for (auto v : kernel_size) seed = hash_combine(seed, v);
+        for (auto v : stride) seed = hash_combine(seed, v);
+        for (auto v : padding) seed = hash_combine(seed, v);
+        for (auto v : dilation) seed = hash_combine(seed, v);
+        for (auto v : input_spatial_shape) seed = hash_combine(seed, v);
+        for (auto v : output_spatial_shape) seed = hash_combine(seed, v);
+        seed = hash_combine(seed, std::hash<std::string>{}(activation));
+        seed = hash_combine(seed, std::hash<std::string>{}(rulebook));
+        seed = hash_combine(seed, std::hash<float>{}(input_abs_max));
+        seed = hash_combine(seed, std::hash<float>{}(output_abs_max));
+        seed = hash_combine(seed, std::hash<std::string>{}(input_handoff_producer));
+        return seed;
+    }
+
+    bool operator==(const primitive& rhs) const override {
+        if (!compare_common_params(rhs))
+            return false;
+        auto rhs_casted = downcast<const sparse_convolution>(rhs);
+        return kernel_size == rhs_casted.kernel_size &&
+               stride == rhs_casted.stride &&
+               padding == rhs_casted.padding &&
+               dilation == rhs_casted.dilation &&
+               subm == rhs_casted.subm &&
+               out_channels == rhs_casted.out_channels &&
+               in_channels == rhs_casted.in_channels &&
+               input_spatial_shape == rhs_casted.input_spatial_shape &&
+               output_spatial_shape == rhs_casted.output_spatial_shape &&
+               activation == rhs_casted.activation &&
+               output_bound == rhs_casted.output_bound &&
+               rulebook == rhs_casted.rulebook &&
+               input_abs_max == rhs_casted.input_abs_max &&
+               output_abs_max == rhs_casted.output_abs_max &&
+               input_handoff_producer == rhs_casted.input_handoff_producer;
+    }
+
+    void save(BinaryOutputBuffer& ob) const override {
+        primitive_base<sparse_convolution>::save(ob);
+        ob << kernel_size;
+        ob << stride;
+        ob << padding;
+        ob << dilation;
+        ob << subm;
+        ob << out_channels;
+        ob << in_channels;
+        ob << input_spatial_shape;
+        ob << output_spatial_shape;
+        ob << activation;
+        ob << output_bound;
+        ob << rulebook;
+        ob << input_abs_max;
+        ob << output_abs_max;
+        ob << input_handoff_producer;
+    }
+
+    void load(BinaryInputBuffer& ib) override {
+        primitive_base<sparse_convolution>::load(ib);
+        ib >> kernel_size;
+        ib >> stride;
+        ib >> padding;
+        ib >> dilation;
+        ib >> subm;
+        ib >> out_channels;
+        ib >> in_channels;
+        ib >> input_spatial_shape;
+        ib >> output_spatial_shape;
+        ib >> activation;
+        ib >> output_bound;
+        ib >> rulebook;
+        ib >> input_abs_max;
+        ib >> output_abs_max;
+        ib >> input_handoff_producer;
+    }
+};
+
+}  // namespace cldnn
