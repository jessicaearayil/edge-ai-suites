@@ -0,0 +1,341 @@
+// Copyright (C) 2018-2026 Intel Corporation
+// SPDX-License-Identifier: Apache-2.0
+//
+// ONNX Frontend mapping for sparse convolution custom ops.
+//
+// Supports two ONNX export formats, both mapped to the unified
+// ov::op::v15::SparseConvolution IR op.
+//
+// Format 1 — "org.openvinotoolkit" domain (primary, used by test ONNX):
+//   Op: org.openvinotoolkit::SparseConvolution
+//   Node inputs:  features [M, C_in] f16/f32, indices [M, 4] i32,
+//                 weight [K_vol, C_in, C_out] f16/f32, bias [C_out] f16/f32 (optional)
+//   Attributes: kernel_size (INTS), stride (INTS), padding (INTS), dilation (INTS),
+//               submanifold (INT), out_channels (INT), spatial_shape (INTS)
+//   Outputs: out_features [M_out, C_out], out_indices [M_out, 4]
+//
+// Format 2 — "bevfusion" domain (BEVFusion ONNX export):
+//   Ops: bevfusion::SubMConv3d / bevfusion::SparseConv3d
+//   Inputs: features, indices, spatial_shape, batch_size, weight, bias
+//   Attributes: kernel_size_d/h/w, stride_d/h/w, padding_d/h/w, dilation_d/h/w, out_channels
+//   Outputs: out_features, out_indices, out_spatial_shape, out_batch_size
+
+#include <limits>
+#include <string>
+#include <vector>
+
+#include "core/operator_set.hpp"
+#include "exceptions.hpp"
+#include "openvino/op/sparse_convolution.hpp"
+#include "openvino/op/constant.hpp"
+#include "openvino/op/reshape.hpp"
+
+namespace ov {
+namespace frontend {
+namespace onnx {
+
+// =========================================================================
+// Shared utilities
+// =========================================================================
+
+namespace {
+
+// Keep uint32_t bounds check at the frontend boundary (these attributes only
+// make sense as non-negative fixed-width ints), but return int64_t because the
+// core SparseConvolution op now stores them as int64_t (so they serialize via
+// the XML serializer's vector<int64_t> path).
+int64_t to_u32_checked(const ov::frontend::onnx::Node& node, const std::string& name, int64_t value) {
+    CHECK_VALID_NODE(node,
+                     value >= 0 && value <= static_cast<int64_t>(std::numeric_limits<uint32_t>::max()),
+                     "Attribute '", name, "' is out of uint32 range: ", value);
+    return value;
+}
+
+/// Read an INT attribute with fallback to name + "_i" suffix (new ONNX export convention).
+int64_t get_int_attr(const ov::frontend::onnx::Node& node,
+                     const std::string& name, int64_t default_val) {
+    if (node.has_attribute(name))
+        return node.get_attribute_value<int64_t>(name, default_val);
+    const auto suffixed = name + "_i";
+    if (node.has_attribute(suffixed))
+        return node.get_attribute_value<int64_t>(suffixed, default_val);
+    return default_val;
+}
+
+/// Read a STRING attribute with fallback to name + "_s" suffix (new ONNX export convention).
+std::string get_string_attr(const ov::frontend::onnx::Node& node,
+                            const std::string& name, const std::string& default_val) {
+    if (node.has_attribute(name))
+        return node.get_attribute_value<std::string>(name, default_val);
+    const auto suffixed = name + "_s";
+    if (node.has_attribute(suffixed))
+        return node.get_attribute_value<std::string>(suffixed, default_val);
+    return default_val;
+}
+
+std::vector<int64_t> get_ints_attr(const ov::frontend::onnx::Node& node,
+                                   const std::string& name,
+                                   std::vector<int64_t> default_val) {
+    if (!node.has_attribute(name))
+        return default_val;
+    auto ints = node.get_attribute_value<std::vector<int64_t>>(name);
+    std::vector<int64_t> result;
+    result.reserve(ints.size());
+    for (auto v : ints)
+        result.push_back(to_u32_checked(node, name, v));
+    return result;
+}
+
+/// Read a Constant node's values as a vector of int64_t (uint32 range-checked).
+std::vector<int64_t> get_constant_u32_values(const ov::Output<ov::Node>& output) {
+    auto constant = std::dynamic_pointer_cast<ov::op::v0::Constant>(output.get_node_shared_ptr());
+    if (!constant)
+        return {};
+    const auto& et = constant->get_element_type();
+    const auto count = ov::shape_size(constant->get_shape());
+    std::vector<int64_t> result(count);
+    if (et == ov::element::i32) {
+        auto data = constant->get_data_ptr<int32_t>();
+        for (size_t i = 0; i < count; ++i) result[i] = static_cast<int64_t>(data[i]);
+    } else if (et == ov::element::i64) {
+        auto data = constant->get_data_ptr<int64_t>();
+        for (size_t i = 0; i < count; ++i) result[i] = data[i];
+    }
+    return result;
+}
+
+/// Reshape weight from 5D [kD,kH,kW,C_in,C_out] to 3D [K_vol,C_in,C_out] if needed.
+ov::Output<ov::Node> ensure_3d_weight(const ov::Output<ov::Node>& weight) {
+    const auto& ps = weight.get_partial_shape();
+    if (ps.rank().is_static() && ps.rank().get_length() == 3)
+        return weight;
+    auto target_shape = ov::op::v0::Constant::create(ov::element::i64, ov::Shape{3}, {-1, 0, 0});
+    return std::make_shared<ov::op::v1::Reshape>(weight, target_shape, true)->output(0);
+}
+
+/// Extract 3D convolution param from individual _d/_h/_w attributes (bevfusion format).
+std::vector<int64_t> get_conv_param_dhw(const ov::frontend::onnx::Node& node,
+                                        const std::string& base_name,
+                                        int64_t default_val) {
+    const auto d_name = base_name + "_d";
+    if (!node.has_attribute(d_name))
+        return {default_val, default_val, default_val};
+    return {
+        to_u32_checked(node, d_name, node.get_attribute_value<int64_t>(d_name, default_val)),
+        to_u32_checked(node, base_name + "_h", node.get_attribute_value<int64_t>(base_name + "_h", default_val)),
+        to_u32_checked(node, base_name + "_w", node.get_attribute_value<int64_t>(base_name + "_w", default_val))
+    };
+}
+
+}  // anonymous namespace
+
+// =========================================================================
+// Format 1: org.openvinotoolkit::SparseConvolution
+// =========================================================================
+//
+// Node inputs: features [M, C_in], indices [M, 4], weight [K_vol, C_in, C_out], bias [C_out]
+// All convolution parameters are in attributes.
+// Outputs: out_features [M_out, C_out], out_indices [M_out, 4]
+
+namespace org_openvinotoolkit {
+namespace opset_1 {
+
+ov::OutputVector sparse_convolution(const ov::frontend::onnx::Node& node) {
+    auto inputs = node.get_ov_inputs();
+    CHECK_VALID_NODE(node, inputs.size() >= 3,
+                     "SparseConvolution expects >= 3 inputs (features, indices, weight[, bias]). Got: ",
+                     inputs.size());
+
+    auto features = inputs[0];   // [M, C_in] f16/f32
+    auto coords = inputs[1];     // [M, 4] i32
+    auto weight = ensure_3d_weight(inputs[2]);  // [K_vol, C_in, C_out]
+
+    // Extract convolution parameters from attributes
+    auto kernel_size = get_ints_attr(node, "kernel_size", {3, 3, 3});
+    auto stride = get_ints_attr(node, "stride", {1, 1, 1});
+    auto padding = get_ints_attr(node, "padding", {1, 1, 1});
+    auto dilation = get_ints_attr(node, "dilation", {1, 1, 1});
+    bool subm = get_int_attr(node, "submanifold", 0) != 0;
+    auto out_channels = to_u32_checked(node, "out_channels",
+        get_int_attr(node, "out_channels", 0));
+
+    // New attributes: input_spatial_shape (with backward compat fallback to spatial_shape)
+    auto input_spatial_shape = get_ints_attr(node, "input_spatial_shape", {});
+    if (input_spatial_shape.empty())
+        input_spatial_shape = get_ints_attr(node, "spatial_shape", {0, 0, 0});
+    auto output_spatial_shape = get_ints_attr(node, "output_spatial_shape", {0, 0, 0});
+    auto in_channels = to_u32_checked(node, "in_channels",
+        get_int_attr(node, "in_channels", 0));
+    auto activation = get_string_attr(node, "activation", "None");
+    auto output_bound = to_u32_checked(node, "output_bound",
+        get_int_attr(node, "output_bound", 0));
+    auto rulebook = get_string_attr(node, "rulebook", "");
+
+    // Infer out_channels from weight shape if not provided
+    if (out_channels == 0) {
+        const auto& w_ps = weight.get_partial_shape();
+        if (w_ps.rank().is_static() && w_ps.rank().get_length() == 3 && w_ps[2].is_static())
+            out_channels = w_ps[2].get_length();
+    }
+    CHECK_VALID_NODE(node, out_channels > 0, "Cannot determine out_channels from attributes or weight shape.");
+
+    // Check for bias (input 3)
+    bool has_bias = inputs.size() > 3;
+    if (has_bias) {
+        const auto& bias_ps = inputs[3].get_partial_shape();
+        if (bias_ps.rank().is_static() && bias_ps.rank().get_length() >= 1 &&
+            bias_ps[0].is_static() && bias_ps[0].get_length() == 0)
+            has_bias = false;
+    }
+
+    std::shared_ptr<ov::op::v15::SparseConvolution> sc_op;
+    if (has_bias) {
+        sc_op = std::make_shared<ov::op::v15::SparseConvolution>(
+            features, coords, weight, inputs[3],
+            kernel_size, stride, padding, dilation,
+            subm, out_channels, input_spatial_shape,
+            in_channels, output_spatial_shape,
+            activation, output_bound, rulebook);
+    } else {
+        sc_op = std::make_shared<ov::op::v15::SparseConvolution>(
+            features, coords, weight,
+            kernel_size, stride, padding, dilation,
+            subm, out_channels, input_spatial_shape,
+            in_channels, output_spatial_shape,
+            activation, output_bound, rulebook);
+    }
+
+    return {sc_op->output(0), sc_op->output(1)};
+}
+
+bool register_translators(void) {
+    ONNX_OP_M("SparseConvolution", OPSET_SINCE(1),
+              org_openvinotoolkit::opset_1::sparse_convolution, OPENVINO_ONNX_DOMAIN);
+    return true;
+}
+
+static bool registered = register_translators();
+
+}  // namespace opset_1
+}  // namespace org_openvinotoolkit
+
+// =========================================================================
+// Format 2: bevfusion::SubMConv3d / SparseConv3d
+// =========================================================================
+//
+// Inputs: features[0], indices[1], spatial_shape[2], batch_size[3], weight[4], bias[5]
+// Outputs: out_features, out_indices, out_spatial_shape, out_batch_size
+
+namespace bevfusion {
+namespace opset_1 {
+
+namespace {
+
+std::vector<int64_t> compute_output_spatial_shape(const std::vector<int64_t>& in_shape,
+                                                  const std::vector<int64_t>& kernel_size,
+                                                  const std::vector<int64_t>& stride,
+                                                  const std::vector<int64_t>& padding,
+                                                  const std::vector<int64_t>& dilation,
+                                                  bool subm) {
+    if (subm) return in_shape;
+    std::vector<int64_t> out_shape(3);
+    for (int i = 0; i < 3; ++i) {
+        out_shape[i] = (in_shape[i] + 2 * padding[i] - dilation[i] * (kernel_size[i] - 1) - 1) / stride[i] + 1;
+    }
+    return out_shape;
+}
+
+ov::OutputVector sparse_conv_impl(const ov::frontend::onnx::Node& node, bool subm) {
+    auto inputs = node.get_ov_inputs();
+    CHECK_VALID_NODE(node, inputs.size() >= 5,
+                     "Expected >= 5 inputs (features, indices, spatial_shape, batch_size, weight). Got: ",
+                     inputs.size());
+
+    auto features = inputs[0];
+    auto coords = inputs[1];
+    auto spatial_shape_input = inputs[2];
+    auto weight = ensure_3d_weight(inputs[4]);
+
+    auto input_spatial_shape = get_constant_u32_values(spatial_shape_input);
+    CHECK_VALID_NODE(node, input_spatial_shape.size() == 3,
+                     "spatial_shape must be a Constant with 3 elements. Got: ", input_spatial_shape.size());
+
+    auto kernel_size = get_conv_param_dhw(node, "kernel_size", 3);
+    auto padding = get_conv_param_dhw(node, "padding", 1);
+    auto dilation = get_conv_param_dhw(node, "dilation", 1);
+    std::vector<int64_t> stride = subm ? std::vector<int64_t>{1, 1, 1} : get_conv_param_dhw(node, "stride", 1);
+
+    auto out_channels = to_u32_checked(node, "out_channels",
+        get_int_attr(node, "out_channels", 0));
+    if (out_channels == 0) {
+        const auto& w_ps = weight.get_partial_shape();
+        if (w_ps.rank().is_static() && w_ps.rank().get_length() == 3 && w_ps[2].is_static())
+            out_channels = w_ps[2].get_length();
+    }
+    CHECK_VALID_NODE(node, out_channels > 0, "Cannot determine out_channels.");
+
+    // New attributes
+    auto in_channels = to_u32_checked(node, "in_channels",
+        get_int_attr(node, "in_channels", 0));
+    auto activation = get_string_attr(node, "activation", "None");
+    auto output_bound = to_u32_checked(node, "output_bound",
+        get_int_attr(node, "output_bound", 0));
+    auto rulebook = get_string_attr(node, "rulebook", "");
+
+    // Compute output spatial shape
+    auto out_ss = compute_output_spatial_shape(input_spatial_shape, kernel_size, stride, padding, dilation, subm);
+
+    bool has_bias = inputs.size() > 5;
+    if (has_bias) {
+        const auto& bias_ps = inputs[5].get_partial_shape();
+        if (bias_ps.rank().is_static() && bias_ps.rank().get_length() >= 1 &&
+            bias_ps[0].is_static() && bias_ps[0].get_length() == 0)
+            has_bias = false;
+    }
+
+    std::shared_ptr<ov::op::v15::SparseConvolution> sc_op;
+    if (has_bias) {
+        sc_op = std::make_shared<ov::op::v15::SparseConvolution>(
+            features, coords, weight, inputs[5],
+            kernel_size, stride, padding, dilation, subm, out_channels, input_spatial_shape,
+            in_channels, out_ss, activation, output_bound, rulebook);
+    } else {
+        sc_op = std::make_shared<ov::op::v15::SparseConvolution>(
+            features, coords, weight,
+            kernel_size, stride, padding, dilation, subm, out_channels, input_spatial_shape,
+            in_channels, out_ss, activation, output_bound, rulebook);
+    }
+
+    auto out_spatial_const = ov::op::v0::Constant::create(ov::element::i32, ov::Shape{3},
+        std::vector<int32_t>{static_cast<int32_t>(out_ss[0]),
+                             static_cast<int32_t>(out_ss[1]),
+                             static_cast<int32_t>(out_ss[2])});
+    auto out_batch_const = ov::op::v0::Constant::create(ov::element::i32, ov::Shape{1}, std::vector<int32_t>{1});
+
+    return {sc_op->output(0), sc_op->output(1), out_spatial_const, out_batch_const};
+}
+
+}  // anonymous namespace
+
+ov::OutputVector subm_conv3d(const ov::frontend::onnx::Node& node) {
+    return sparse_conv_impl(node, true);
+}
+
+ov::OutputVector sparse_conv3d(const ov::frontend::onnx::Node& node) {
+    return sparse_conv_impl(node, false);
+}
+
+bool register_translators(void) {
+    ONNX_OP_M("SubMConv3d", OPSET_SINCE(1), bevfusion::opset_1::subm_conv3d, "bevfusion");
+    ONNX_OP_M("SparseConv3d", OPSET_SINCE(1), bevfusion::opset_1::sparse_conv3d, "bevfusion");
+    return true;
+}
+
+static bool registered = register_translators();
+
+}  // namespace opset_1
+}  // namespace bevfusion
+
+}  // namespace onnx
+}  // namespace frontend
+}  // namespace ov
