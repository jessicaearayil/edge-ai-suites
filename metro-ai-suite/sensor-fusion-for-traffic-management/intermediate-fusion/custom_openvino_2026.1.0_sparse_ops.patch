+}
+
+void SparseToDense::validate_and_infer_types() {
+    NODE_VALIDATION_CHECK(this,
+                          get_input_size() == 4,
+                          "SparseToDense expects exactly 4 inputs. Got: ",
+                          get_input_size());
+
+    // Input 0: features [M, C] — must be floating-point
+    const auto feat_et = get_input_element_type(0);
+    NODE_VALIDATION_CHECK(this, feat_et.is_real(),
+                          "Input 0 (features) must be floating-point. Got: ", feat_et);
+    const auto feat_ps = get_input_partial_shape(0);
+    NODE_VALIDATION_CHECK(this, feat_ps.rank().compatible(2),
+                          "Input 0 (features) must be 2D [M, C]. Got: ", feat_ps);
+
+    // Input 1: indices [M, 4] — must be integer
+    const auto idx_et = get_input_element_type(1);
+    NODE_VALIDATION_CHECK(this, idx_et.is_integral(),
+                          "Input 1 (indices) must be integer. Got: ", idx_et);
+    const auto idx_ps = get_input_partial_shape(1);
+    NODE_VALIDATION_CHECK(this, idx_ps.rank().compatible(2),
+                          "Input 1 (indices) must be 2D [M, 4]. Got: ", idx_ps);
+
+    // Input 2: spatial_shape [3] — must be integer
+    const auto ss_et = get_input_element_type(2);
+    NODE_VALIDATION_CHECK(this, ss_et.is_integral(),
+                          "Input 2 (spatial_shape) must be integer. Got: ", ss_et);
+
+    // Input 3: batch_size — must be integer
+    const auto bs_et = get_input_element_type(3);
+    NODE_VALIDATION_CHECK(this, bs_et.is_integral(),
+                          "Input 3 (batch_size) must be integer. Got: ", bs_et);
+
+    // Extract C from features dim-1
+    Dimension c_dim = Dimension::dynamic();
+    if (feat_ps.rank().is_static() && feat_ps.rank().get_length() == 2)
+        c_dim = feat_ps[1];
+
+    // Try to read spatial_shape and batch_size from Constant inputs
+    int64_t Z = -1, Y = -1, X = -1, B = -1;
+
+    auto ss_const = std::dynamic_pointer_cast<op::v0::Constant>(
+        get_input_node_shared_ptr(2));
+    if (ss_const) {
+        auto vals = ss_const->cast_vector<int64_t>();
+        if (vals.size() == 3) {
+            Z = vals[0]; Y = vals[1]; X = vals[2];
+        }
+    }
+
+    auto bs_const = std::dynamic_pointer_cast<op::v0::Constant>(
+        get_input_node_shared_ptr(3));
+    if (bs_const) {
+        auto vals = bs_const->cast_vector<int64_t>();
+        if (!vals.empty())
+            B = vals[0];
+    }
+
+    auto b_dim = B > 0 ? Dimension(B) : Dimension::dynamic();
+    auto z_dim = Z > 0 ? Dimension(Z) : Dimension::dynamic();
+    auto y_dim = Y > 0 ? Dimension(Y) : Dimension::dynamic();
+    auto x_dim = X > 0 ? Dimension(X) : Dimension::dynamic();
+
+    if (m_fuse_permute_reshape) {
+        // Fused 4D output: fold X into C → C*X
+        Dimension cx_dim = Dimension::dynamic();
+        if (c_dim.is_static() && x_dim.is_static())
+            cx_dim = Dimension(c_dim.get_length() * x_dim.get_length());
+
+        if (m_channels_first)
+            set_output_type(0, feat_et, PartialShape{b_dim, cx_dim, z_dim, y_dim});
+        else
+            set_output_type(0, feat_et, PartialShape{b_dim, z_dim, y_dim, cx_dim});
+    } else {
+        // Non-fused 5D output
+        if (m_channels_first)
+            set_output_type(0, feat_et, PartialShape{b_dim, c_dim, z_dim, y_dim, x_dim});
+        else
+            set_output_type(0, feat_et, PartialShape{b_dim, z_dim, y_dim, x_dim, c_dim});
+    }
+}
+
+std::shared_ptr<Node> SparseToDense::clone_with_new_inputs(const OutputVector& new_args) const {
+    check_new_args_count(this, new_args);
+    return std::make_shared<SparseToDense>(new_args[0], new_args[1], new_args[2], new_args[3],
+                                           m_channels_first, m_fuse_permute_reshape);
+}
+
+bool SparseToDense::evaluate(TensorVector& outputs, const TensorVector& inputs) const {
+    const auto& features = inputs[0];
+    const auto& indices = inputs[1];
+    const auto& spatial_shape_t = inputs[2];
+    const auto& batch_size_t = inputs[3];
+
+    const auto M = features.get_shape()[0];
+    const auto C = features.get_shape()[1];
+
+    // Read spatial_shape [Z, Y, X]
+    auto ss_data = spatial_shape_t.data<int32_t>();
+    const size_t Z = static_cast<size_t>(ss_data[0]);
+    const size_t Y = static_cast<size_t>(ss_data[1]);
+    const size_t X = static_cast<size_t>(ss_data[2]);
+
+    // Read batch_size
+    size_t B = 1;
+    if (batch_size_t.get_shape().empty()) {
+        B = static_cast<size_t>(*batch_size_t.data<int32_t>());
+    } else {
+        B = static_cast<size_t>(batch_size_t.data<int32_t>()[0]);
+    }
+
+    // Set output shape and zero-initialize
+    size_t out_len = 0;
+    if (m_fuse_permute_reshape) {
+        const size_t CX = C * X;
+        if (m_channels_first)
+            outputs[0].set_shape({B, CX, Z, Y});
+        else
+            outputs[0].set_shape({B, Z, Y, CX});
+        out_len = B * CX * Z * Y;
+    } else {
+        if (m_channels_first)
+            outputs[0].set_shape({B, C, Z, Y, X});
+        else
+            outputs[0].set_shape({B, Z, Y, X, C});
+        out_len = B * C * Z * Y * X;
+    }
+
+    auto* out = outputs[0].data<float>();
+    std::memset(out, 0, out_len * sizeof(float));
+
+    const auto* feat_data = features.data<float>();
+    const auto* idx_data = indices.data<int32_t>();
+
+    for (size_t i = 0; i < M; i++) {
+        const auto b = static_cast<size_t>(idx_data[i * 4 + 0]);
+        const auto z = static_cast<size_t>(idx_data[i * 4 + 1]);
+        const auto y = static_cast<size_t>(idx_data[i * 4 + 2]);
+        const auto x = static_cast<size_t>(idx_data[i * 4 + 3]);
+
+        if (b >= B || z >= Z || y >= Y || x >= X)
+            continue;
+
+        for (size_t c = 0; c < C; c++) {
+            size_t out_idx;
+            if (m_fuse_permute_reshape) {
+                const size_t CX = C * X;
+                if (m_channels_first)
+                    out_idx = ((b * CX + c * X + x) * Z + z) * Y + y;
+                else
+                    out_idx = ((b * Z + z) * Y + y) * CX + c * X + x;
+            } else {
+                if (m_channels_first)
+                    out_idx = ((((b * C + c) * Z + z) * Y + y) * X + x);
+                else
+                    out_idx = ((((b * Z + z) * Y + y) * X + x) * C + c);
+            }
+            out[out_idx] = feat_data[i * C + c];
+        }
+    }
+    return true;
+}
+
+bool SparseToDense::has_evaluate() const {
+    // Support CPU evaluate for f32 features with i32 indices
+    return get_input_element_type(0) == element::f32 &&
+           get_input_element_type(1) == element::i32;
+}
+
+}  // namespace v15
+}  // namespace op
+}  // namespace ov
