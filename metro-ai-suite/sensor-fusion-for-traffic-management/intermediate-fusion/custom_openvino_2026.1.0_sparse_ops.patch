diff --git a/src/plugins/intel_gpu/src/graph/sparse_convolution.cpp b/src/plugins/intel_gpu/src/graph/sparse_convolution.cpp
new file mode 100644
index 0000000000..12222866e0
--- /dev/null
+++ b/src/plugins/intel_gpu/src/graph/sparse_convolution.cpp
@@ -0,0 +1,88 @@
+// Copyright (C) 2018-2026 Intel Corporation
+// SPDX-License-Identifier: Apache-2.0
+//
+
+#include "sparse_convolution_inst.h"
+
+#include "json_object.h"
+#include "primitive_type_base.h"
+
+#include <sstream>
+#include <type_traits>
+
+namespace cldnn {
+GPU_DEFINE_PRIMITIVE_TYPE_ID(sparse_convolution)
+
+sparse_convolution_inst::typed_primitive_inst(network& network, sparse_convolution_node const& node)
+    : parent(network, node) {}
+
+layout sparse_convolution_inst::calc_output_layout(sparse_convolution_node const& node,
+                                                   kernel_impl_params const& impl_param) {
+    return calc_output_layouts<ov::PartialShape>(node, impl_param)[0];
+}
+
+template <typename ShapeType>
+std::vector<layout> sparse_convolution_inst::calc_output_layouts(sparse_convolution_node const& node,
+                                                                 kernel_impl_params const& impl_param) {
+    auto primitive = impl_param.typed_desc<sparse_convolution>();
+    const auto& input_layout = impl_param.get_input_layout(0);  // features [M_in, C_in]
+
+    // Output 0: features [M_out, C_out]
+    // Output 1: coords   [M_out, 4]
+    ShapeType feat_shape;
+    ShapeType coord_shape;
+
+    if constexpr (std::is_same_v<ShapeType, ov::PartialShape>) {
+        const auto input_shape = input_layout.get<ShapeType>();
+        ov::Dimension m_out;
+        if (primitive->subm) {
+            // SubMConv: M_out == M_in
+            m_out = (input_shape.rank().is_static() && input_shape.rank().get_length() > 0)
+                        ? input_shape[0]
+                        : ov::Dimension::dynamic();
+        } else if (primitive->output_bound > 0) {
+            // SparseConv with output_bound: pre-allocate buffer of specified size.
+            // The GPU plugin requires static shapes for buffer allocation.
+            m_out = ov::Dimension(static_cast<int64_t>(primitive->output_bound));
+        } else {
+            // SparseConv stride>1: M_out determined at runtime by downsample.
+            // Use M_in as initial allocation size — execute_impl handles the
+            // actual M_out via std::min(m_out, out_buf_m) clamping.
+            m_out = (input_shape.rank().is_static() && input_shape.rank().get_length() > 0)
+                        ? input_shape[0]
+                        : ov::Dimension::dynamic();
+        }
+        feat_shape = ShapeType{m_out, static_cast<int64_t>(primitive->out_channels)};
+        coord_shape = ShapeType{m_out, 4};
+    } else {
+        // Static shape path
+        const auto input_shape = input_layout.get<ShapeType>();
+        size_t m_out = (primitive->output_bound > 0 && !primitive->subm)
+                           ? static_cast<size_t>(primitive->output_bound)
+                           : static_cast<size_t>(input_shape[0]);
+        feat_shape = ShapeType{m_out, static_cast<size_t>(primitive->out_channels)};
+        coord_shape = ShapeType{m_out, size_t{4}};
+    }
+
+    return {layout{feat_shape, input_layout.data_type, format::bfyx},
+            layout{coord_shape, data_types::i32, format::bfyx}};
+}
+
+template std::vector<layout>
+sparse_convolution_inst::calc_output_layouts<ov::PartialShape>(sparse_convolution_node const& node,
+                                                               kernel_impl_params const& impl_param);
+
+std::string sparse_convolution_inst::to_string(sparse_convolution_node const& node) {
+    auto node_info = node.desc_to_json();
+    json_composite info;
+    info.add("input_features", node.input(0).id());
+    info.add("input_coords", node.input(1).id());
+    info.add("subm", node.get_primitive()->subm);
+    info.add("out_channels", node.get_primitive()->out_channels);
+    node_info->add("sparse_convolution info", info);
+    std::stringstream ss;
+    node_info->dump(ss);
+    return ss.str();
+}
+
+}  // namespace cldnn
diff --git a/src/plugins/intel_gpu/src/graph/sparse_to_dense.cpp b/src/plugins/intel_gpu/src/graph/sparse_to_dense.cpp
new file mode 100644
index 0000000000..87fc768821
--- /dev/null
+++ b/src/plugins/intel_gpu/src/graph/sparse_to_dense.cpp
@@ -0,0 +1,108 @@
+// Copyright (C) 2018-2026 Intel Corporation
+// SPDX-License-Identifier: Apache-2.0
+//
+
+#include "sparse_to_dense_inst.h"
+
+#include "json_object.h"
+#include "primitive_type_base.h"
+
+#include <sstream>
+#include <type_traits>
+
+namespace cldnn {
+GPU_DEFINE_PRIMITIVE_TYPE_ID(sparse_to_dense)
+
+sparse_to_dense_inst::typed_primitive_inst(network& network, sparse_to_dense_node const& node)
+    : parent(network, node) {}
+
+layout sparse_to_dense_inst::calc_output_layout(sparse_to_dense_node const& node,
+                                                kernel_impl_params const& impl_param) {
+    return calc_output_layouts<ov::PartialShape>(node, impl_param)[0];
+}
+
+template <typename ShapeType>
+std::vector<layout> sparse_to_dense_inst::calc_output_layouts(sparse_to_dense_node const& node,
+                                                              kernel_impl_params const& impl_param) {
+    auto primitive = impl_param.typed_desc<sparse_to_dense>();
+    const auto& feat_layout = impl_param.get_input_layout(0);  // features [M, C]
+
+    // Extract C from features layout
+    int64_t C = -1;
+    if constexpr (std::is_same_v<ShapeType, ov::PartialShape>) {
+        const auto feat_shape = feat_layout.get<ShapeType>();
+        if (feat_shape.rank().is_static() && feat_shape[1].is_static())
+            C = feat_shape[1].get_length();
+    } else {
+        const auto feat_shape = feat_layout.get<ShapeType>();
+        C = static_cast<int64_t>(feat_shape[1]);
+    }
+
+    // Read spatial_shape [Z, Y, X] and batch_size B from primitive attributes
+    // (stored at compile time, same pattern as SparseConvolution)
+    int64_t Z = primitive->spatial_shape.size() >= 3 ? primitive->spatial_shape[0] : 1;
+    int64_t Y = primitive->spatial_shape.size() >= 3 ? primitive->spatial_shape[1] : 1;
+    int64_t X = primitive->spatial_shape.size() >= 3 ? primitive->spatial_shape[2] : 1;
+    int64_t B = primitive->batch_size > 0 ? primitive->batch_size : 1;
+
+    ShapeType out_shape;
+
+    if (primitive->fuse_permute_reshape) {
+        int64_t CX = C > 0 ? C * X : X;
+
+        if constexpr (std::is_same_v<ShapeType, ov::PartialShape>) {
+            if (primitive->channels_first)
+                out_shape = ShapeType{B, CX, Z, Y};
+            else
+                out_shape = ShapeType{B, Z, Y, CX};
+        } else {
+            if (primitive->channels_first)
+                out_shape = ShapeType{static_cast<size_t>(B), static_cast<size_t>(CX),
+                                      static_cast<size_t>(Z), static_cast<size_t>(Y)};
+            else
+                out_shape = ShapeType{static_cast<size_t>(B), static_cast<size_t>(Z),
+                                      static_cast<size_t>(Y), static_cast<size_t>(CX)};
+        }
+    } else {
+        int64_t c_val = C > 0 ? C : 1;
+
+        if constexpr (std::is_same_v<ShapeType, ov::PartialShape>) {
+            if (primitive->channels_first)
+                out_shape = ShapeType{B, c_val, Z, Y, X};
+            else
+                out_shape = ShapeType{B, Z, Y, X, c_val};
+        } else {
+            if (primitive->channels_first)
+                out_shape = ShapeType{static_cast<size_t>(B), static_cast<size_t>(c_val),
+                                      static_cast<size_t>(Z), static_cast<size_t>(Y),
+                                      static_cast<size_t>(X)};
+            else
+                out_shape = ShapeType{static_cast<size_t>(B), static_cast<size_t>(Z),
+                                      static_cast<size_t>(Y), static_cast<size_t>(X),
+                                      static_cast<size_t>(c_val)};
+        }
+    }
+
+    // 4D fused → bfyx, 5D non-fused → bfzyx
+    auto out_fmt = primitive->fuse_permute_reshape ? format::bfyx : format::bfzyx;
+    return {layout{out_shape, feat_layout.data_type, out_fmt}};
+}
+
+template std::vector<layout>
+sparse_to_dense_inst::calc_output_layouts<ov::PartialShape>(sparse_to_dense_node const& node,
+                                                            kernel_impl_params const& impl_param);
+
+std::string sparse_to_dense_inst::to_string(sparse_to_dense_node const& node) {
+    auto node_info = node.desc_to_json();
+    json_composite info;
+    info.add("features", node.input(0).id());
+    info.add("indices", node.input(1).id());
+    info.add("channels_first", node.get_primitive()->channels_first);
+    info.add("fuse_permute_reshape", node.get_primitive()->fuse_permute_reshape);
+    node_info->add("sparse_to_dense info", info);
+    std::stringstream ss;
+    node_info->dump(ss);
+    return ss.str();
+}
+
+}  // namespace cldnn
