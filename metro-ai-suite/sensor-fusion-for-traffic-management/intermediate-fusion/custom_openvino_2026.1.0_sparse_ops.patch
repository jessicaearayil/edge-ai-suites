+        }
+        case ov::element::Type_t::u32: {
+            auto* p = itv_tensor.data<uint32_t>();
+            for (size_t i = 0; i < itv_count; ++i) {
+                p[i] = static_cast<uint32_t>(std::max<int64_t>(0, itv_values[i]));
+            }
+            break;
+        }
+        case ov::element::Type_t::u64: {
