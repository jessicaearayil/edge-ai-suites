+//
+
+#pragma once
+
+#include "sparse_convolution_inst.h"
+#include "registry/implementation_manager.hpp"
+
+namespace cldnn {
+namespace sycl {
+
+struct SparseConvolutionV15SyclImpl : public ImplementationManager {
+    OV_GPU_PRIMITIVE_IMPL("sycl::sparse_convolution")
+
+    SparseConvolutionV15SyclImpl(shape_types shape_type, ValidateFunc vf = nullptr)
+        : ImplementationManager(impl_types::sycl, shape_type, vf) {}
+
+    std::unique_ptr<primitive_impl> create_impl(const program_node& node, const kernel_impl_params& params) const override;
+
+    bool validate_impl(const program_node& node) const override {
+        assert(node.is_type<sparse_convolution>());
+
+        if (node.has_fused_primitives())
+            return false;
+
+        const auto num_inputs = node.get_input_layouts().size();
+        // 3 inputs (no bias) or 4 inputs (with bias)
+        if (num_inputs != 3 && num_inputs != 4)
+            return false;
+
+        // Input 0: features [M_in, C_in] — must be f32 or f16 with bfyx format
+        const auto& feat_layout = node.get_input_layout(0);
+        if (feat_layout.data_type != data_types::f32 && feat_layout.data_type != data_types::f16)
+            return false;
+        if (feat_layout.format != format::bfyx || feat_layout.data_padding)
+            return false;
+
+        // Input 1: coords [M_in, 4] — must be i32 with bfyx format
+        const auto& coord_layout = node.get_input_layout(1);
+        if (coord_layout.data_type != data_types::i32)
+            return false;
+        if (coord_layout.format != format::bfyx || coord_layout.data_padding)
+            return false;
+
+        // Input 2: weights [K_vol, C_in, C_out] — must match feature data type
+        const auto& weight_layout = node.get_input_layout(2);
+        if (weight_layout.data_type != data_types::f32 && weight_layout.data_type != data_types::f16)
+            return false;
+        if (weight_layout.format != format::bfyx || weight_layout.data_padding)
+            return false;
+
+        // Input 3 (optional): bias [C_out] — must match feature data type
+        if (num_inputs == 4) {
+            const auto& bias_layout = node.get_input_layout(3);
+            if (bias_layout.data_type != data_types::f32 && bias_layout.data_type != data_types::f16)
+                return false;
+            if (bias_layout.format != format::bfyx || bias_layout.data_padding)
+                return false;
+        }
+
+        return true;
+    }
+};
