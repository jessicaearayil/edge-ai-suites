+//
+
+#pragma once
+
+#include "primitive.hpp"
+
+namespace cldnn {
+
+/// @brief GPU primitive descriptor for SparseToDense.
+///
+/// Inputs:
+///   0: features      [M, C]   f16/f32   sparse point features
+///   1: indices        [M, 4]   i32       coords (batch, z, y, x)
+///   2: spatial_shape  [3]      i32       spatial dims [Z, Y, X]
+///   3: batch_size     []       i32       batch size B
+///
+/// Outputs:
+///   fuse=false: [B, C, Z, Y, X] or [B, Z, Y, X, C]  (5D)
+///   fuse=true:  [B, C*X, Z, Y] or [B, Z, Y, C*X]    (4D)
+struct sparse_to_dense : public primitive_base<sparse_to_dense> {
+    CLDNN_DECLARE_PRIMITIVE(sparse_to_dense)
+
+    sparse_to_dense() : primitive_base("", {}) {}
+
+    sparse_to_dense(const primitive_id& id,
+                    const std::vector<input_info>& inputs,
+                    bool channels_first = true,
+                    bool fuse_permute_reshape = false,
+                    std::vector<int32_t> spatial_shape = {},
+                    int32_t batch_size = 0)
+        : primitive_base(id, inputs),
+          channels_first(channels_first),
+          fuse_permute_reshape(fuse_permute_reshape),
+          spatial_shape(std::move(spatial_shape)),
+          batch_size(batch_size) {}
+
+    bool channels_first = true;
+    bool fuse_permute_reshape = false;
+    std::vector<int32_t> spatial_shape;  // [Z, Y, X] — compile-time constants
+    int32_t batch_size = 0;              // B — compile-time constant
+
+    size_t hash() const override {
+        size_t seed = primitive::hash();
+        seed = hash_combine(seed, channels_first);
+        seed = hash_combine(seed, fuse_permute_reshape);
+        seed = hash_combine(seed, batch_size);
+        for (auto v : spatial_shape) seed = hash_combine(seed, v);
+        return seed;
+    }
+
+    bool operator==(const primitive& rhs) const override {
+        if (!compare_common_params(rhs))
+            return false;
+        auto rhs_casted = downcast<const sparse_to_dense>(rhs);
+        return channels_first == rhs_casted.channels_first &&
+               fuse_permute_reshape == rhs_casted.fuse_permute_reshape &&
+               spatial_shape == rhs_casted.spatial_shape &&
+               batch_size == rhs_casted.batch_size;
+    }
+
+    void save(BinaryOutputBuffer& ob) const override {
+        primitive_base<sparse_to_dense>::save(ob);
+        ob << channels_first;
+        ob << fuse_permute_reshape;
+        ob << spatial_shape;
+        ob << batch_size;
+    }
+
+    void load(BinaryInputBuffer& ib) override {
+        primitive_base<sparse_to_dense>::load(ib);
+        ib >> channels_first;
+        ib >> fuse_permute_reshape;
+        ib >> spatial_shape;
+        ib >> batch_size;
+    }
+};
+
+}  // namespace cldnn
