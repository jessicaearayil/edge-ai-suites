+#!/usr/bin/env python3
+"""
+End-to-end validation of the full SparseEncoder ONNX model on OpenVINO GPU.
+
+Feeds the original BEVFusion voxel features + coordinates into the compiled
+sparse_encoder.onnx (21 SparseConv/SubMConv + 8 Add + 8 ReLU + 1 SparseToDense),
+and compares the dense [1, 128, 128, 128] output against the spconv reference
+dumped from PyTorch.
+
+This validates the ENTIRE inference chain — including error accumulation across
+21 convolution layers, residual Add/ReLU ops, and the final SparseToDense scatter.
+
+Usage:
+    # Preferred: use the wrapper, which sets PYTHONPATH / LD_LIBRARY_PATH to
+    # the locally built OpenVINO so the SparseConvolution / SparseToDense
+    # ONNX translators are picked up (the pip-installed openvino does not
+    # have them).
+    ./run_e2e.sh
+
+    # Manual invocation (all env vars on ONE line — no `\` line continuations):
+    OV_DIR=/home/jie/workspace/openvino/bin/intel64/Release \
+        PYTHONPATH="$OV_DIR/python:$PYTHONPATH" \
+        LD_LIBRARY_PATH="$OV_DIR:$LD_LIBRARY_PATH" \
+        /home/jie/env/spconvEnv/bin/python test_sparse_encoder_e2e.py \
+        --onnx /home/jie/workspace/openvino/test_data/sparse_encoder_new.onnx
+
+    # With options:
+    ./run_e2e.sh --fp32
+    ./run_e2e.sh --niter 5
+
+Default ONNX model location is test_data/sparse_encoder_new.onnx; override with
+--onnx if you exported a different model.
+"""
+
+import argparse
+import sys
+import time
+
+import numpy as np
+
+
+def resolve_gpu_device(ov_core, requested_device: str) -> tuple[str, str]:
+    """Resolve logical GPU device to a concrete OpenVINO target.
+
+    If requested_device is exactly "GPU", this picks a concrete GPU.x device.
+    Preference order: Arc/B580-like discrete devices first, then fallback to GPU.0.
+    Returns (device_name_to_use, human_readable_device_name).
+    """
+    if requested_device != "GPU":
+        return requested_device, requested_device
+
+    gpu_devices = [d for d in ov_core.available_devices if d.startswith("GPU")]
+    if not gpu_devices:
+        available = ", ".join(ov_core.available_devices)
+        raise RuntimeError(
+            "No Intel GPU device found in OpenVINO runtime. "
+            f"Available devices: [{available}]"
+        )
+
+    detailed = []
+    for dev in gpu_devices:
+        try:
+            full_name = str(ov_core.get_property(dev, "FULL_DEVICE_NAME"))
+        except Exception:
+            full_name = "Unknown GPU"
+        detailed.append((dev, full_name))
+
+    # Prefer likely discrete Arc/B580 class devices when present.
+    preferred_keywords = ("arc", "b580", "discrete", "max")
+    for dev, full_name in detailed:
+        lowered = full_name.lower()
+        if any(k in lowered for k in preferred_keywords):
+            return dev, full_name
+
+    # Fallback to the first GPU reported by runtime.
+    return detailed[0][0], detailed[0][1]
+
+
+def load_reference_data(dump_dir: str) -> dict:
+    """Load E2E reference data from the SparseEncoder dump.
+
+    Returns dict with keys: voxel_features, coors, spatial_features.
+    """
+    import os
+
+    npz_path = os.path.join(dump_dir, "module_encoders_lidar_backbone_SparseEncoder.npz")
+    data = np.load(npz_path)
+
+    return {
+        "voxel_features": data["voxel_features"],       # [N, 4] f32
+        "coors": data["coors"],                          # [N, 4] i32 — [batch, z, y, x]
+        "spatial_features": data["spatial_features"],    # [1, 128, 128, 128] f32
+    }
+
+
+def run_openvino_e2e(
+    ov_core,
+    onnx_path: str,
+    features: np.ndarray,
+    coords: np.ndarray,
+    device: str,
+    use_fp16: bool,
+    niter: int,
+) -> tuple[np.ndarray, list[float]]:
+    """Run full sparse encoder inference on OpenVINO GPU.
+
+    Returns (output_dense, latencies_ms).
+    """
+    model = ov_core.read_model(onnx_path)
+
+    # Set input precision — the ONNX model accepts f32 inputs;
+    # OpenVINO handles f32→f16 conversion internally when the plugin needs it
+    np_dtype = np.float16 if use_fp16 else np.float32
+    feat_input = features.astype(np_dtype)
+    coord_input = coords.astype(np.int32)
+
+    compiled = ov_core.compile_model(model, device)
+
+    # Warmup
+    compiled({0: feat_input, 1: coord_input})
+
+    # Timed iterations
+    latencies = []
+    output = None
+    for _ in range(niter):
+        t0 = time.perf_counter()
+        result = compiled({0: feat_input, 1: coord_input})
+        t1 = time.perf_counter()
+        latencies.append((t1 - t0) * 1000.0)
+        output = result[0]
+
+    return output, latencies
+
+
+def compare_dense_outputs(
+    ov_output: np.ndarray,
+    ref_output: np.ndarray,
+) -> dict:
+    """Compare OpenVINO dense output against spconv reference.
+
+    Returns a dict of metrics.
+    """
+    ov_f32 = ov_output.astype(np.float32)
+    ref_f32 = ref_output.astype(np.float32)
+
+    abs_diff = np.abs(ov_f32 - ref_f32)
+
+    # Overall metrics
+    max_abs_err = float(abs_diff.max())
+    mean_abs_err = float(abs_diff.mean())
+    ref_abs_max = float(np.abs(ref_f32).max())
+
+    # Relative error on non-zero reference positions
+    nonzero_mask = np.abs(ref_f32) > 1e-6
+    if nonzero_mask.any():
+        rel_diff = abs_diff[nonzero_mask] / np.abs(ref_f32[nonzero_mask])
+        max_rel_err = float(rel_diff.max())
+        mean_rel_err = float(rel_diff.mean())
+        p99_rel_err = float(np.percentile(rel_diff, 99))
+    else:
+        max_rel_err = 0.0
+        mean_rel_err = 0.0
+        p99_rel_err = 0.0
+
+    # Sparsity pattern comparison (zero vs non-zero)
+    ov_nonzero = ov_f32 != 0
+    ref_nonzero = ref_f32 != 0
+    ov_nnz = int(ov_nonzero.sum())
+    ref_nnz = int(ref_nonzero.sum())
+    pattern_match = int((ov_nonzero == ref_nonzero).sum())
+    total_elements = int(ref_f32.size)
+
+    # Cosine similarity on flattened vectors
+    ov_flat = ov_f32.flatten()
+    ref_flat = ref_f32.flatten()
+    dot = float(np.dot(ov_flat, ref_flat))
+    norm_ov = float(np.linalg.norm(ov_flat))
+    norm_ref = float(np.linalg.norm(ref_flat))
+    cosine_sim = dot / (norm_ov * norm_ref) if norm_ov > 0 and norm_ref > 0 else 0.0
+
+    return {
+        "max_abs_err": max_abs_err,
+        "mean_abs_err": mean_abs_err,
+        "ref_abs_max": ref_abs_max,
+        "max_rel_err": max_rel_err,
+        "mean_rel_err": mean_rel_err,
+        "p99_rel_err": p99_rel_err,
+        "ov_nnz": ov_nnz,
+        "ref_nnz": ref_nnz,
+        "pattern_match_pct": 100.0 * pattern_match / total_elements,
+        "cosine_similarity": cosine_sim,
+        "total_elements": total_elements,
+    }
+
+
+def main():
+    parser = argparse.ArgumentParser(
+        description="E2E validation of SparseEncoder ONNX on OpenVINO GPU"
+    )
+    parser.add_argument(
+        "--onnx",
+        type=str,
+        default="/home/jie/workspace/openvino/test_data/sparse_encoder_new.onnx",
+        help="Path to sparse_encoder.onnx (default points at test_data/)",
+    )
+    parser.add_argument(
+        "--dump-dir",
+        type=str,
+        default="/home/jie/workspace/openvino/test_data/sparse_encoder_dump",
+        help="Path to sparse_encoder_dump directory with reference data (default: test_data/)",
+    )
+    parser.add_argument("--device", type=str, default="GPU")
+    parser.add_argument(
+        "--fp32", action="store_true",
+        help="Feed FP32 inputs (default: FP16)",
+    )
+    parser.add_argument(
+        "--niter", type=int, default=3,
+        help="Number of timed inference iterations (default: 3)",
+    )
+    parser.add_argument(
+        "--atol", type=float, default=0.5,
+        help="Absolute error tolerance for PASS/FAIL (default: 0.5)",
+    )
+    parser.add_argument(
+        "--rtol", type=float, default=0.1,
+        help="Relative error P99 tolerance for PASS/FAIL (default: 0.1 = 10%%)",
+    )
+    parser.add_argument(
+        "--cosine-tol", type=float, default=0.99,
+        help="Minimum cosine similarity for PASS (default: 0.99)",
+    )
+    args = parser.parse_args()
+
+    import openvino as ov
+
+    use_fp16 = not args.fp32
+    core = ov.Core()
+    selected_device, selected_device_name = resolve_gpu_device(core, args.device)
+
+    print(f"OpenVINO version : {ov.__version__}")
+    print(f"Device (arg)     : {args.device}")
+    print(f"Device (resolved): {selected_device}")
+    print(f"GPU name         : {selected_device_name}")
+    print(f"Input precision  : {'FP16' if use_fp16 else 'FP32'}")
+    print(f"ONNX model       : {args.onnx}")
+    print(f"Dump directory   : {args.dump_dir}")
+    print(f"Iterations       : {args.niter}")
+    print()
+
+    # ------------------------------------------------------------------
+    # Load reference data
+    # ------------------------------------------------------------------
+    print("Loading reference data ...")
+    ref = load_reference_data(args.dump_dir)
+    n_voxels = ref["voxel_features"].shape[0]
+    in_channels = ref["voxel_features"].shape[1]
+    ref_shape = ref["spatial_features"].shape
+    print(f"  Input voxels   : {n_voxels} x {in_channels}")
+    print(f"  Reference shape: {ref_shape}")
+    print()
+
+    # ------------------------------------------------------------------
+    # Run OpenVINO inference
+    # ------------------------------------------------------------------
+    print("Running OpenVINO inference ...")
+    ov_output, latencies = run_openvino_e2e(
+        core,
+        args.onnx,
+        ref["voxel_features"],
+        ref["coors"],
+        selected_device,
+        use_fp16,
+        args.niter,
+    )
+    print(f"  Output shape   : {ov_output.shape}")
+    print(f"  Latency (ms)   : {', '.join(f'{t:.1f}' for t in latencies)}")
+    print(f"  Median latency : {np.median(latencies):.1f} ms")
+    print(f"  FPS            : {1000.0 / np.median(latencies):.1f}")
+    print()
+
+    # ------------------------------------------------------------------
+    # Compare against reference
+    # ------------------------------------------------------------------
+    print("Comparing against spconv reference ...")
+    metrics = compare_dense_outputs(ov_output, ref["spatial_features"])
+
+    print(f"  Output shape         : {ov_output.shape}")
+    print(f"  Reference range      : [0, {metrics['ref_abs_max']:.4f}]")
+    print()
+    print(f"  Max absolute error   : {metrics['max_abs_err']:.6f}")
+    print(f"  Mean absolute error  : {metrics['mean_abs_err']:.6f}")
+    print(f"  Max relative error   : {metrics['max_rel_err']:.4f}  ({metrics['max_rel_err']*100:.2f}%)")
+    print(f"  Mean relative error  : {metrics['mean_rel_err']:.4f}  ({metrics['mean_rel_err']*100:.2f}%)")
+    print(f"  P99 relative error   : {metrics['p99_rel_err']:.4f}  ({metrics['p99_rel_err']*100:.2f}%)")
+    print()
+    print(f"  Cosine similarity    : {metrics['cosine_similarity']:.8f}")
+    print(f"  OV non-zero elements : {metrics['ov_nnz']}")
+    print(f"  Ref non-zero elements: {metrics['ref_nnz']}")
+    print(f"  Sparsity pattern     : {metrics['pattern_match_pct']:.2f}% match")
+    print()
+
+    # ------------------------------------------------------------------
+    # PASS / FAIL verdict
+    # ------------------------------------------------------------------
+    checks = {
+        f"max_abs_err <= {args.atol}": metrics["max_abs_err"] <= args.atol,
+        f"p99_rel_err <= {args.rtol} ({args.rtol*100:.0f}%)": metrics["p99_rel_err"] <= args.rtol,
+        f"cosine_similarity >= {args.cosine_tol}": metrics["cosine_similarity"] >= args.cosine_tol,
+    }
+
+    all_pass = all(checks.values())
+    print("=" * 70)
+    print("VERDICT")
+    print("=" * 70)
+    for desc, passed in checks.items():
+        status = "PASS" if passed else "FAIL"
+        print(f"  [{status}] {desc}")
+    print()
+    print(f"  Overall: {'PASS' if all_pass else 'FAIL'}")
+    print(f"  Median latency: {np.median(latencies):.1f} ms ({1000.0 / np.median(latencies):.1f} FPS)")
+
+    return 0 if all_pass else 1
+
+
+if __name__ == "__main__":
+    sys.exit(main())
