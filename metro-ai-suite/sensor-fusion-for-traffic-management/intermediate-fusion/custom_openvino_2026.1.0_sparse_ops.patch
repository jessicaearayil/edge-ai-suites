+// Copyright (C) 2018-2026 Intel Corporation
+// SPDX-License-Identifier: Apache-2.0
+//
+
+#include "openvino/op/sparse_convolution.hpp"
+
+#include <algorithm>
+#include <numeric>
+
+#include "itt.hpp"
+
+namespace ov {
+namespace op {
+namespace v15 {
+
+SparseConvolution::SparseConvolution(const Output<Node>& input_features,
+                                     const Output<Node>& input_coords,
+                                     const Output<Node>& weights,
+                                     std::vector<int64_t> kernel_size,
+                                     std::vector<int64_t> stride,
+                                     std::vector<int64_t> padding,
+                                     std::vector<int64_t> dilation,
+                                     bool subm,
+                                     int64_t out_channels,
+                                     std::vector<int64_t> input_spatial_shape,
+                                     int64_t in_channels,
+                                     std::vector<int64_t> output_spatial_shape,
+                                     std::string activation,
+                                     int64_t output_bound,
+                                     std::string rulebook)
+    : Op({input_features, input_coords, weights}),
+      m_kernel_size(std::move(kernel_size)),
+      m_stride(std::move(stride)),
+      m_padding(std::move(padding)),
+      m_dilation(std::move(dilation)),
+      m_subm(subm),
+      m_out_channels(out_channels),
+      m_in_channels(in_channels),
+      m_input_spatial_shape(std::move(input_spatial_shape)),
+      m_output_spatial_shape(std::move(output_spatial_shape)),
+      m_activation(std::move(activation)),
+      m_output_bound(output_bound),
+      m_rulebook(std::move(rulebook)) {
+    constructor_validate_and_infer_types();
+}
+
+SparseConvolution::SparseConvolution(const Output<Node>& input_features,
+                                     const Output<Node>& input_coords,
+                                     const Output<Node>& weights,
+                                     const Output<Node>& bias,
+                                     std::vector<int64_t> kernel_size,
+                                     std::vector<int64_t> stride,
+                                     std::vector<int64_t> padding,
+                                     std::vector<int64_t> dilation,
+                                     bool subm,
+                                     int64_t out_channels,
+                                     std::vector<int64_t> input_spatial_shape,
+                                     int64_t in_channels,
+                                     std::vector<int64_t> output_spatial_shape,
+                                     std::string activation,
+                                     int64_t output_bound,
+                                     std::string rulebook)
+    : Op({input_features, input_coords, weights, bias}),
+      m_kernel_size(std::move(kernel_size)),
+      m_stride(std::move(stride)),
+      m_padding(std::move(padding)),
+      m_dilation(std::move(dilation)),
+      m_subm(subm),
+      m_out_channels(out_channels),
+      m_in_channels(in_channels),
+      m_input_spatial_shape(std::move(input_spatial_shape)),
+      m_output_spatial_shape(std::move(output_spatial_shape)),
+      m_activation(std::move(activation)),
+      m_output_bound(output_bound),
+      m_rulebook(std::move(rulebook)) {
+    constructor_validate_and_infer_types();
+}
+
+bool SparseConvolution::visit_attributes(AttributeVisitor& visitor) {
+    visitor.on_attribute("kernel_size", m_kernel_size);
+    visitor.on_attribute("stride", m_stride);
+    visitor.on_attribute("padding", m_padding);
+    visitor.on_attribute("dilation", m_dilation);
+    visitor.on_attribute("subm", m_subm);
+    visitor.on_attribute("out_channels", m_out_channels);
+    visitor.on_attribute("in_channels", m_in_channels);
+    visitor.on_attribute("input_spatial_shape", m_input_spatial_shape);
+    visitor.on_attribute("output_spatial_shape", m_output_spatial_shape);
+    visitor.on_attribute("activation", m_activation);
+    visitor.on_attribute("output_bound", m_output_bound);
+    visitor.on_attribute("rulebook", m_rulebook);
+    // Per-tensor activation abs-max from PTQ (0 == not set). Round-trips
+    // through IR xml so a once-computed value survives save_model / read_model.
+    visitor.on_attribute("input_abs_max", m_input_abs_max);
+    visitor.on_attribute("output_abs_max", m_output_abs_max);
+    visitor.on_attribute("input_handoff_producer", m_input_handoff_producer);
+    return true;
+}
+
+void SparseConvolution::validate_and_infer_types() {
+    const auto num_inputs = get_input_size();
+    NODE_VALIDATION_CHECK(this,
+                          num_inputs == 3 || num_inputs == 4,
+                          "SparseConvolution expects 3 or 4 inputs (features, coords, weights[, bias]). Got: ",
+                          num_inputs);
+
+    NODE_VALIDATION_CHECK(this, m_out_channels > 0, "out_channels must be > 0.");
+    NODE_VALIDATION_CHECK(this, m_kernel_size.size() == 3, "kernel_size must have 3 elements.");
+    NODE_VALIDATION_CHECK(this, m_stride.size() == 3, "stride must have 3 elements.");
+    NODE_VALIDATION_CHECK(this, m_padding.size() == 3, "padding must have 3 elements.");
+    NODE_VALIDATION_CHECK(this, m_dilation.size() == 3, "dilation must have 3 elements.");
+    NODE_VALIDATION_CHECK(this, m_input_spatial_shape.size() == 3, "input_spatial_shape must have 3 elements.");
+
+    // Validate input types
+    const auto feat_et = get_input_element_type(0);
+    NODE_VALIDATION_CHECK(this, feat_et.is_real(), "Input 0 (features) must be floating-point. Got: ", feat_et);
+
+    const auto coord_et = get_input_element_type(1);
+    NODE_VALIDATION_CHECK(this,
+                          coord_et == element::i32,
+                          "Input 1 (coords) must be i32. Got: ",
+                          coord_et);
+
+    const auto weight_et = get_input_element_type(2);
+    NODE_VALIDATION_CHECK(this,
+                          weight_et.is_real(),
+                          "Input 2 (weights) must be floating-point. Got: ",
+                          weight_et);
+
+    if (num_inputs == 4) {
+        const auto bias_et = get_input_element_type(3);
+        NODE_VALIDATION_CHECK(this,
+                              bias_et.is_real(),
+                              "Input 3 (bias) must be floating-point. Got: ",
+                              bias_et);
+    }
+
+    // Validate shapes
+    const auto feat_ps = get_input_partial_shape(0);   // [M_in, C_in]
+    NODE_VALIDATION_CHECK(this,
+                          feat_ps.rank().compatible(2),
+                          "Input 0 (features) must be 2D [M_in, C_in]. Got: ",
+                          feat_ps);
+
+    const auto coord_ps = get_input_partial_shape(1);  // [M_in, 4]
+    NODE_VALIDATION_CHECK(this,
+                          coord_ps.rank().compatible(2),
+                          "Input 1 (coords) must be 2D [M_in, 4]. Got: ",
+                          coord_ps);
+
+    const auto weight_ps = get_input_partial_shape(2); // [K_vol, C_in, C_out]
+    NODE_VALIDATION_CHECK(this,
+                          weight_ps.rank().compatible(3),
+                          "Input 2 (weights) must be 3D [K_vol, C_in, C_out]. Got: ",
+                          weight_ps);
+
+    // Determine M_out
+    Dimension m_out;
+    if (m_subm) {
+        // SubMConv: output points == input points
+        m_out = feat_ps.rank().is_static() ? feat_ps[0] : Dimension::dynamic();
+    } else {
+        // SparseConv: output points determined at runtime by downsample
+        m_out = Dimension::dynamic();
+    }
+
+    // Output 0: features [M_out, C_out]
+    set_output_type(0, feat_et, PartialShape{m_out, m_out_channels});
+    // Output 1: coords [M_out, 4]
+    set_output_type(1, element::i32, PartialShape{m_out, 4});
+}
+
+std::shared_ptr<Node> SparseConvolution::clone_with_new_inputs(const OutputVector& new_args) const {
+    check_new_args_count(this, new_args);
+    std::shared_ptr<SparseConvolution> cloned;
+    if (new_args.size() == 4) {
+        cloned = std::make_shared<SparseConvolution>(new_args[0], new_args[1], new_args[2], new_args[3],
+                                                     m_kernel_size, m_stride, m_padding, m_dilation,
+                                                     m_subm, m_out_channels, m_input_spatial_shape,
+                                                     m_in_channels, m_output_spatial_shape,
+                                                     m_activation, m_output_bound, m_rulebook);
+    } else {
+        cloned = std::make_shared<SparseConvolution>(new_args[0], new_args[1], new_args[2],
+                                                     m_kernel_size, m_stride, m_padding, m_dilation,
+                                                     m_subm, m_out_channels, m_input_spatial_shape,
+                                                     m_in_channels, m_output_spatial_shape,
+                                                     m_activation, m_output_bound, m_rulebook);
+    }
+    // Carry the PTQ input abs-max through clone — otherwise any pass that
+    // recreates the node via clone_with_new_inputs (LPT, common passes, etc.)
+    // would silently reset it to 0 and force the kernel onto the online path.
+    cloned->m_input_abs_max = m_input_abs_max;
+    cloned->m_output_abs_max = m_output_abs_max;
+    cloned->m_input_handoff_producer = m_input_handoff_producer;
+    return cloned;
+}
+
+bool SparseConvolution::evaluate(TensorVector& outputs, const TensorVector& inputs) const {
+    // CPU reference implementation — will be added later if needed for testing.
+    // For now, GPU-only execution is sufficient.
+    return false;
+}
+
+bool SparseConvolution::has_evaluate() const {
+    return false;
+}
+
