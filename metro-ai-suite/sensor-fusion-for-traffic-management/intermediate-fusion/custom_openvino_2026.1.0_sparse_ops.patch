new file mode 100644
index 0000000000..13c6663887
--- /dev/null
+++ b/src/plugins/intel_gpu/src/plugin/transformations/eat_sparse_conv_input_fakequantize.cpp
@@ -0,0 +1,115 @@
+// Copyright (C) 2018-2026 Intel Corporation
+// SPDX-License-Identifier: Apache-2.0
+//
+
+#include "eat_sparse_conv_input_fakequantize.hpp"
+
+#include <algorithm>
+#include <cmath>
+#include <memory>
+
+#include "openvino/op/constant.hpp"
+#include "openvino/op/convert.hpp"
+#include "openvino/op/fake_quantize.hpp"
+#include "openvino/op/sparse_convolution.hpp"
+#include "openvino/pass/pattern/op/wrap_type.hpp"
+#include "openvino/util/log.hpp"
+
+namespace ov::intel_gpu {
+
+namespace {
+
+/// Walk through optional `Convert` nodes (LPT frequently sandwiches them)
+/// to find the real Constant producing the FakeQuantize range.
+std::shared_ptr<ov::op::v0::Constant> as_range_constant(const ov::Output<ov::Node>& in) {
+    auto node = in.get_node_shared_ptr();
+    while (ov::is_type<ov::op::v0::Convert>(node)) {
+        if (node->get_input_size() == 0)
+            return nullptr;
+        node = node->get_input_node_shared_ptr(0);
+    }
+    return ov::as_type_ptr<ov::op::v0::Constant>(node);
+}
+
+/// Symmetric abs-max from a (potentially per-channel) range constant.
+/// Returns 0 if the data can't be read.
+float abs_max_from_constant(const std::shared_ptr<ov::op::v0::Constant>& c) {
+    if (!c) return 0.0f;
+    const auto values = c->cast_vector<float>();
+    float m = 0.0f;
+    for (float v : values) m = std::max(m, std::fabs(v));
+    return m;
+}
+
+}  // namespace
+
+EatSparseConvInputFakeQuantize::EatSparseConvInputFakeQuantize() {
+    // Match any SparseConvolution and dispatch on its port-0 producer in
+    // the callback. Constraining the pattern on port 0 (FakeQuantize)
+    // failed to match in practice because the pattern matcher insists on
+    // the Op taking exactly N inputs; SparseConv has 3 or 4 (optional
+    // bias), and `wrap_type<SparseConvolution>({fq, any, any})` doesn't
+    // match the 4-input variant. Matching on the op alone sidesteps the
+    // arity mismatch.
+    auto sc = ov::pass::pattern::wrap_type<ov::op::v15::SparseConvolution>();
+
+    matcher_pass_callback cb = [](ov::pass::pattern::Matcher& m) {
+        auto sparse_conv = ov::as_type_ptr<ov::op::v15::SparseConvolution>(m.get_match_root());
+        if (!sparse_conv) return false;
+
+        if (std::getenv("EAT_FQ_TRACE")) {
+            auto p0 = sparse_conv->input_value(0).get_node_shared_ptr();
+            fprintf(stderr, "[EatSparseConvInputFakeQuantize] matched %s, port0=%s(%s)\n",
+                    sparse_conv->get_friendly_name().c_str(),
+                    p0->get_type_name(),
+                    p0->get_friendly_name().c_str());
+        }
+
+        // Only symmetric 8-bit PTQ ranges are supported. Other levels (binary,
+        // 4-bit, etc.) would need a different kernel path.
+        auto fq_node = ov::as_type_ptr<ov::op::v0::FakeQuantize>(
+            sparse_conv->input_value(0).get_node_shared_ptr());
+        if (!fq_node) {
+            if (std::getenv("EAT_FQ_TRACE"))
+                fprintf(stderr, "  → port0 not FakeQuantize, skipping\n");
+            return false;
+        }
+        if (fq_node->get_levels() != 256) return false;
+
+        // FakeQuantize inputs: 0=data, 1=input_low, 2=input_high,
+        //                      3=output_low, 4=output_high.
+        // Use output_low/output_high for the symmetric quantization range —
+        // NNCF places the post-quantized scale there.
+        auto low_c  = as_range_constant(fq_node->input_value(3));
+        auto high_c = as_range_constant(fq_node->input_value(4));
+        float lo_abs = abs_max_from_constant(low_c);
+        float hi_abs = abs_max_from_constant(high_c);
+        float abs_max = std::max(lo_abs, hi_abs);
+
+        if (!(abs_max > 0.0f)) {
+            // Zero or missing range — fall through to the runtime on-line
+            // abs-max reduction path.
+            return false;
+        }
+
+        // Idempotent: don't clobber a previously set value with the same
+        // number (the pass should be run once, but guard just in case).
+        if (sparse_conv->get_input_abs_max() > 0.0f)
+            return false;
+
+        sparse_conv->set_input_abs_max(abs_max);
+        if (std::getenv("EAT_FQ_TRACE")) {
+            fprintf(stderr, "[EatSparseConvInputFakeQuantize] %s abs_max=%.6f\n",
+                    sparse_conv->get_friendly_name().c_str(), abs_max);
+        }
+        // Return false — we haven't changed the graph topology, only an
+        // attribute of the SparseConv node. The matcher will continue.
+        return false;
+    };
+
+    auto matcher = std::make_shared<ov::pass::pattern::Matcher>(
+        sc, "EatSparseConvInputFakeQuantize");
+    register_matcher(matcher, cb);
+}
+
+}  // namespace ov::intel_gpu
diff --git a/src/plugins/intel_gpu/src/plugin/transformations/eat_sparse_conv_input_fakequantize.hpp b/src/plugins/intel_gpu/src/plugin/transformations/eat_sparse_conv_input_fakequantize.hpp
new file mode 100644
index 0000000000..aeca464a59
--- /dev/null
+++ b/src/plugins/intel_gpu/src/plugin/transformations/eat_sparse_conv_input_fakequantize.hpp
@@ -0,0 +1,38 @@
+// Copyright (C) 2018-2026 Intel Corporation
+// SPDX-License-Identifier: Apache-2.0
+//
+
+#pragma once
+
+#include "openvino/pass/graph_rewrite.hpp"
+#include "openvino/core/visibility.hpp"
+
+namespace ov::intel_gpu {
+
+/// Records the activation-side PTQ scale on each v15::SparseConvolution by
+/// looking at the FakeQuantize sitting on its port 0.
+///
+/// NNCF's PTQ output puts a FakeQuantize (levels=256) directly in front of
+/// every SparseConv activation input. The FakeQuantize's output_low /
+/// output_high carry the calibrated quantization range. LPT will later
+/// decompose that FakeQuantize into `quantize_to_u8 → Multiply(dequant)`
+/// on the same edge; the fp16 data SparseConv sees afterwards is
+/// effectively `q_u8 * (abs_max / 127)` with a single per-tensor scale.
+///
+/// Our GPU INT8 kernel used to recover that scale per-frame with an
+/// on-line abs-max reduce; for PTQ-quantised models we can skip the
+/// reduce and just use the calibrated `abs_max` from the FakeQuantize.
+/// This pass extracts it (max(|output_low|, |output_high|) → symmetric)
+/// and stashes it on the SparseConv op via `set_input_abs_max`. The
+/// FakeQuantize node itself is left untouched; downstream LPT still
+/// decomposes it as before.
+///
+/// Must run BEFORE LowPrecision in the GPU pipeline, so the
+/// FakeQuantize still matches as the direct producer of port 0.
+class EatSparseConvInputFakeQuantize : public ov::pass::MatcherPass {
+public:
+    OPENVINO_MATCHER_PASS_RTTI("EatSparseConvInputFakeQuantize");
+    EatSparseConvInputFakeQuantize();
+};
+
+}  // namespace ov::intel_gpu
diff --git a/src/plugins/intel_gpu/src/plugin/transformations/eat_sparse_conv_output_fakequantize.cpp b/src/plugins/intel_gpu/src/plugin/transformations/eat_sparse_conv_output_fakequantize.cpp
new file mode 100644
index 0000000000..5709f8d3e4
--- /dev/null
+++ b/src/plugins/intel_gpu/src/plugin/transformations/eat_sparse_conv_output_fakequantize.cpp
@@ -0,0 +1,145 @@
+// Copyright (C) 2018-2026 Intel Corporation
+// SPDX-License-Identifier: Apache-2.0
+//
+
+#include "eat_sparse_conv_output_fakequantize.hpp"
+
+#include <algorithm>
+#include <cmath>
+#include <memory>
+
+#include "openvino/op/constant.hpp"
+#include "openvino/op/convert.hpp"
+#include "openvino/op/fake_quantize.hpp"
+#include "openvino/op/relu.hpp"
+#include "openvino/op/sparse_convolution.hpp"
+#include "openvino/pass/pattern/op/wrap_type.hpp"
+#include "openvino/util/log.hpp"
+
+namespace ov::intel_gpu {
+
+namespace {
+
+std::shared_ptr<ov::op::v0::Constant> as_range_constant(const ov::Output<ov::Node>& in) {
+    auto node = in.get_node_shared_ptr();
+    while (ov::is_type<ov::op::v0::Convert>(node)) {
+        if (node->get_input_size() == 0)
+            return nullptr;
+        node = node->get_input_node_shared_ptr(0);
+    }
+    return ov::as_type_ptr<ov::op::v0::Constant>(node);
+}
+
+float abs_max_from_constant(const std::shared_ptr<ov::op::v0::Constant>& c) {
+    if (!c) return 0.0f;
+    const auto values = c->cast_vector<float>();
+    float m = 0.0f;
+    for (float v : values) m = std::max(m, std::fabs(v));
+    return m;
+}
+
+/// Walk the producer SparseConv's output 0 through a trivial, per-tensor-
+/// range-preserving chain to find a FakeQuantize+downstream SparseConv pair.
+///
+/// Accepts:
+///   SC_a → FakeQuantize(256) → SC_b
+///   SC_a → Relu → FakeQuantize(256) → SC_b
+///
+/// Rejects on any branch / fan-out (> 1 consumer on the producer output),
+/// on any Add / Concat / other op that changes the per-tensor range. When
+/// the FakeQuantize has multiple consumers we also reject — INT8 handoff
+/// is single-consumer by design (we don't want to materialise int8 for
+/// only one of several consumers).
+std::shared_ptr<ov::op::v15::SparseConvolution> find_handoff_consumer(
+    const std::shared_ptr<ov::op::v15::SparseConvolution>& producer,
+    std::shared_ptr<ov::op::v0::FakeQuantize>& out_fq)
+{
+    out_fq = nullptr;
+    auto out0 = producer->output(0);
+    if (out0.get_target_inputs().size() != 1)
+        return nullptr;
+
+    auto next = out0.get_target_inputs().begin()->get_node();
+    // Single hop: Relu between SparseConv and FakeQuantize is common for
+    // NNCF-quantised subm chains (subm1 → Relu → fq → subm2). We treat
+    // Relu as identity for range-tracking purposes because the downstream
+    // FakeQuantize re-calibrates the range.
+    if (ov::is_type<ov::op::v0::Relu>(next)) {
+        auto relu_out = next->output(0);
+        if (relu_out.get_target_inputs().size() != 1)
+            return nullptr;
+        next = relu_out.get_target_inputs().begin()->get_node();
+    }
+    auto fq = dynamic_cast<ov::op::v0::FakeQuantize*>(next);
+    if (!fq) return nullptr;
+    if (fq->get_levels() != 256) return nullptr;
+
+    // FakeQuantize must feed exactly one consumer, and that consumer must
+    // be another SparseConvolution (on port 0 — its activation input).
+    auto fq_out = fq->output(0);
+    if (fq_out.get_target_inputs().size() != 1)
+        return nullptr;
+    auto* fq_consumer_in = &*fq_out.get_target_inputs().begin();
+    auto* fq_consumer = fq_consumer_in->get_node();
+    if (fq_consumer_in->get_index() != 0)
+        return nullptr;  // only activation port counts
+    auto sc_b = dynamic_cast<ov::op::v15::SparseConvolution*>(fq_consumer);
+    if (!sc_b) return nullptr;
+
+    out_fq = std::dynamic_pointer_cast<ov::op::v0::FakeQuantize>(next->shared_from_this());
+    return std::dynamic_pointer_cast<ov::op::v15::SparseConvolution>(sc_b->shared_from_this());
+}
+
+}  // namespace
+
+EatSparseConvOutputFakeQuantize::EatSparseConvOutputFakeQuantize() {
+    auto sc = ov::pass::pattern::wrap_type<ov::op::v15::SparseConvolution>();
+
+    matcher_pass_callback cb = [](ov::pass::pattern::Matcher& m) {
+        auto producer = ov::as_type_ptr<ov::op::v15::SparseConvolution>(m.get_match_root());
+        if (!producer) return false;
+
+        std::shared_ptr<ov::op::v0::FakeQuantize> fq;
+        auto consumer = find_handoff_consumer(producer, fq);
+        if (!consumer || !fq) {
+            if (std::getenv("EAT_FQ_TRACE"))
+                fprintf(stderr, "[EatSparseConvOutputFakeQuantize] %s — no direct SC→FQ→SC chain\n",
+                        producer->get_friendly_name().c_str());
+            return false;
+        }
+
+        // Extract the FakeQuantize's input range (output_low / output_high).
+        auto low_c  = as_range_constant(fq->input_value(3));
+        auto high_c = as_range_constant(fq->input_value(4));
+        float lo = abs_max_from_constant(low_c);
+        float hi = abs_max_from_constant(high_c);
+        float abs_max = std::max(lo, hi);
+        if (!(abs_max > 0.0f)) return false;
+
+        // Idempotent: only set once. A SparseConv can only have one
+        // "downstream handoff" target anyway (single-consumer rule above).
+        if (producer->get_output_abs_max() > 0.0f)
+            return false;
+
+        producer->set_output_abs_max(abs_max);
+        // Tag the consumer with the producer's friendly name. The SYCL impl
+        // looks up the handoff buffer by this string at execute time — buffer
+        // pointer matching doesn't work because LPT inserts a Multiply
+        // (dequant) on the producer→consumer edge that rewrites the pointer.
+        consumer->set_input_handoff_producer(producer->get_friendly_name());
+        if (std::getenv("EAT_FQ_TRACE")) {
+            fprintf(stderr, "[EatSparseConvOutputFakeQuantize] %s → %s  abs_max=%.6f\n",
+                    producer->get_friendly_name().c_str(),
+                    consumer->get_friendly_name().c_str(),
+                    abs_max);
+        }
+        // No graph-topology change, only an attribute on producer.
+        return false;
+    };
+
+    auto matcher = std::make_shared<ov::pass::pattern::Matcher>(
+        sc, "EatSparseConvOutputFakeQuantize");
+    register_matcher(matcher, cb);
+}
+
+}  // namespace ov::intel_gpu
