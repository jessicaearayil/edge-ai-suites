+// Copyright (C) 2018-2026 Intel Corporation
+// SPDX-License-Identifier: Apache-2.0
+//
+
+#include "openvino/op/sparse_convolution.hpp"
+
+#include "intel_gpu/plugin/common_utils.hpp"
+#include "intel_gpu/plugin/program_builder.hpp"
+#include "intel_gpu/primitives/sparse_convolution.hpp"
+
+namespace ov::intel_gpu {
+
+static void CreateSparseConvolutionOp(ProgramBuilder& p,
+                                      const std::shared_ptr<ov::op::v15::SparseConvolution>& op) {
+    // 3 inputs (no bias) or 4 inputs (with bias)
+    validate_inputs_count(op, {3, 4});
+    auto inputs = p.GetInputInfo(op);
+
+    // IR op stores attributes as int64_t (serializer requirement); the cldnn
+    // primitive still uses uint32_t for compactness. Narrow here.
+    auto to_u32_vec = [](const std::vector<int64_t>& v) {
+        std::vector<uint32_t> out;
+        out.reserve(v.size());
+        for (auto x : v) out.push_back(static_cast<uint32_t>(x));
+        return out;
+    };
+
+    auto prim = cldnn::sparse_convolution(layer_type_name_ID(op),
+                                          inputs,
+                                          to_u32_vec(op->get_kernel_size()),
+                                          to_u32_vec(op->get_stride()),
+                                          to_u32_vec(op->get_padding()),
+                                          to_u32_vec(op->get_dilation()),
+                                          op->is_subm(),
+                                          static_cast<uint32_t>(op->get_out_channels()),
+                                          to_u32_vec(op->get_input_spatial_shape()),
+                                          static_cast<uint32_t>(op->get_in_channels()),
+                                          to_u32_vec(op->get_output_spatial_shape()),
+                                          op->get_activation(),
+                                          static_cast<uint32_t>(op->get_output_bound()),
+                                          op->get_rulebook(),
+                                          op->get_input_abs_max(),
+                                          op->get_output_abs_max(),
+                                          op->get_input_handoff_producer());
+    p.add_primitive(*op, prim);
+}
+
+REGISTER_FACTORY_IMPL(v15, SparseConvolution);
+
+}  // namespace ov::intel_gpu
