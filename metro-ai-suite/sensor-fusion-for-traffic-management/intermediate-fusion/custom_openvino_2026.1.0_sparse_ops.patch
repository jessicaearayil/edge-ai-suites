+// Copyright (C) 2018-2026 Intel Corporation
+// SPDX-License-Identifier: Apache-2.0
+//
+// GPU unit tests for SparseToDense primitive.
+// Tests 4 modes: {channels_first, channels_last} × {non-fused 5D, fused 4D}
+// Each mode tested with FP32 and FP16.
+
+#include <intel_gpu/primitives/sparse_to_dense.hpp>
+#include <intel_gpu/primitives/input_layout.hpp>
+#include <intel_gpu/primitives/reorder.hpp>
+#include <intel_gpu/runtime/internal_properties.hpp>
+
+#include "openvino/core/type/float16.hpp"
+
+#include "test_utils.h"
+
+using namespace cldnn;
+using namespace ::tests;
+
+namespace {
+
+// ===================================================================
+// CPU reference for SparseToDense (supports all 4 modes)
+// ===================================================================
+
+static void sparse_to_dense_cpu_reference(
+    const float* features,       // [M, C]
+    const int32_t* indices,      // [M, 4]  batch, z, y, x
+    float* output,               // pre-zeroed output buffer
+    int M, int C,
+    int B, int Z, int Y, int X,
+    bool channels_first,
+    bool fuse_permute_reshape)
+{
+    const int CX = C * X;
+
+    for (int i = 0; i < M; i++) {
+        const int b = indices[i * 4 + 0];
+        const int z = indices[i * 4 + 1];
+        const int y = indices[i * 4 + 2];
+        const int x = indices[i * 4 + 3];
+
+        if (b < 0 || b >= B || z < 0 || z >= Z || y < 0 || y >= Y || x < 0 || x >= X)
+            continue;
+
+        for (int c = 0; c < C; c++) {
+            size_t out_idx;
+            if (fuse_permute_reshape) {
+                if (channels_first)
+                    out_idx = ((static_cast<size_t>(b) * CX + static_cast<size_t>(c) * X + x) * Z + z) * Y + y;
+                else
+                    out_idx = ((static_cast<size_t>(b) * Z + z) * Y + y) * CX + static_cast<size_t>(c) * X + x;
+            } else {
+                if (channels_first)
+                    out_idx = ((((static_cast<size_t>(b) * C + c) * Z + z) * Y + y) * X + x);
+                else
+                    out_idx = ((((static_cast<size_t>(b) * Z + z) * Y + y) * X + x) * C + c);
+            }
+            output[out_idx] = features[i * C + c];
+        }
+    }
+}
+
+// ===================================================================
+// Test data: M=6 sparse points, C=4, spatial_shape=[3,4,2], B=1
+// ===================================================================
+
+struct TestConfig {
+    static constexpr int M = 6;
+    static constexpr int C = 4;
+    static constexpr int B = 1;
+    static constexpr int Z = 3;
+    static constexpr int Y = 4;
+    static constexpr int X = 2;
+
+    static std::vector<float> get_features() {
+        std::vector<float> feats(M * C);
+        for (int i = 0; i < M * C; i++)
+            feats[i] = static_cast<float>(i + 1) * 0.1f;
+        return feats;
+    }
+
+    static std::vector<int32_t> get_indices() {
+        return {
+            0, 0, 0, 0,   // point 0: batch=0, z=0, y=0, x=0
+            0, 0, 0, 1,   // point 1: batch=0, z=0, y=0, x=1
+            0, 1, 2, 0,   // point 2: batch=0, z=1, y=2, x=0
+            0, 1, 2, 1,   // point 3: batch=0, z=1, y=2, x=1
+            0, 2, 3, 0,   // point 4: batch=0, z=2, y=3, x=0
+            0, 2, 3, 1,   // point 5: batch=0, z=2, y=3, x=1
+        };
+    }
+
+    static std::vector<int32_t> get_spatial_shape() { return {Z, Y, X}; }
+    static std::vector<int32_t> get_batch_size() { return {B}; }
+
+    static size_t output_size(bool fuse) {
+        if (fuse) return static_cast<size_t>(B) * C * X * Z * Y;
+        return static_cast<size_t>(B) * C * Z * Y * X;
+    }
+};
+
+// ===================================================================
+// Helper: run one test with given config
+// ===================================================================
+
+static void run_sparse_to_dense_test(bool channels_first,
+                                     bool fuse_permute_reshape,
+                                     data_types feat_dt,
+                                     float tolerance) {
+    auto& engine = get_test_engine();
+    auto stream = get_test_stream_ptr(get_test_default_config(engine));
+
+    using TC = TestConfig;
+
+    // --- Allocate GPU memory ---
+    auto feat_mem = engine.allocate_memory(
+        {ov::PartialShape{TC::M, TC::C}, feat_dt, format::bfyx},
+        allocation_type::usm_host);
+    auto idx_mem = engine.allocate_memory(
+        {ov::PartialShape{TC::M, 4}, data_types::i32, format::bfyx},
+        allocation_type::usm_host);
+    auto ss_mem = engine.allocate_memory(
+        {ov::PartialShape{3}, data_types::i32, format::bfyx},
+        allocation_type::usm_host);
+    auto bs_mem = engine.allocate_memory(
+        {ov::PartialShape{1}, data_types::i32, format::bfyx},
+        allocation_type::usm_host);
+
+    // --- Set test data ---
+    auto feats = TC::get_features();
+    auto indices = TC::get_indices();
+    auto ss = TC::get_spatial_shape();
+    auto bs = TC::get_batch_size();
+
+    if (feat_dt == data_types::f16) {
+        using f16 = ov::float16;
+        std::vector<f16> feats_f16(feats.size());
+        for (size_t i = 0; i < feats.size(); i++)
+            feats_f16[i] = f16(feats[i]);
+        set_values<f16>(feat_mem, feats_f16);
+    } else {
+        set_values<float>(feat_mem, feats);
+    }
+    set_values<int32_t>(idx_mem, indices);
+    set_values<int32_t>(ss_mem, ss);
+    set_values<int32_t>(bs_mem, bs);
+
+    // --- Compute CPU reference (always in FP32) ---
+    size_t out_size = TC::output_size(fuse_permute_reshape);
+    std::vector<float> ref_out(out_size, 0.0f);
+    sparse_to_dense_cpu_reference(
+        feats.data(), indices.data(), ref_out.data(),
+        TC::M, TC::C, TC::B, TC::Z, TC::Y, TC::X,
+        channels_first, fuse_permute_reshape);
+
+    // --- Build GPU topology ---
+    topology topo;
+    topo.add(input_layout("feats", feat_mem->get_layout()));
+    topo.add(input_layout("indices", idx_mem->get_layout()));
+    topo.add(input_layout("spatial_shape", ss_mem->get_layout()));
+    topo.add(input_layout("batch_size", bs_mem->get_layout()));
+
+    topo.add(sparse_to_dense("s2d",
+        {input_info("feats"), input_info("indices"),
+         input_info("spatial_shape"), input_info("batch_size")},
+        channels_first,
+        fuse_permute_reshape,
+        {TC::Z, TC::Y, TC::X},
+        TC::B));
+
+    // 4D fused → bfyx, 5D non-fused → bfzyx
+    auto out_fmt = fuse_permute_reshape ? format::bfyx : format::bfzyx;
+    topo.add(reorder("output", input_info("s2d"), out_fmt, feat_dt));
+
+    auto config = get_test_default_config(engine);
+    config.set_property(ov::intel_gpu::allow_new_shape_infer(true));
+    auto network = get_network(engine, topo, config, stream, false);
+    network->set_input_data("feats", feat_mem);
+    network->set_input_data("indices", idx_mem);
+    network->set_input_data("spatial_shape", ss_mem);
+    network->set_input_data("batch_size", bs_mem);
+
+    const auto outputs = network->execute();
+
+    // --- Compare output ---
+    auto out_feat = outputs.at("output").get_memory();
+
+    if (feat_dt == data_types::f16) {
+        using f16 = ov::float16;
+        mem_lock<f16, mem_lock_type::read> out_ptr(out_feat, get_test_stream());
+        ASSERT_EQ(out_ptr.size(), out_size);
+        for (size_t i = 0; i < out_size; i++) {
+            float actual = static_cast<float>(out_ptr[i]);
+            ASSERT_NEAR(ref_out[i], actual, tolerance)
+                << "Mismatch at index " << i
+                << " (cf=" << channels_first << ", fuse=" << fuse_permute_reshape << ")";
+        }
+    } else {
+        mem_lock<float, mem_lock_type::read> out_ptr(out_feat, get_test_stream());
+        ASSERT_EQ(out_ptr.size(), out_size);
+        for (size_t i = 0; i < out_size; i++) {
+            ASSERT_NEAR(ref_out[i], out_ptr[i], tolerance)
+                << "Mismatch at index " << i
+                << " (cf=" << channels_first << ", fuse=" << fuse_permute_reshape << ")";
+        }
+    }
+}
+
+// ===================================================================
+// Test cases: 8 total = {cf, cl} × {nofuse, fuse} × {f32, f16}
+// ===================================================================
+
+// --- Non-fused (5D output) ---
+
