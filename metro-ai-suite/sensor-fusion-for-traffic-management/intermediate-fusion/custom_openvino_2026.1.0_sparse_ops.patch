+# ---------------------------------------------------------------------------
+# Main
+# ---------------------------------------------------------------------------
+
+def main():
+    parser = argparse.ArgumentParser(
+        description="Validate OpenVINO SparseConvolution against spconv dump"
+    )
+    parser.add_argument(
+        "--dump-dir",
+        type=str,
+        default="/home/jie/workspace/openvino/test_data/sparse_conv_dump",
+    )
+    parser.add_argument("--device", type=str, default="GPU")
+    parser.add_argument(
+        "--fp32", action="store_true",
+        help="Use FP32 instead of FP16 (more accurate but slower)"
+    )
+    parser.add_argument(
+        "--layers", type=str, default=None,
+        help="Comma-separated layer indices to test (0-20). Default: all."
+    )
+    args = parser.parse_args()
+
+    import openvino as ov
+
+    use_fp16 = not args.fp32
+    core = ov.Core()
+    selected_device, selected_device_name = resolve_gpu_device(core, args.device)
+
+    print(f"OpenVINO version: {ov.__version__}")
+    print(f"Device (arg): {args.device}")
+    print(f"Device (resolved): {selected_device}")
+    print(f"GPU name: {selected_device_name}")
+    print(f"Precision: {'FP16' if use_fp16 else 'FP32'}")
+    print(f"Dump dir: {args.dump_dir}")
+    print()
+
+    # Load manifest
+    manifest_path = os.path.join(args.dump_dir, "manifest.json")
+    with open(manifest_path) as f:
+        manifest = json.load(f)
+
+    # Load all npz files (filename-sorted, matching EXEC_ORDER indices)
+    npz_files = sorted(f for f in os.listdir(args.dump_dir) if f.endswith(".npz"))
+    assert len(npz_files) == 21, f"Expected 21 npz files, got {len(npz_files)}"
+
+    all_data = []
+    configs: list[LayerConfig] = []
+    for i, entry in enumerate(manifest):
+        npz_path = os.path.join(args.dump_dir, entry["file"])
+        all_data.append(np.load(npz_path))
+        configs.append(LayerConfig(
+            name=entry["layer_name"],
+            file=entry["file"],
+            layer_type=entry["type"],
+            in_channels=entry["in_channels"],
+            out_channels=entry["out_channels"],
+            kernel_size=entry["kernel_size"],
+            stride=entry["stride"],
+            padding=entry["padding"],
+            dilation=entry["dilation"],
+            input_nnz=entry["input_nnz"],
+            output_nnz=entry["output_nnz"],
+            input_spatial_shape=entry["input_spatial_shape"],
+            output_spatial_shape=entry["output_spatial_shape"],
+            is_subm=(entry["type"] == "SubMConv3d"),
+        ))
+
+    # Determine which layers to test
+    if args.layers:
+        test_indices = set(int(x) for x in args.layers.split(","))
+    else:
+        test_indices = set(range(len(EXEC_ORDER)))
+
+    # ======================================================================
+    # Part 1: Per-layer independent validation
+    # ======================================================================
+    print("=" * 105)
+    print("PART 1: Per-layer validation (OpenVINO GPU vs spconv reference)")
+    print("=" * 105)
+
+    layer_results: dict[int, ComparisonResult] = {}
+    n_pass = 0
+    n_diff = 0
+    n_fail = 0
+
+    with tempfile.TemporaryDirectory(prefix="ov_sparse_val_") as tmp_dir:
+        for order_idx, (file_idx, desc) in enumerate(EXEC_ORDER):
+            if order_idx not in test_indices:
+                continue
+
+            cfg = configs[file_idx]
+            npz = all_data[file_idx]
+
+            try:
+                ov_feats, ov_coords, actual_m = run_layer_openvino(
+                    core, cfg, npz, selected_device, use_fp16, tmp_dir
+                )
+            except Exception as e:
+                print(f"  [ERR ] {desc:42s}  {e}")
+                n_fail += 1
+                continue
+
+            ref_feats = npz["output_features"]
+            ref_coords = npz["output_indices"]
+
+            result = compare_outputs(
+                ov_feats, ov_coords, ref_feats, ref_coords,
+                cfg.in_channels, cfg.kernel_size,
+            )
+            layer_results[file_idx] = result
+
+            if result.voxel_exact and result.feat_close:
+                status = "PASS"
+                n_pass += 1
+            elif not result.voxel_exact:
+                status = "DIFF"
+                n_diff += 1
+            else:
+                status = "FAIL"
+                n_fail += 1
+
+            if result.voxel_exact:
+                print(
+                    f"  [{status:4s}] {desc:42s}  "
+                    f"voxels={result.ref_nnz:>6d}(exact)  "
+                    f"max_abs={result.max_abs_err:.2e}  "
+                    f"mean_abs={result.mean_abs_err:.2e}  "
+                    f"bound={result.fp32_bound:.2e}"
+                )
+            else:
+                overlap_pct = 100.0 * result.common_count / max(result.ref_nnz, 1)
+                print(
+                    f"  [{status:4s}] {desc:42s}  "
+                    f"ref={result.ref_nnz:>6d}  ov={result.ov_nnz:>6d}  "
+                    f"common={result.common_count:>6d}({overlap_pct:4.1f}%)  "
+                    f"max_abs={result.max_abs_err:.2e}"
+                )
+
+    # ======================================================================
+    # Part 2: Summary
+    # ======================================================================
+    print()
+    print("=" * 105)
+    print("SUMMARY")
+    print("=" * 105)
+    tested = n_pass + n_diff + n_fail
+    print(f"  Tested: {tested}/{len(EXEC_ORDER)} layers")
+    print(f"  PASS:   {n_pass}  (voxels exact + features within tolerance)")
+    print(f"  DIFF:   {n_diff}  (voxel set mismatch — expected for SparseConv3d)")
+    print(f"  FAIL:   {n_fail}  (error or features beyond tolerance)")
+    print()
+
+    # Detail on DIFF layers (SparseConv3d with different voxel enumeration)
+    if n_diff > 0:
+        print("  Layers with voxel-set differences (OpenVINO vs spconv):")
+        for file_idx, desc in EXEC_ORDER:
+            if file_idx in layer_results and not layer_results[file_idx].voxel_exact:
+                r = layer_results[file_idx]
+                print(
+                    f"    {desc:42s}  ref={r.ref_nnz:>6d}  "
+                    f"ov={r.ov_nnz:>6d}  common={r.common_count:>6d}  "
+                    f"max_abs(common)={r.max_abs_err:.2e}"
+                )
+        print()
+        print("  NOTE: SparseConv3d (stride>1) voxel-set differences are expected —")
+        print("  different sparse convolution libraries enumerate output voxels differently.")
+        print("  The key metric is whether features on COMMON voxels match.")
+
+    return 0 if n_fail == 0 else 1
+
+
+if __name__ == "__main__":
+    sys.exit(main())
