new file mode 100644
index 0000000000..1897794ad4
--- /dev/null
+++ b/src/core/include/openvino/op/sparse_convolution.hpp
@@ -0,0 +1,157 @@
+// Copyright (C) 2018-2026 Intel Corporation
+// SPDX-License-Identifier: Apache-2.0
+//
+
+#pragma once
+
+#include <cstdint>
+#include <string>
+#include <vector>
+
+#include "openvino/op/op.hpp"
+
+namespace ov {
+namespace op {
+namespace v15 {
+
+/// @brief SparseConvolution — 3D sparse convolution for point cloud processing.
+///
+/// Performs sparse 3D convolution (SubMConv3d or SparseConv3d) using implicit GEMM
+/// with hash-based kernel map building. Designed for LiDAR sparse encoders such as
+/// BEVFusion.
+///
+/// Inputs:
+///   0 (input_features)  — [M_in, C_in]          f32   active voxel features
+///   1 (input_coords)    — [M_in, 4]             i32   voxel coords [batch, dim0, dim1, dim2]
+///   2 (weights)         — [K_vol, C_in, C_out]  f32   convolution weights (Constant)
+///   3 (bias)            — [C_out]               f32   bias (optional, present after BN fusion)
+///
+/// Outputs:
+///   0 (output_features) — [M_out, C_out]        f32   output voxel features
+///   1 (output_coords)   — [M_out, 4]            i32   output voxel coords
+///
+/// When subm=true  (SubMConv3d): M_out == M_in, output_coords == input_coords
+/// When subm=false (SparseConv3d): M_out determined at runtime by downsample algorithm
+class OPENVINO_API SparseConvolution : public Op {
+public:
+    OPENVINO_OP("SparseConvolution", "opset15");
+    SparseConvolution() = default;
+
+    /// @brief Constructor without bias.
+    SparseConvolution(const Output<Node>& input_features,
+                      const Output<Node>& input_coords,
+                      const Output<Node>& weights,
+                      std::vector<int64_t> kernel_size,
+                      std::vector<int64_t> stride,
+                      std::vector<int64_t> padding,
+                      std::vector<int64_t> dilation,
+                      bool subm,
+                      int64_t out_channels,
+                      std::vector<int64_t> input_spatial_shape,
+                      int64_t in_channels = 0,
+                      std::vector<int64_t> output_spatial_shape = {0, 0, 0},
+                      std::string activation = "None",
+                      int64_t output_bound = 0,
+                      std::string rulebook = "");
+
+    /// @brief Constructor with bias.
+    SparseConvolution(const Output<Node>& input_features,
+                      const Output<Node>& input_coords,
+                      const Output<Node>& weights,
+                      const Output<Node>& bias,
+                      std::vector<int64_t> kernel_size,
+                      std::vector<int64_t> stride,
+                      std::vector<int64_t> padding,
+                      std::vector<int64_t> dilation,
+                      bool subm,
+                      int64_t out_channels,
+                      std::vector<int64_t> input_spatial_shape,
+                      int64_t in_channels = 0,
+                      std::vector<int64_t> output_spatial_shape = {0, 0, 0},
+                      std::string activation = "None",
+                      int64_t output_bound = 0,
+                      std::string rulebook = "");
+
+    bool visit_attributes(AttributeVisitor& visitor) override;
+    void validate_and_infer_types() override;
+    std::shared_ptr<Node> clone_with_new_inputs(const OutputVector& new_args) const override;
+    bool evaluate(TensorVector& outputs, const TensorVector& inputs) const override;
+    bool has_evaluate() const override;
+
+    bool has_bias() const { return get_input_size() == 4; }
+    bool is_subm() const { return m_subm; }
+
+    const std::vector<int64_t>& get_kernel_size() const { return m_kernel_size; }
+    const std::vector<int64_t>& get_stride() const { return m_stride; }
+    const std::vector<int64_t>& get_padding() const { return m_padding; }
+    const std::vector<int64_t>& get_dilation() const { return m_dilation; }
+    int64_t get_out_channels() const { return m_out_channels; }
+    int64_t get_in_channels() const { return m_in_channels; }
+    const std::vector<int64_t>& get_input_spatial_shape() const { return m_input_spatial_shape; }
+    const std::vector<int64_t>& get_output_spatial_shape() const { return m_output_spatial_shape; }
+    const std::string& get_activation() const { return m_activation; }
+    int64_t get_output_bound() const { return m_output_bound; }
+    const std::string& get_rulebook() const { return m_rulebook; }
+    /// Backward-compatible alias for get_input_spatial_shape().
+    const std::vector<int64_t>& get_spatial_shape() const { return m_input_spatial_shape; }
+
+    /// Symmetric per-tensor absolute-max of the activation input, derived
+    /// from a PTQ FakeQuantize upstream. Default 0 means "not set" — the
+    /// GPU INT8 kernel then falls back to an online abs-max reduction.
+    /// Populated by the GPU plugin's EatSparseConvInputFakeQuantize pass
+    /// before LPT runs, so callers from the ONNX frontend don't need to
+    /// know about it.
+    float get_input_abs_max() const { return m_input_abs_max; }
+    void  set_input_abs_max(float v) { m_input_abs_max = v; }
+
+    /// Symmetric per-tensor absolute-max of the activation OUTPUT, derived
+    /// from the downstream FakeQuantize (if any). When > 0 AND a downstream
+    /// SparseConv consumer exists (also INT8-capable), the GPU kernel can
+    /// additionally produce an int8 copy of its output quantised to this
+    /// scale, letting the consumer skip its own quantize kernel.
+    /// Populated by the GPU plugin's EatSparseConvOutputFakeQuantize pass
+    /// (Path 1). 0 = fall back to fp16-out + per-layer quantize.
+    float get_output_abs_max() const { return m_output_abs_max; }
+    void  set_output_abs_max(float v) { m_output_abs_max = v; }
+
+    /// Path 1 handoff identity: when this SparseConv's upstream producer is
+    /// another SparseConv that's emitting an int8 handoff copy, this holds
+    /// the producer's friendly name. The SYCL impl uses it at execute time
+    /// to look up the handoff scratch by ID (rather than by buffer pointer,
+    /// which gets rewritten by LPT's dequant Multiply on the edge).
+    const std::string& get_input_handoff_producer() const { return m_input_handoff_producer; }
+    void set_input_handoff_producer(const std::string& v) { m_input_handoff_producer = v; }
+
+private:
+    // Attribute storage uses int64_t because OpenVINO's XML serializer only
+    // supports vector<int>, vector<int64_t>, vector<uint64_t>, vector<float>,
+    // vector<string>. vector<uint32_t> previously used here caused
+    // "Unsupported attribute type for serialization" at compile_model time
+    // (GPU plugin serializes the IR before sending it to kernel cache).
+    std::vector<int64_t> m_kernel_size = {3, 3, 3};
+    std::vector<int64_t> m_stride = {1, 1, 1};
+    std::vector<int64_t> m_padding = {1, 1, 1};
+    std::vector<int64_t> m_dilation = {1, 1, 1};
+    bool m_subm = false;
+    int64_t m_out_channels = 0;
+    int64_t m_in_channels = 0;
+    std::vector<int64_t> m_input_spatial_shape = {0, 0, 0};
+    std::vector<int64_t> m_output_spatial_shape = {0, 0, 0};
+    std::string m_activation = "None";
+    int64_t m_output_bound = 0;
+    std::string m_rulebook;
+    // Activation-input symmetric abs-max from PTQ FakeQuantize. 0 = unset.
+    // Not a ctor parameter — the ONNX frontend doesn't read it; it is only
+    // populated by a GPU-plugin-level graph transformation pass. Serialised
+    // via visit_attributes so it round-trips through IR xml.
+    float m_input_abs_max = 0.0f;
+    // Activation-output symmetric abs-max; see get_output_abs_max() doc.
+    float m_output_abs_max = 0.0f;
+    // Path 1: friendly-name of the producer SparseConv that will feed us
+    // via int8 handoff. Empty string = no handoff.
+    std::string m_input_handoff_producer;
+};
+
+}  // namespace v15
+}  // namespace op
+}  // namespace ov
