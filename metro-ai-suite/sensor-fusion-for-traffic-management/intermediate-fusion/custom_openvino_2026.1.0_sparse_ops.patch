+// Copyright (C) 2018-2026 Intel Corporation
+// SPDX-License-Identifier: Apache-2.0
+//
+// Shared actual-M map for sparse operations.
+//
+// SparseConvolution stores actual output voxel counts keyed by the output
+// coordinate buffer pointer.  SparseToDense reads them so it only scatters
+// valid voxels instead of iterating over the entire pre-allocated buffer.
+
+#pragma once
+
+#include <unordered_map>
+
+namespace cldnn {
+namespace sycl {
+
+/// Returns a reference to the process-wide actual-M map.
+/// Key: raw pointer to the coordinate output buffer.
+/// Value: actual number of valid rows (m_out).
+inline std::unordered_map<const void*, int>& sparse_actual_m_map() {
+    static std::unordered_map<const void*, int> map;
+    return map;
+}
+
+}  // namespace sycl
+}  // namespace cldnn
diff --git a/src/plugins/intel_gpu/src/graph/impls/sycl/sparse_convolution_sycl.cpp b/src/plugins/intel_gpu/src/graph/impls/sycl/sparse_convolution_sycl.cpp
new file mode 100644
index 0000000000..6112f3b4bb
--- /dev/null
+++ b/src/plugins/intel_gpu/src/graph/impls/sycl/sparse_convolution_sycl.cpp
@@ -0,0 +1,3204 @@
+// Copyright (C) 2018-2026 Intel Corporation
+// SPDX-License-Identifier: Apache-2.0
+//
+// SparseConvolution SYCL kernel implementation.
+//
+// Ported from the TorchSparse SYCL backend. Two-stage computation:
+//   Stage 1: Kernel Map Building (FNV-1a hash table + neighbor query)
+//   Stage 2: Implicit GEMM (tiled sparse matrix multiply)
+
+#include "sparse_convolution_sycl.hpp"
+#include "sparse_actual_m_map.h"
+
+#include "ocl/ocl_stream.hpp"
+#include "ocl/sycl_stream.hpp"
+#include "primitive_sycl_base.h"
+
+#include "intel_gpu/runtime/memory.hpp"
+
+#include <algorithm>
+#include <chrono>
+#include <cstdint>
+#include <cstdlib>
+#include <cstring>
+#include <memory>
+#include <numeric>
+#include <string>
+#include <unordered_map>
+#include <vector>
+
+#include "sycl/sycl.hpp"
+#include <sycl/ext/oneapi/matrix/matrix.hpp>
+
+namespace sycl_matrix = ::sycl::ext::oneapi::experimental::matrix;
+
+namespace cldnn {
+namespace sycl {
+
+// ===================================================================
+// Rulebook cache: shared kernel map between SubMConv3d layers
+// ===================================================================
+
+/// Cached Stage 1 artifacts for rulebook sharing.
+/// SubMConv3d layers with the same rulebook key share hash table + kernel map.
+struct RulebookCache {
+    int64_t* hash_keys = nullptr;      // [hash_cap]
+    int* hash_vals = nullptr;           // [hash_cap]
+    int hash_cap = 0;
+    int32_t* reordered_in = nullptr;    // [m_points * 4], xyzb format
+    int32_t* out_in_map = nullptr;      // [m_points * k_vol]
+    int m_points = 0;
+    int k_vol = 0;
+    const void* last_coord_ptr = nullptr;
+    ::sycl::queue* q = nullptr;
+
+    bool matches(int m_in, int kv, const void* coord_ptr) const {
+        return m_points == m_in && k_vol == kv
+            && last_coord_ptr == coord_ptr
+            && out_in_map != nullptr;
+    }
+
+    void clear() {
+        if (hash_keys && q) { ::sycl::free(hash_keys, *q); hash_keys = nullptr; }
+        if (hash_vals && q) { ::sycl::free(hash_vals, *q); hash_vals = nullptr; }
+        if (reordered_in && q) { ::sycl::free(reordered_in, *q); reordered_in = nullptr; }
+        if (out_in_map && q) { ::sycl::free(out_in_map, *q); out_in_map = nullptr; }
+        m_points = 0; k_vol = 0; hash_cap = 0; last_coord_ptr = nullptr;
+    }
+
+    // Do NOT call clear() here — static destruction order is undefined and the
+    // SYCL runtime/queue may already be torn down, causing double-free.
+    // Device memory is reclaimed by the OS at process exit.
+    ~RulebookCache() = default;
+
+    // Non-copyable, non-movable (raw pointers with manual lifetime)
+    RulebookCache() = default;
+    RulebookCache(const RulebookCache&) = delete;
+    RulebookCache& operator=(const RulebookCache&) = delete;
+    RulebookCache(RulebookCache&& o) noexcept
+        : hash_keys(o.hash_keys), hash_vals(o.hash_vals), hash_cap(o.hash_cap),
+          reordered_in(o.reordered_in), out_in_map(o.out_in_map),
+          m_points(o.m_points), k_vol(o.k_vol), last_coord_ptr(o.last_coord_ptr), q(o.q) {
+        o.hash_keys = nullptr; o.hash_vals = nullptr;
+        o.reordered_in = nullptr; o.out_in_map = nullptr;
+        o.m_points = 0; o.k_vol = 0; o.hash_cap = 0; o.last_coord_ptr = nullptr;
+    }
+    RulebookCache& operator=(RulebookCache&& o) noexcept {
+        if (this != &o) {
+            clear();
+            hash_keys = o.hash_keys; hash_vals = o.hash_vals; hash_cap = o.hash_cap;
+            reordered_in = o.reordered_in; out_in_map = o.out_in_map;
+            m_points = o.m_points; k_vol = o.k_vol; last_coord_ptr = o.last_coord_ptr; q = o.q;
+            o.hash_keys = nullptr; o.hash_vals = nullptr;
+            o.reordered_in = nullptr; o.out_in_map = nullptr;
+            o.m_points = 0; o.k_vol = 0; o.hash_cap = 0; o.last_coord_ptr = nullptr;
+        }
+        return *this;
+    }
+};
+
+static std::unordered_map<std::string, RulebookCache> s_rulebook_cache;
+
+/// Alias for the shared actual-M map (see sparse_actual_m_map.h).
+/// SparseConv3d stores actual m_out; downstream layers (SubM, SparseToDense) read it.
+static auto& s_actual_m_map = sparse_actual_m_map();
+
+// ===================================================================
+// INT8 weight cache (one-time pre-quantization of the fp16 weight
+// Constant on first execution of each layer)
+// ===================================================================
+
+/// Per-layer INT8 weight cache entry. Built lazily on first execute() call.
+/// Keyed by the underlying fp16 weight Constant's USM pointer.
+struct Int8WeightCache {
+    int8_t* weights_i8 = nullptr;              // [k_vol * C_in * C_out] int8
+    float*  per_channel_scale_inv = nullptr;   // [C_out] = 127 / abs_max[c]
+    float*  per_channel_abs_max   = nullptr;   // [C_out] = abs_max[c]
+    float*  per_channel_scale     = nullptr;   // [C_out] = abs_max[c] / 127 (fed directly to dequant kernel)
+    int64_t total = 0;                         // k_vol * C_in * C_out
+    int c_out = 0;
+    ::sycl::queue* q = nullptr;
+
+    // Leaked on process exit — SYCL queue teardown ordering is undefined.
+    ~Int8WeightCache() = default;
+    Int8WeightCache() = default;
+    Int8WeightCache(const Int8WeightCache&) = delete;
+    Int8WeightCache& operator=(const Int8WeightCache&) = delete;
+    Int8WeightCache(Int8WeightCache&& o) noexcept
+        : weights_i8(o.weights_i8),
+          per_channel_scale_inv(o.per_channel_scale_inv),
+          per_channel_abs_max(o.per_channel_abs_max),
+          per_channel_scale(o.per_channel_scale),
+          total(o.total), c_out(o.c_out), q(o.q) {
+        o.weights_i8 = nullptr;
+        o.per_channel_scale_inv = nullptr;
+        o.per_channel_abs_max = nullptr;
+        o.per_channel_scale = nullptr;
+    }
+    Int8WeightCache& operator=(Int8WeightCache&& o) noexcept = delete;
+};
+
+static std::unordered_map<const void*, Int8WeightCache> s_int8_weight_cache;
+
+// ===================================================================
+// Path 1 INT8 → INT8 handoff table
+// ===================================================================
+//
+// Producer SparseConv (with output_abs_max > 0) writes a quantised int8
+// copy of its output into a per-impl scratch buffer AND registers it
+// here keyed by the PRODUCER'S friendly-name. The consumer knows that
+// name statically (stored on its op attribute by the
+// EatSparseConvOutputFakeQuantize pass) and looks it up at execute time.
+//
+// Why keyed by name and not by buffer pointer: LPT inserts a Multiply
+// (dequant) on the producer→consumer edge during low-precision
+// transformations, which allocates its own fp16 scratch. The consumer's
+// `feat_raw` therefore does NOT match the producer's `out_feat_ptr`
+// most of the time. The friendly-name link, baked in at compile time
+// by the pass, survives both LPT and the rest of the pipeline.
+//
+// Invalidation: the buffer stays alive as long as the producer impl
+// does. The consumer reads it in the same frame's GPU stream. Entries
+// are overwritten each frame by the same producer; no leak.
+struct Int8Handoff {
+    const int8_t* data_i8 = nullptr;  // producer-owned, matches fp16 out layout
+    int M = 0;  // number of valid rows in the int8 buffer
+    int C = 0;  // channels (== producer's c_out, consumer's c_in)
+};
+static std::unordered_map<std::string, Int8Handoff> s_int8_handoff;
+
+// ===================================================================
+// Constants
+// ===================================================================
+
+static constexpr int NDIM = 4;           // [x, y, z, batch] or [batch, x, y, z]
+static constexpr int HASH_EMPTY = 0;     // Empty cell sentinel for hash table keys
+static constexpr int WG_SIZE = 256;      // Default work-group size
+static constexpr int TILE_M = 128;       // Implicit GEMM tile: output rows
+static constexpr int TILE_N = 16;        // Implicit GEMM tile: output columns
+static constexpr int TILE_K = 16;        // Implicit GEMM tile: input channels per iteration
+static constexpr int SKEW = 8;           // SLM bank-conflict avoidance skew
+
+// ===================================================================
+// Utility: SLM offset with bank-conflict-avoidance skew
+// ===================================================================
+
+inline int slm_skew(int row, int col, int stride) {
+    return row * (stride + SKEW) + col;
+}
+
+// ===================================================================
+// Stage 1a: Coordinate reorder kernels
+// ===================================================================
+
+/// Reorder [batch, x, y, z] → [x, y, z, batch]  (N points, row-major [N,4])
+static void reorder_bxyz_to_xyzb(::sycl::queue& q,
+                                  const int32_t* __restrict__ in,
+                                  int32_t* __restrict__ out,
+                                  int n) {
+    q.parallel_for(::sycl::range<1>(n), [=](::sycl::id<1> idx) {
+        int i = idx[0];
+        out[i * 4 + 0] = in[i * 4 + 1];  // x
+        out[i * 4 + 1] = in[i * 4 + 2];  // y
+        out[i * 4 + 2] = in[i * 4 + 3];  // z
+        out[i * 4 + 3] = in[i * 4 + 0];  // batch
+    });
+}
+
+/// Reorder [x, y, z, batch] → [batch, x, y, z]
+static void reorder_xyzb_to_bxyz(::sycl::queue& q,
+                                  const int32_t* __restrict__ in,
+                                  int32_t* __restrict__ out,
+                                  int n) {
+    q.parallel_for(::sycl::range<1>(n), [=](::sycl::id<1> idx) {
+        int i = idx[0];
+        out[i * 4 + 0] = in[i * 4 + 3];  // batch
+        out[i * 4 + 1] = in[i * 4 + 0];  // x
+        out[i * 4 + 2] = in[i * 4 + 1];  // y
+        out[i * 4 + 3] = in[i * 4 + 2];  // z
+    });
+}
+
+// ===================================================================
+// Stage 1b: FNV-1a hash + linear-probing hash table
+// ===================================================================
+
+/// FNV-1a 64-bit hash for 4-int coordinate [x, y, z, batch]. Used only for
+/// selecting the initial hash-table slot; NOT used as the lookup key itself.
+inline uint64_t fnv1a_hash(int a, int b, int c, int d) {
+    uint64_t h = 14695981039346656037ULL;
+    h ^= static_cast<uint32_t>(a); h *= 1099511628211ULL;
+    h ^= static_cast<uint32_t>(b); h *= 1099511628211ULL;
+    h ^= static_cast<uint32_t>(c); h *= 1099511628211ULL;
+    h ^= static_cast<uint32_t>(d); h *= 1099511628211ULL;
+    return h;
+}
+
+/// Pack 4 int-coord components into a single int64 unique key.
+///
+/// Valid input range: each component ∈ [-32768, 32767] (int16). Real voxel
+/// grids are well below this (typical: 1024×1024×40; padding-induced negatives
+/// never below -2). This packing is collision-free in that range.
+///
+/// The MSB is always set so the packed key is a negative int64 and therefore
+/// cannot collide with the HASH_EMPTY=0 sentinel used by hash_insert_coords.
+///
+/// Rationale: previously keys[] stored fnv1a(coord) values and lookup compared
+/// hashes, so any 64-bit FNV-1a collision between two distinct voxels would
+/// be silently treated as the same voxel → ghost detections at fixed BEV
+/// positions (observed on KITTI-v2x frames 000015 / 000048 / 000053 near
+/// pc_range corner (101, 49) m). Packing + slot-only hash is zero-collision.
+inline int64_t pack_coord_key(int x, int y, int z, int b) {
+    uint64_t p =  (static_cast<uint64_t>(static_cast<uint16_t>(static_cast<int16_t>(x))))
+               | ((static_cast<uint64_t>(static_cast<uint16_t>(static_cast<int16_t>(y)))) << 16)
+               | ((static_cast<uint64_t>(static_cast<uint16_t>(static_cast<int16_t>(z)))) << 32)
+               | ((static_cast<uint64_t>(static_cast<uint16_t>(static_cast<int16_t>(b)))) << 48);
+    return static_cast<int64_t>(p | (1ULL << 63));
+}
+
+/// Insert N coordinates (xyzb format, [N,4]) into hash table.
+/// Values are 1-indexed; 0 means "empty".
+static void hash_insert_coords(::sycl::queue& q,
+                                int64_t* __restrict__ keys,
+                                int* __restrict__ vals,
+                                int capacity,
+                                const int32_t* __restrict__ coords,
+                                int n) {
+    q.parallel_for(::sycl::range<1>(n), [=](::sycl::id<1> idx) {
+        int i = idx[0];
+        int x = coords[i * 4 + 0];
+        int y = coords[i * 4 + 1];
+        int z = coords[i * 4 + 2];
+        int batch = coords[i * 4 + 3];
+
+        int64_t key = pack_coord_key(x, y, z, batch);
+        uint64_t slot_h = fnv1a_hash(x, y, z, batch);
+        int slot = static_cast<int>(slot_h % static_cast<uint64_t>(capacity));
+
+        // Bounded probing — if table is full (capacity <= n) we abort rather
+        // than spin forever. Caller sizes capacity = max(512, 2*n), so in
+        // practice this loop terminates after a few probes.
+        for (int probe = 0; probe < capacity; probe++) {
+            ::sycl::atomic_ref<int64_t,
+                               ::sycl::memory_order::relaxed,
+                               ::sycl::memory_scope::device,
+                               ::sycl::access::address_space::global_space>
+                atomic_key(keys[slot]);
+
+            int64_t expected = HASH_EMPTY;
+            if (atomic_key.compare_exchange_strong(expected, key)) {
+                vals[slot] = i + 1;  // 1-indexed
+                break;
+            }
+            if (expected == key) {
+                // Duplicate input coord — skip (first inserter keeps slot)
+                break;
+            }
+            slot = (slot + 1) % capacity;
+        }
+    });
+}
+
+// ===================================================================
+// Stage 1c: Kernel-map query (lookup neighbors for each output coord)
+// ===================================================================
+
+/// For each output coord (xyzb format) and each kernel offset, compute the
+/// corresponding input-space coordinate, hash it, and look up in the hash
+/// table.  Produces out_in_map[M_out, k_vol] with -1 = no neighbor.
+///
+/// Neighbor formula:
+///   input_coord[dim] = output_coord[dim] * stride[dim] + k_dim - padding[dim]
+/// where k_dim is decomposed from the flat kernel index using ix-major order
+/// (matching spconv convention: flat_idx = ix*(ky*kz) + iy*kz + iz).
+static void hash_lookup_build_kmap(::sycl::queue& q,
+                                    const int64_t* __restrict__ keys,
+                                    const int* __restrict__ vals,
+                                    int capacity,
+                                    const int32_t* __restrict__ out_coords,
+                                    int m_out,
+                                    const uint32_t* kernel_size_host,
+                                    const uint32_t* stride_host,
+                                    const uint32_t* padding_host,
+                                    int k_vol,
+                                    int32_t* __restrict__ out_in_map) {
+    // Capture small arrays by value — no device allocation needed
+    const int ks1 = static_cast<int>(kernel_size_host[1]);
+    const int ks2 = static_cast<int>(kernel_size_host[2]);
+    const int st0 = static_cast<int>(stride_host[0]);
+    const int st1 = static_cast<int>(stride_host[1]);
+    const int st2 = static_cast<int>(stride_host[2]);
+    const int pd0 = static_cast<int>(padding_host[0]);
+    const int pd1 = static_cast<int>(padding_host[1]);
+    const int pd2 = static_cast<int>(padding_host[2]);
+
+    int num_wg = (m_out + WG_SIZE - 1) / WG_SIZE;
+    q.parallel_for(
+        ::sycl::nd_range<1>(::sycl::range<1>(num_wg * WG_SIZE),
+                            ::sycl::range<1>(WG_SIZE)),
+        [=](::sycl::nd_item<1> item) {
+            int gid = item.get_global_id(0);
+            if (gid >= m_out) return;
+
+            int ox = out_coords[gid * 4 + 0];
+            int oy = out_coords[gid * 4 + 1];
+            int oz = out_coords[gid * 4 + 2];
+            int ob = out_coords[gid * 4 + 3];
+
+            for (int k = 0; k < k_vol; k++) {
+                // ix-major decomposition (matches spconv convention):
+                // flat_idx = ix*(ky*kz) + iy*kz + iz
+                int tmp = k;
+                int kz = tmp % ks2; tmp /= ks2;
+                int ky = tmp % ks1; tmp /= ks1;
+                int kx = tmp;
+
+                int nx = ox * st0 + kx - pd0;
+                int ny = oy * st1 + ky - pd1;
+                int nz = oz * st2 + kz - pd2;
+
+                int64_t key = pack_coord_key(nx, ny, nz, ob);
+                uint64_t slot_h = fnv1a_hash(nx, ny, nz, ob);
+                int slot = static_cast<int>(slot_h % static_cast<uint64_t>(capacity));
+
+                int result = 0;
+                for (int probe = 0; probe < capacity; probe++) {
+                    int64_t slot_key = keys[slot];
+                    if (slot_key == key) {
+                        result = vals[slot];
+                        break;
+                    }
+                    if (slot_key == HASH_EMPTY) break;
+                    slot = (slot + 1) % capacity;
+                }
+
+                out_in_map[gid * k_vol + k] = result - 1;
+            }
+        });
+}
+
+// ===================================================================
+// Stage 1d: Downsample (stride > 1) — generate output coordinates
+// ===================================================================
+
+/// For one input voxel, enumerate all valid output coordinates.
+/// Returns number of valid outputs written to out_coords.
+/// Algorithm matches spconv getValidOutPos.
+/// Input coords in [batch, x, y, z] format.
+inline int get_output_coords_for_voxel(
+    int kernel_volume,
+    const int* in_coord,       // [batch, x, y, z] for this voxel
+    const int* kernel_sizes,   // [3]
+    const int* stride,         // [3]
+    const int* coords_min,     // [4] in bxyz
+    const int* coords_max,     // [4] in bxyz
+    const int* padding,        // [3]
+    int* out_coords)           // output buffer [kernel_volume * 4]
+{
+    int point_counter = 0;
+    int counter[3] = {0, 0, 0};
+    int lower[3];
+    for (int i = 0; i < 3; i++) lower[i] = -(kernel_sizes[i] - 1);
+
+    for (int i = 0; i < kernel_volume; i++) {
+        bool valid = true;
+
+        // Check spatial dims (indices 1,2,3 in bxyz)
+        for (int j = 3; j >= 1; --j) {
+            int cur = in_coord[j] + (lower[j - 1] + counter[j - 1]) + padding[j - 1];
+            int cur_div = cur / stride[j - 1];
+            if ((cur % stride[j - 1] == 0) &&
+                (cur_div >= coords_min[j]) &&
+                (cur_div <= coords_max[j])) {
+                out_coords[point_counter * NDIM + j] = cur_div;
+            } else {
+                valid = false;
+            }
+        }
+
+        counter[2]++;
+        out_coords[point_counter * NDIM] = in_coord[0];  // batch
+
+        if (valid) point_counter++;
+
+        // Carry
+        for (int c = 2; c >= 0; --c) {
+            if (counter[c] == kernel_sizes[c] && c > 0) {
+                counter[c - 1]++;
+                counter[c] = 0;
+            }
+        }
+    }
+    return point_counter;
+}
+
+/// Ravel ND coordinate to 1D hash using mixed-radix encoding.
+inline int64_t ravel_coord(const int* coord, const int* mins, const int* sizes) {
+    int64_t cur = 0;
+    for (int i = 0; i < NDIM; i++) {
+        cur = cur * sizes[i] + (coord[i] - mins[i]);
+    }
+    return cur;
+}
+
+/// Unravel 1D hash back to ND coordinate.
+inline void unravel_coord(int64_t hash, const int* mins, const int* sizes, int* out) {
+    for (int i = NDIM - 1; i >= 0; i--) {
+        out[i] = mins[i] + static_cast<int>(hash % sizes[i]);
+        hash /= sizes[i];
+    }
+}
+
+/// Generate unique output coordinates for stride > 1 convolution.
+/// Input coords in [batch, x, y, z] format.
+/// Returns number of unique output voxels written to out_coords_bxyz.
+///
+/// GPU-only pipeline: candidate generation → hash-table dedup → compact +
+/// GPU unravel. One D→H memcpy of num_unique (needed for the return value /
+/// downstream buffer sizing); NO host-side sort, no host unravel, no H→D of
+/// coordinates. Scratch allocations persist in `scratch` (high-watermark).
+///
+/// Historical: earlier revision did host sort + host unravel + H→D of
+/// [num_unique, 4] int32. That sat on the critical path serialized behind
+/// two q.wait() calls, adding ~5-8 ms to spconv1 alone. See
+/// ov_sparse_convolution_int8_optimization.md §11.
+///
+/// Ordering note (from §11.3 experiment): we dropped host std::sort on the
+/// assumption that downstream doesn't require sorted output coords. Verified
+/// empirically — recall stays 0.9517, latency improves. The output order is
+/// now whatever the atomic fetch_add in the compact kernel produces
+/// (stable within a frame, but not lexicographic).
+template <typename Stage1Scratch_>
+static int downsample_generate_output_coords(
+    ::sycl::queue& q,
+    const int32_t* in_coords_bxyz,   // [N_in, 4] on device, bxyz format
+    int n_in,
+    const uint32_t* kernel_sizes,    // host [3]
+    const uint32_t* stride,          // host [3]
+    const uint32_t* padding,         // host [3]
+    const uint32_t* spatial_shape,   // host [3] — input spatial shape
+    int32_t* out_coords_bxyz,        // [max_out, 4] on device, bxyz format
+    int max_out,
+    Stage1Scratch_& scratch)
+{
+    int k_vol = static_cast<int>(kernel_sizes[0]) *
+                static_cast<int>(kernel_sizes[1]) *
+                static_cast<int>(kernel_sizes[2]);
+
+    // Compute output space bounds
+    int h_cmin[4] = {0, 0, 0, 0};
+    int h_cmax[4];
+    h_cmax[0] = 0;  // batch
+    for (int i = 0; i < 3; i++) {
+        h_cmax[i + 1] = static_cast<int>(
+            (spatial_shape[i] - 1 + 2 * padding[i] - (kernel_sizes[i] - 1)) / stride[i]);
+    }
+
+    int h_sizes[4];
+    for (int i = 0; i < 4; i++) h_sizes[i] = h_cmax[i] - h_cmin[i] + 1;
+
+    const int ks0 = static_cast<int>(kernel_sizes[0]);
+    const int ks1 = static_cast<int>(kernel_sizes[1]);
+    const int ks2 = static_cast<int>(kernel_sizes[2]);
+    const int st0 = static_cast<int>(stride[0]);
+    const int st1 = static_cast<int>(stride[1]);
+    const int st2 = static_cast<int>(stride[2]);
+    const int pd0 = static_cast<int>(padding[0]);
+    const int pd1 = static_cast<int>(padding[1]);
+    const int pd2 = static_cast<int>(padding[2]);
+    const int cmin0 = h_cmin[0], cmin1 = h_cmin[1], cmin2 = h_cmin[2], cmin3 = h_cmin[3];
+    const int cmax0 = h_cmax[0], cmax1 = h_cmax[1], cmax2 = h_cmax[2], cmax3 = h_cmax[3];
+    const int sz0 = h_sizes[0], sz1 = h_sizes[1], sz2 = h_sizes[2], sz3 = h_sizes[3];
+
+    // Total output spatial volume — used for hash table sizing
+    int64_t total_output_space = static_cast<int64_t>(sz0) * sz1 * sz2 * sz3;
+
+    // Hash table capacity: 2× expected unique count for low collision rate.
+    // Upper-bound unique count by min(k_vol * n_in, total_output_space).
+    int64_t max_unique_est = std::min(static_cast<int64_t>(k_vol) * n_in,
+                                       total_output_space);
+    int hash_cap = static_cast<int>(std::min(max_unique_est * 2,
+                                              static_cast<int64_t>(1 << 22)));  // cap at 4M
+    if (hash_cap < 1024) hash_cap = 1024;
+
+    // Sentinel for empty hash slots: use -1 (no valid raveled coord is negative)
+    constexpr int64_t HASH_EMPTY_KEY = -1;
+
+    // Persistent device buffers (A3) — grow high-watermark, never freed
+    // per-frame. `scratch.q` is set on first call and drives the destructor
+    // cleanup in sparse_convolution_sycl::~.
+    if (scratch.q == nullptr) scratch.q = &q;
+    if (scratch.hash_cap < hash_cap) {
+        if (scratch.hash_keys) ::sycl::free(scratch.hash_keys, q);
+        scratch.hash_keys = ::sycl::malloc_device<int64_t>(hash_cap, q);
+        scratch.hash_cap = hash_cap;
+    }
+    if (scratch.counter == nullptr) {
+        scratch.counter = ::sycl::malloc_device<int>(1, q);
+    }
+    int64_t* d_hash_keys = scratch.hash_keys;
+    int*     d_out_counter = scratch.counter;
+
+    // Initialize hash table to empty and counter to 0
+    q.memset(d_out_counter, 0, sizeof(int));
+    q.fill(d_hash_keys, HASH_EMPTY_KEY, hash_cap);
+
+    // ---------------------------------------------------------------
+    // Step 1: Generate candidate coords and insert into hash table (GPU)
+    // Each input point generates up to k_vol candidates.
+    // Dedup via atomic CAS into the hash table — duplicates are rejected.
+    // ---------------------------------------------------------------
+    int num_wg = (n_in + WG_SIZE - 1) / WG_SIZE;
+    q.parallel_for(
+        ::sycl::nd_range<1>(::sycl::range<1>(num_wg * WG_SIZE),
+                            ::sycl::range<1>(WG_SIZE)),
+        [=](::sycl::nd_item<1> item) {
+            int gid = item.get_global_id(0);
+            if (gid >= n_in) return;
+
+            int counter_arr[3] = {0, 0, 0};
+            const int lower[3] = {-(ks0 - 1), -(ks1 - 1), -(ks2 - 1)};
+            const int l_ks[3] = {ks0, ks1, ks2};
+            const int l_st[3] = {st0, st1, st2};
+            const int l_pd[3] = {pd0, pd1, pd2};
+            const int l_cmin[4] = {cmin0, cmin1, cmin2, cmin3};
+            const int l_cmax[4] = {cmax0, cmax1, cmax2, cmax3};
+            const int l_sz[4] = {sz0, sz1, sz2, sz3};
+
+            const int* in_c = in_coords_bxyz + gid * 4;
+
+            for (int ki = 0; ki < k_vol; ki++) {
+                int out_c[4];
+                bool valid = true;
+                for (int j = 3; j >= 1; --j) {
+                    int cur = in_c[j] + (lower[j - 1] + counter_arr[j - 1]) + l_pd[j - 1];
+                    int cur_div = cur / l_st[j - 1];
+                    if ((cur % l_st[j - 1] == 0) &&
+                        (cur_div >= l_cmin[j]) &&
+                        (cur_div <= l_cmax[j])) {
+                        out_c[j] = cur_div;
+                    } else {
+                        valid = false;
+                    }
+                }
+                counter_arr[2]++;
+                out_c[0] = in_c[0];
+
+                for (int c = 2; c >= 0; --c) {
+                    if (counter_arr[c] == l_ks[c] && c > 0) {
+                        counter_arr[c - 1]++;
+                        counter_arr[c] = 0;
+                    }
+                }
+
+                if (!valid) continue;
+
+                // Ravel coordinate to int64 key
+                int64_t key = 0;
+                for (int dd = 0; dd < 4; dd++)
+                    key = key * l_sz[dd] + (out_c[dd] - l_cmin[dd]);
+
+                // Insert into hash table via atomic CAS (linear probing)
+                // FNV-1a hash for slot selection
+                uint64_t h = 14695981039346656037ULL;
+                h ^= static_cast<uint64_t>(key);
+                h *= 1099511628211ULL;
+                h ^= static_cast<uint64_t>(key >> 32);
+                h *= 1099511628211ULL;
+                int slot = static_cast<int>(h % static_cast<uint64_t>(hash_cap));
+
+                for (int probe = 0; probe < hash_cap; probe++) {
+                    ::sycl::atomic_ref<int64_t,
+                                       ::sycl::memory_order::relaxed,
+                                       ::sycl::memory_scope::device,
+                                       ::sycl::access::address_space::global_space>
+                        slot_ref(d_hash_keys[slot]);
+
+                    int64_t expected = HASH_EMPTY_KEY;
+                    if (slot_ref.compare_exchange_strong(expected, key)) {
+                        // Successfully inserted a new unique key — count it
+                        ::sycl::atomic_ref<int,
+                                           ::sycl::memory_order::relaxed,
+                                           ::sycl::memory_scope::device,
+                                           ::sycl::access::address_space::global_space>
+                            cnt(d_out_counter[0]);
+                        cnt.fetch_add(1);
+                        break;
+                    }
+                    if (expected == key) break;  // Already exists — dedup
+                    slot = (slot + 1) % hash_cap;  // Linear probing
+                }
+            }
+        });
+
+    // ---------------------------------------------------------------
+    // Step 2: Compact hash table → GPU unravel to output coords.
+    //
+    // Previously: host readback + std::sort + manual unravel + H→D copy.
+    // That sat on the critical path behind two q.wait() calls and added
+    // 5-8 ms to spconv1 alone (§11). Now: compact + unravel both on GPU,
+    // one `wait()` + one 4-byte D→H (for num_unique → return value +
+    // buffer sizing).
+    // ---------------------------------------------------------------
+    // Capture the stack-local hash size array (can't capture h_sizes / h_cmin
+    // directly — they're arrays, not trivially copyable into device lambdas).
+    const int sizes_copy[NDIM] = { h_sizes[0], h_sizes[1], h_sizes[2], h_sizes[3] };
+    const int mins_copy[NDIM]  = { h_cmin[0],  h_cmin[1],  h_cmin[2],  h_cmin[3]  };
+
+    // First read num_unique (needed for out_coords_bxyz sizing via max_out clamp).
+    // We MUST wait here — num_unique drives the `n_copy` return value which the
+    // caller uses to size downstream allocations. Only 4-byte D→H.
+    q.wait();
+    int num_unique = 0;
+    q.memcpy(&num_unique, d_out_counter, sizeof(int)).wait();
+    if (num_unique <= 0) {
+        return 0;
+    }
+    int n_copy = std::min(num_unique, max_out);
+
+    // Persistent compact buffer (A3). Grow high-watermark.
+    if (scratch.compact_cap < num_unique) {
+        if (scratch.compact) ::sycl::free(scratch.compact, q);
+        scratch.compact = ::sycl::malloc_device<int64_t>(num_unique, q);
+        scratch.compact_cap = num_unique;
+    }
+    int64_t* d_compact = scratch.compact;
+
+    // Reset counter (reused as compact position) — submit async, no wait.
+    q.memset(d_out_counter, 0, sizeof(int));
+
+    // Compact: scan hash table, write non-empty keys into d_compact.
+    int hash_wg = (hash_cap + WG_SIZE - 1) / WG_SIZE;
+    const int  hash_cap_local   = hash_cap;
+    const int  num_unique_local = num_unique;
+    q.parallel_for(
+        ::sycl::nd_range<1>(::sycl::range<1>(hash_wg * WG_SIZE),
+                            ::sycl::range<1>(WG_SIZE)),
+        [=](::sycl::nd_item<1> item) {
+            int gid = item.get_global_id(0);
+            if (gid >= hash_cap_local) return;
+            int64_t key = d_hash_keys[gid];
+            if (key != HASH_EMPTY_KEY) {
+                ::sycl::atomic_ref<int,
+                                   ::sycl::memory_order::relaxed,
+                                   ::sycl::memory_scope::device,
+                                   ::sycl::access::address_space::global_space>
+                    cnt(d_out_counter[0]);
+                int pos = cnt.fetch_add(1);
+                if (pos < num_unique_local) d_compact[pos] = key;
+            }
+        });
+
+    // GPU unravel d_compact[0..n_copy] → out_coords_bxyz. No sort:
+    // downstream SubM kmap construction and kernel_map lookup don't require
+    // sorted output coordinates, only a stable per-frame ordering. Verified
+    // empirically in §11.3 (recall unchanged).
+    //
+    // SPCONV_STAGE1_LEGACY=1 restores the old host sort + host unravel + H→D
+    // path as an A/B bisect handle (regression diagnosis only; slow).
+    static const bool s_stage1_legacy = []() {
+        const char* e = std::getenv("SPCONV_STAGE1_LEGACY");
+        return e != nullptr && e[0] != '0' && e[0] != '\0';
+    }();
+    if (s_stage1_legacy) {
+        q.wait();
+        std::vector<int64_t> host_compact(num_unique);
+        q.memcpy(host_compact.data(), d_compact, num_unique * sizeof(int64_t)).wait();
+        std::sort(host_compact.begin(), host_compact.end());
+        std::vector<int32_t> host_out(n_copy * 4);
+        for (int i = 0; i < n_copy; i++) {
+            int64_t cur = host_compact[i];
+            for (int d = NDIM - 1; d >= 0; d--) {
+                host_out[i * 4 + d] = mins_copy[d] + static_cast<int>(cur % sizes_copy[d]);
+                cur /= sizes_copy[d];
+            }
+        }
+        q.memcpy(out_coords_bxyz, host_out.data(), n_copy * 4 * sizeof(int32_t));
+        return n_copy;
+    }
+
+    const int n_copy_local = n_copy;
+    q.parallel_for(
+        ::sycl::range<1>(n_copy_local),
+        [=](::sycl::id<1> idx) {
+            int i = static_cast<int>(idx[0]);
+            int64_t cur = d_compact[i];
+            int* out = out_coords_bxyz + i * 4;
+            // Match original host-side unravel: walk d=NDIM-1..0, out[d] = mins[d] + cur%sizes[d].
+            for (int d = NDIM - 1; d >= 0; d--) {
+                out[d] = mins_copy[d] + static_cast<int>(cur % sizes_copy[d]);
+                cur /= sizes_copy[d];
+            }
+        });
+
+    // Don't wait — compact+unravel are in flight; caller will wait before
+    // using out_coords_bxyz in downstream Stage 1 ops on the same queue.
+    return n_copy;
+}
+
+// ===================================================================
+// Stage 2a: Implicit GEMM — FP32 tiled kernel
+// ===================================================================
+
+/// Tiled implicit GEMM for sparse convolution.
+///
+/// Grid: num_work_groups = ceil(M/TILE_M) * ceil(N/TILE_N)
+/// Work-group: 256 threads (8 rows × 32 cols logically)
+/// Each thread accumulates 8×4 output elements.
+///
+/// No masking/sorting — iterates all kernel positions and checks map directly.
+static void conv_implicit_gemm_fp32_kernel(
+    ::sycl::nd_item<1> item,
+    ::sycl::local_accessor<float, 1> slm_in,
+    ::sycl::local_accessor<float, 1> slm_wt,
+    int M, int K, int N, int k_vol,
+    const float* __restrict__ in_feats,
+    const float* __restrict__ weights,
+    const int32_t* __restrict__ out_in_map,
+    float* __restrict__ out_feats)
+{
+    const int lid = item.get_local_id(0);
+    const int gid = item.get_group(0);
+
+    const int tid_x = lid % 32;
+    const int tid_y = lid / 32;
+
+    const int N_tiles = (N + TILE_N - 1) / TILE_N;
+    const int tile_m = gid / N_tiles;
+    const int tile_n = gid % N_tiles;
+
+    const int out_row_start = tile_m * TILE_M;
+    const int out_col_start = tile_n * TILE_N;
+
+    // Per-thread accumulators: 8 rows × 4 cols = 32
+    float C[32];
+    for (int i = 0; i < 32; i++) C[i] = 0.0f;
+
+    const int K_padded = ((K + TILE_K - 1) / TILE_K) * TILE_K;
+
+    // Loop over kernel positions and K tiles
+    for (int ki = 0; ki < k_vol; ki++) {
+        for (int k_tile = 0; k_tile < K_padded; k_tile += TILE_K) {
+
+            // Phase 1: Load input tile to SLM [TILE_M × TILE_K]
+            // Use tid_x/16 to split 32 threads into two halves, each covering
+            // 8 rows within a 16-row block — together they fill all 128 rows.
+            for (int li = 0; li < 8; li++) {
+                int row = tid_y * 16 + (tid_x / 16) * 8 + li;
+                int col = tid_x % 16;
+
+                if (row < TILE_M && col < TILE_K) {
+                    int g_row = out_row_start + row;
+                    float val = 0.0f;
+
+                    if (g_row < M) {
+                        int map_idx = out_in_map[g_row * k_vol + ki];
+                        if (map_idx >= 0) {
+                            int g_k = k_tile + col;
+                            if (g_k < K)
+                                val = in_feats[map_idx * K + g_k];
+                        }
+                    }
+                    slm_in[slm_skew(row, col, TILE_K)] = val;
+                }
+            }
+
+            // Phase 2: Load weight tile to SLM [TILE_K × TILE_N]
+            {
+                int k_idx = tid_y * 2 + tid_x / 16;
+                int n_idx = tid_x % 16;
+
+                if (k_idx < TILE_K && n_idx < TILE_N) {
+                    int g_k = k_tile + k_idx;
+                    int g_n = out_col_start + n_idx;
+                    float val = 0.0f;
+                    if (g_k < K && g_n < N)
+                        val = weights[ki * K * N + g_k * N + g_n];
+                    slm_wt[slm_skew(k_idx, n_idx, TILE_N)] = val;
+                }
+            }
+
+            item.barrier(::sycl::access::fence_space::local_space);
+
+            // Phase 3: Matrix multiply
+            // Use (tid_x/16)*8 offset so both halves of each 16-row block are computed.
+            for (int kk = 0; kk < TILE_K; kk++) {
+                float a[8];
+                for (int i = 0; i < 8; i++) {
+                    int row = tid_y * 16 + (tid_x / 16) * 8 + i;
+                    a[i] = (row < TILE_M && (out_row_start + row) < M)
+                               ? slm_in[slm_skew(row, kk, TILE_K)]
+                               : 0.0f;
+                }
+                float b[4];
+                for (int j = 0; j < 4; j++) {
+                    int col = (tid_x % 4) * 4 + j;
+                    b[j] = (col < TILE_N) ? slm_wt[slm_skew(kk, col, TILE_N)] : 0.0f;
+                }
+                for (int i = 0; i < 8; i++)
+                    for (int j = 0; j < 4; j++)
+                        C[i * 4 + j] += a[i] * b[j];
+            }
+
+            item.barrier(::sycl::access::fence_space::local_space);
+        }
+    }
+
+    // Phase 4: Store results
+    for (int i = 0; i < 8; i++) {
+        int g_row = out_row_start + tid_y * 16 + (tid_x / 16) * 8 + i;
+        if (g_row < M) {
+            for (int j = 0; j < 4; j++) {
+                int g_col = out_col_start + (tid_x % 4) * 4 + j;
+                if (g_col < N) {
+                    out_feats[g_row * N + g_col] = C[i * 4 + j];
+                }
+            }
+        }
+    }
+}
+
+/// Launch the FP32 implicit GEMM.
+static void run_implicit_gemm_fp32(::sycl::queue& q,
+                                    const float* in_feats,
+                                    const float* weights,
+                                    const int32_t* out_in_map,
+                                    float* out_feats,
+                                    int M, int K, int N, int k_vol) {
+    const int M_tiles = (M + TILE_M - 1) / TILE_M;
+    const int N_tiles = (N + TILE_N - 1) / TILE_N;
+    const int num_groups = M_tiles * N_tiles;
+    const int slm_in_size = TILE_M * (TILE_K + SKEW);
+    const int slm_wt_size = TILE_K * (TILE_N + SKEW);
+
+    q.submit([&](::sycl::handler& cgh) {
+        auto slm_in = ::sycl::local_accessor<float, 1>(slm_in_size, cgh);
+        auto slm_wt = ::sycl::local_accessor<float, 1>(slm_wt_size, cgh);
+
+        cgh.parallel_for(
+            ::sycl::nd_range<1>(::sycl::range<1>(num_groups * WG_SIZE),
+                                ::sycl::range<1>(WG_SIZE)),
+            [=](::sycl::nd_item<1> item) {
+                conv_implicit_gemm_fp32_kernel(
+                    item, slm_in, slm_wt,
+                    M, K, N, k_vol,
+                    in_feats, weights, out_in_map, out_feats);
+            });
+    });
+}
+
+// ===================================================================
+// Stage 2a-fp16: Implicit GEMM — FP16 XMX (joint_matrix) kernel
+// ===================================================================
+//
+// Uses Intel XMX hardware (DPAS instructions) via SYCL joint_matrix API.
+// Mixed precision: FP16 inputs/weights, FP32 accumulator, FP16 output.
+// Fuses bias addition + ReLU into the store phase (single kernel launch).
+//
+// Tile config (16×16×16 joint_matrix):
+//   TILE_M = 64  (4 sub-groups × TM=16)
+//   TILE_N = 32  (2 iterations × TN=16)
+//   TILE_K = 16
+//   Work-group: 8 sub-groups × 16 threads = 128 threads
+//   SLM: input 64×16 half + weight 16×32 half + temp 8×16×16 float ≈ 7KB
+
+static constexpr int XMX_TM = 16;
+static constexpr int XMX_TN = 16;
+static constexpr int XMX_TK = 16;
+static constexpr int XMX_TILE_M = XMX_TM * 4;   // 64
+static constexpr int XMX_TILE_N = XMX_TN * 2;   // 32
+static constexpr int XMX_TILE_K = XMX_TK;        // 16
+static constexpr int XMX_NUM_SG = 8;             // sub-groups per work-group
+static constexpr int XMX_SG_SIZE = 16;           // threads per sub-group
+static constexpr int XMX_WG_SIZE = XMX_NUM_SG * XMX_SG_SIZE;  // 128
+static constexpr int XMX_SKEW = 8;              // SLM bank-conflict avoidance (half elements)
+
+// SLM layout constants for FP16 XMX kernel (standard TILE_N=32)
+static constexpr int SLM_IN_STRIDE = XMX_TILE_K + XMX_SKEW;   // 24
+static constexpr int SLM_WT_STRIDE = XMX_TILE_N + XMX_SKEW;   // 40
+static constexpr int SLM_IN_BUF_SIZE = XMX_TILE_M * SLM_IN_STRIDE;   // 64×24 = 1536
+static constexpr int SLM_WT_BUF_SIZE = XMX_TILE_K * SLM_WT_STRIDE;   // 16×40 = 640
+
+// Wide kernel variant: TILE_N=64 for layers with N≥64
+// Uses 16 sub-groups (4 rows × 4 cols), WG=256. Halves N-groups so each
+// input tile is shared by 2× more SG columns, reducing redundant input reads.
+static constexpr int XMX_TILE_N_WIDE = XMX_TN * 4;            // 64
+static constexpr int XMX_NUM_SG_WIDE = 16;                     // 4 rows × 4 cols
+static constexpr int XMX_WG_SIZE_WIDE = XMX_NUM_SG_WIDE * XMX_SG_SIZE;  // 256
+static constexpr int SLM_WT_STRIDE_WIDE = XMX_TILE_N_WIDE + XMX_SKEW;   // 72
+static constexpr int SLM_WT_BUF_SIZE_WIDE = XMX_TILE_K * SLM_WT_STRIDE_WIDE;  // 16×72 = 1152
+
+/// Load one input tile [TILE_M × TILE_K] into SLM at slm_base offset.
+/// Row-based distribution: 128 threads load 64 rows → ~1 row/2threads.
+/// Uses half8 vectorized global loads when the source row is contiguous.
+static inline void load_input_tile_to_slm(
+    ::sycl::local_accessor<::sycl::half, 1>& slm_input,
+    int slm_base,
+    int local_id,
+    int out_row_start,
+    int M, int K, int k_vol,
+    int kernel_idx, int k_offset_in_kernel,
+    const ::sycl::half* __restrict__ in_feats,
+    const int32_t* __restrict__ out_in_map)
+{
+    // Row-based assignment: thread t handles row (t/2), cols [0..7] or [8..15]
+    // 128 threads handle 64 rows × 2 halves = 8 elements/thread
+    // This allows reading out_in_map once per row and doing contiguous half8 loads.
+    const int assigned_row = local_id / 2;
+    const int col_half = (local_id % 2) * 8;  // 0 or 8
+
+    if (assigned_row < XMX_TILE_M) {
+        const int global_row = out_row_start + assigned_row;
+        const int slm_row_base = slm_base + assigned_row * SLM_IN_STRIDE;
+
+        if (global_row < M) {
+            const int map_idx = out_in_map[global_row * k_vol + kernel_idx];
+
+            if (map_idx >= 0 && k_offset_in_kernel + col_half < K &&
+                k_offset_in_kernel + col_half + 8 <= K) {
+                // Vectorized path: load 8 contiguous half values
+                const ::sycl::half* src = in_feats + map_idx * K
+                                          + k_offset_in_kernel + col_half;
+                using half8 = ::sycl::vec<::sycl::half, 8>;
+                half8 v;
+                v.load(0, ::sycl::address_space_cast<
+                    ::sycl::access::address_space::global_space,
+                    ::sycl::access::decorated::no>(src));
+                // Store to SLM scalars (SLM accessor doesn't support vec store)
+                for (int j = 0; j < 8; j++)
+                    slm_input[slm_row_base + col_half + j] = v[j];
+            } else {
+                // Scalar fallback for partial tiles or small K
+                for (int j = 0; j < 8; j++) {
+                    int col = col_half + j;
+                    ::sycl::half val(0.0f);
+                    if (col < XMX_TILE_K) {
+                        int k_idx = k_offset_in_kernel + col;
+                        if (map_idx >= 0 && k_idx < K)
+                            val = in_feats[map_idx * K + k_idx];
+                    }
+                    slm_input[slm_row_base + col] = val;
+                }
+            }
+        } else {
+            // Out-of-bounds row: zero fill
+            for (int j = 0; j < 8; j++)
+                slm_input[slm_row_base + col_half + j] = ::sycl::half(0.0f);
+        }
+    }
+    // Remaining threads (local_id >= 128) do nothing — 128 threads handle 64 rows × 2 halves
+}
+
+/// Load one weight tile [TILE_K × TILE_N] into SLM at slm_base offset.
+/// Weights are contiguous in N dimension — use half8 vector loads.
+static inline void load_weight_tile_to_slm(
+    ::sycl::local_accessor<::sycl::half, 1>& slm_weight,
+    int slm_base,
+    int local_id,
+    int out_col_start,
+    int K, int N,
+    int kernel_idx, int k_offset_in_kernel,
+    const ::sycl::half* __restrict__ weights)
+{
+    // 16 rows × 32 cols = 512 elements, 128 threads → 4 elements/thread
+    // Assign each thread to a (k_row, n_group) pair for contiguous N access
+    // 128 threads: 16 k_rows × 8 n_groups_of_4 = 128 → 1 thread per group
+    // Actually: 512 elements / 128 threads = 4 elements each, assign linearly by row
+    constexpr int wt_elements = XMX_TILE_K * XMX_TILE_N;
+    constexpr int wt_per_thread = (wt_elements + XMX_WG_SIZE - 1) / XMX_WG_SIZE;  // 4
+
+    for (int elem = 0; elem < wt_per_thread; elem++) {
+        int flat_idx = local_id * wt_per_thread + elem;
+        if (flat_idx < wt_elements) {
+            int k_idx = flat_idx / XMX_TILE_N;
+            int n_idx = flat_idx % XMX_TILE_N;
+            ::sycl::half val(0.0f);
+            int global_k = k_offset_in_kernel + k_idx;
+            int global_n = out_col_start + n_idx;
+            if (global_k < K && global_n < N)
+                val = weights[kernel_idx * K * N + global_k * N + global_n];
+            slm_weight[slm_base + k_idx * SLM_WT_STRIDE + n_idx] = val;
+        }
+    }
+}
+
+/// FP16 XMX implicit GEMM kernel with fused bias + ReLU.
+/// Uses double-buffered SLM: load next tile while computing current tile.
+/// Uses half8 vectorized global loads for input features.
+static void conv_implicit_gemm_fp16_xmx_kernel(
+    ::sycl::nd_item<2> item,
+    ::sycl::local_accessor<::sycl::half, 1> slm_input,   // 2 × SLM_IN_BUF_SIZE
+    ::sycl::local_accessor<::sycl::half, 1> slm_weight,  // 2 × SLM_WT_BUF_SIZE
+    ::sycl::local_accessor<float, 1> slm_temp,
+    int M, int K, int N, int k_vol,
+    const ::sycl::half* __restrict__ in_feats,
+    const ::sycl::half* __restrict__ weights,
+    const int32_t* __restrict__ out_in_map,
+    ::sycl::half* __restrict__ out_feats,
+    const ::sycl::half* __restrict__ bias,  // nullptr if no bias
+    bool apply_relu)
+{
+    auto sg = item.get_sub_group();
+    const int sg_id = sg.get_group_linear_id();
+    const int local_id = item.get_local_linear_id();
+
+    const int group_id_m = item.get_group(0);
+    const int group_id_n = item.get_group(1);
+
+    const int out_row_start = group_id_m * XMX_TILE_M;
+    const int out_col_start = group_id_n * XMX_TILE_N;
+
+    // Each sub-group handles TM×TN output tile
+    const int sg_row_start = out_row_start + (sg_id / 2) * XMX_TM;
+    const int sg_col_start = out_col_start + (sg_id % 2) * XMX_TN;
+
+    // Joint matrix fragments
+    sycl_matrix::joint_matrix<::sycl::sub_group, ::sycl::half,
+                              sycl_matrix::use::a,
+                              XMX_TM, XMX_TK,
+                              sycl_matrix::layout::row_major> sub_a;
+    sycl_matrix::joint_matrix<::sycl::sub_group, ::sycl::half,
+                              sycl_matrix::use::b,
+                              XMX_TK, XMX_TN,
+                              sycl_matrix::layout::row_major> sub_b;
+    sycl_matrix::joint_matrix<::sycl::sub_group, float,
+                              sycl_matrix::use::accumulator,
+                              XMX_TM, XMX_TN> sub_c;
+
+    sycl_matrix::joint_matrix_fill(sg, sub_c, 0.0f);
+
+    const int K_tile_padded = ((K + XMX_TILE_K - 1) / XMX_TILE_K) * XMX_TILE_K;
+    const int K_implicit = K_tile_padded * k_vol;
+    const int total_k_iters = K_implicit / XMX_TILE_K;
+
+    // Sub-group SLM offsets for joint_matrix_load (relative to buffer start)
+    const int sg_slm_row = (sg_id / 2) * XMX_TM;
+    const int sg_slm_col_b = (sg_id % 2) * XMX_TN;
+
+    if (total_k_iters == 0) goto store_results;
+
+    {
+        // Double-buffered main loop:
+        //   buf 0: SLM offset 0
+        //   buf 1: SLM offset SLM_IN_BUF_SIZE / SLM_WT_BUF_SIZE
+        int cur_buf = 0;
+
+        // Prefetch first tile into buf 0
+        {
+            int kernel_idx_0 = 0;
+            int k_offset_0 = 0;
+            load_input_tile_to_slm(slm_input, 0, local_id,
+                out_row_start, M, K, k_vol,
+                kernel_idx_0, k_offset_0, in_feats, out_in_map);
+            load_weight_tile_to_slm(slm_weight, 0, local_id,
+                out_col_start, K, N,
+                kernel_idx_0, k_offset_0, weights);
+        }
+
+        for (int k_iter = 0; k_iter < total_k_iters; k_iter++) {
+            // Ensure current buffer is ready
+            item.barrier(::sycl::access::fence_space::local_space);
+
+            int in_base = cur_buf * SLM_IN_BUF_SIZE;
+            int wt_base = cur_buf * SLM_WT_BUF_SIZE;
+
+            // Start loading next tile into the other buffer (if not last iteration)
+            int next_buf = 1 - cur_buf;
+            if (k_iter + 1 < total_k_iters) {
+                int next_iter = k_iter + 1;
+                int next_kernel_idx = next_iter * XMX_TILE_K / K_tile_padded;
+                int next_k_offset = (next_iter * XMX_TILE_K) % K_tile_padded;
+
+                load_input_tile_to_slm(slm_input,
+                    next_buf * SLM_IN_BUF_SIZE, local_id,
+                    out_row_start, M, K, k_vol,
+                    next_kernel_idx, next_k_offset, in_feats, out_in_map);
+                load_weight_tile_to_slm(slm_weight,
+                    next_buf * SLM_WT_BUF_SIZE, local_id,
+                    out_col_start, K, N,
+                    next_kernel_idx, next_k_offset, weights);
+            }
+
+            // Compute from current buffer — this overlaps with the load above
+            // because they write to different SLM regions
+            sycl_matrix::joint_matrix_load(sg, sub_a,
+                slm_input.template get_multi_ptr<::sycl::access::decorated::no>()
+                    + in_base + sg_slm_row * SLM_IN_STRIDE,
+                SLM_IN_STRIDE);
+
+            sycl_matrix::joint_matrix_load(sg, sub_b,
+                slm_weight.template get_multi_ptr<::sycl::access::decorated::no>()
+                    + wt_base + sg_slm_col_b,
+                SLM_WT_STRIDE);
+
+            sycl_matrix::joint_matrix_mad(sg, sub_c, sub_a, sub_b, sub_c);
+
+            cur_buf = next_buf;
+        }
+    }
+
+store_results:
+    // Phase 4: Store results with fused bias + ReLU
+    constexpr int elements_per_sg = XMX_TM * XMX_TN;
+    float* temp_c = slm_temp.get_multi_ptr<::sycl::access::decorated::no>().get_raw()
+                    + sg_id * elements_per_sg;
+
+    auto temp_c_ptr = ::sycl::address_space_cast<
+        ::sycl::access::address_space::local_space,
+        ::sycl::access::decorated::no>(temp_c);
+    sycl_matrix::joint_matrix_store(sg, sub_c, temp_c_ptr, XMX_TN,
+                                     sycl_matrix::layout::row_major);
+
+    // Preload bias for this sub-group's column range into registers
+    float bias_cache[XMX_TN];
+    if (bias) {
+        for (int j = 0; j < XMX_TN; j++) {
+            int gc = sg_col_start + j;
+            bias_cache[j] = (gc < N) ? static_cast<float>(bias[gc]) : 0.0f;
+        }
+    }
+
+    // Partition store across sub-group threads: each thread handles
+    // elements_per_sg / SG_SIZE = 256 / 16 = 16 elements (one TN-wide row).
+    const int sg_local_id = static_cast<int>(sg.get_local_id()[0]);
+    constexpr int elems_per_thread = elements_per_sg / XMX_SG_SIZE;
+    const int flat_start = sg_local_id * elems_per_thread;
+
+    for (int i = 0; i < elems_per_thread; i++) {
+        int flat = flat_start + i;
+        int row = flat / XMX_TN;
+        int col = flat % XMX_TN;
+        int global_row = sg_row_start + row;
+        int global_col = sg_col_start + col;
+        if (global_row < M && global_col < N) {
+            float val = temp_c[flat];
+            if (bias) val += bias_cache[col];
+            if (apply_relu) val = val > 0.0f ? val : 0.0f;
+            out_feats[global_row * N + global_col] = ::sycl::half(val);
+        }
+    }
+}
+
+/// Launch FP16 XMX implicit GEMM with fused bias + ReLU.
+/// Double-buffered SLM: 2× input + 2× weight buffers.
+static void run_implicit_gemm_fp16_xmx(::sycl::queue& q,
+                                         const ::sycl::half* in_feats,
+                                         const ::sycl::half* weights,
+                                         const int32_t* out_in_map,
+                                         ::sycl::half* out_feats,
+                                         int M, int K, int N, int k_vol,
+                                         const ::sycl::half* bias,
+                                         bool apply_relu) {
+    const int num_groups_m = (M + XMX_TILE_M - 1) / XMX_TILE_M;
+    const int num_groups_n = (N + XMX_TILE_N - 1) / XMX_TILE_N;
+
+    // Double-buffered SLM: 2 copies of input and weight buffers
+    const int slm_input_size = 2 * SLM_IN_BUF_SIZE;
+    const int slm_weight_size = 2 * SLM_WT_BUF_SIZE;
+    const int slm_temp_size = XMX_NUM_SG * XMX_TM * XMX_TN;
+
+    q.submit([&](::sycl::handler& cgh) {
+        auto slm_in = ::sycl::local_accessor<::sycl::half, 1>(slm_input_size, cgh);
+        auto slm_wt = ::sycl::local_accessor<::sycl::half, 1>(slm_weight_size, cgh);
+        auto slm_tmp = ::sycl::local_accessor<float, 1>(slm_temp_size, cgh);
+
+        cgh.parallel_for(
+            ::sycl::nd_range<2>(
+                ::sycl::range<2>(num_groups_m * XMX_NUM_SG,
+                                  num_groups_n * XMX_SG_SIZE),
+                ::sycl::range<2>(XMX_NUM_SG, XMX_SG_SIZE)),
+            [=](::sycl::nd_item<2> item) [[sycl::reqd_sub_group_size(16)]] {
+                conv_implicit_gemm_fp16_xmx_kernel(
+                    item, slm_in, slm_wt, slm_tmp,
+                    M, K, N, k_vol,
+                    in_feats, weights, out_in_map, out_feats,
+                    bias, apply_relu);
+            });
+    });
+}
+
+// ===================================================================
+// Stage 2a-fp16-wide: Wide TILE_N=64 variant for N≥64 layers
+// ===================================================================
+//
+// Same TILE_M=64, TILE_K=16 input tile, but TILE_N=64 weight tile.
+// 16 sub-groups: 4 SG rows × 4 SG cols → WG_SIZE=256.
+// Halves N-workgroups: each input tile shared by 4 SG columns (vs 2).
+// SLM: input 2×64×24 + weight 2×16×72 + temp 16×256 ≈ 23.6KB
+
+/// Load one wide weight tile [TILE_K × TILE_N_WIDE] into SLM.
+/// 256 threads load 16×64=1024 elements → 4 elements/thread.
+static inline void load_weight_tile_to_slm_wide(
+    ::sycl::local_accessor<::sycl::half, 1>& slm_weight,
+    int slm_base,
+    int local_id,
+    int out_col_start,
+    int K, int N,
+    int kernel_idx, int k_offset_in_kernel,
+    const ::sycl::half* __restrict__ weights)
+{
+    constexpr int wt_elements = XMX_TILE_K * XMX_TILE_N_WIDE;  // 1024
+    constexpr int wt_per_thread = (wt_elements + XMX_WG_SIZE_WIDE - 1) / XMX_WG_SIZE_WIDE;  // 4
+
+    for (int elem = 0; elem < wt_per_thread; elem++) {
+        int flat_idx = local_id * wt_per_thread + elem;
+        if (flat_idx < wt_elements) {
+            int k_idx = flat_idx / XMX_TILE_N_WIDE;
+            int n_idx = flat_idx % XMX_TILE_N_WIDE;
+            ::sycl::half val(0.0f);
+            int global_k = k_offset_in_kernel + k_idx;
+            int global_n = out_col_start + n_idx;
+            if (global_k < K && global_n < N)
+                val = weights[kernel_idx * K * N + global_k * N + global_n];
+            slm_weight[slm_base + k_idx * SLM_WT_STRIDE_WIDE + n_idx] = val;
+        }
+    }
+}
+
+/// Wide FP16 XMX implicit GEMM kernel: TILE_N=64, 16 sub-groups, WG=256.
+/// Each sub-group computes a TM×TN (16×16) output tile.
+/// SG layout: 4 rows × 4 cols within [TILE_M=64 × TILE_N=64].
+static void conv_implicit_gemm_fp16_xmx_kernel_wide(
+    ::sycl::nd_item<2> item,
+    ::sycl::local_accessor<::sycl::half, 1> slm_input,   // 2 × SLM_IN_BUF_SIZE
+    ::sycl::local_accessor<::sycl::half, 1> slm_weight,  // 2 × SLM_WT_BUF_SIZE_WIDE
+    ::sycl::local_accessor<float, 1> slm_temp,
+    int M, int K, int N, int k_vol,
+    const ::sycl::half* __restrict__ in_feats,
+    const ::sycl::half* __restrict__ weights,
+    const int32_t* __restrict__ out_in_map,
+    ::sycl::half* __restrict__ out_feats,
+    const ::sycl::half* __restrict__ bias,
+    bool apply_relu)
+{
+    auto sg = item.get_sub_group();
+    const int sg_id = sg.get_group_linear_id();
+    const int local_id = item.get_local_linear_id();
+
+    const int group_id_m = item.get_group(0);
+    const int group_id_n = item.get_group(1);
+
+    const int out_row_start = group_id_m * XMX_TILE_M;
+    const int out_col_start = group_id_n * XMX_TILE_N_WIDE;
+
+    // SG layout: 4 rows × 4 cols (sg_id / 4 = row, sg_id % 4 = col)
+    const int sg_row_start = out_row_start + (sg_id / 4) * XMX_TM;
+    const int sg_col_start = out_col_start + (sg_id % 4) * XMX_TN;
+
+    // Joint matrix fragments
+    sycl_matrix::joint_matrix<::sycl::sub_group, ::sycl::half,
+                              sycl_matrix::use::a,
+                              XMX_TM, XMX_TK,
+                              sycl_matrix::layout::row_major> sub_a;
+    sycl_matrix::joint_matrix<::sycl::sub_group, ::sycl::half,
+                              sycl_matrix::use::b,
+                              XMX_TK, XMX_TN,
+                              sycl_matrix::layout::row_major> sub_b;
+    sycl_matrix::joint_matrix<::sycl::sub_group, float,
+                              sycl_matrix::use::accumulator,
+                              XMX_TM, XMX_TN> sub_c;
+
+    sycl_matrix::joint_matrix_fill(sg, sub_c, 0.0f);
+
+    const int K_tile_padded = ((K + XMX_TILE_K - 1) / XMX_TILE_K) * XMX_TILE_K;
+    const int K_implicit = K_tile_padded * k_vol;
+    const int total_k_iters = K_implicit / XMX_TILE_K;
+
+    // SLM offsets for joint_matrix_load
+    const int sg_slm_row = (sg_id / 4) * XMX_TM;
+    const int sg_slm_col_b = (sg_id % 4) * XMX_TN;
+
+    if (total_k_iters == 0) goto store_results_wide;
+
+    {
+        int cur_buf = 0;
+
+        // Prefetch first tile into buf 0
+        // Input: first 128 threads load (threads 128-255 idle for input, all load weight)
+        {
+            load_input_tile_to_slm(slm_input, 0, local_id,
+                out_row_start, M, K, k_vol,
+                0, 0, in_feats, out_in_map);
+            load_weight_tile_to_slm_wide(slm_weight, 0, local_id,
+                out_col_start, K, N,
+                0, 0, weights);
+        }
+
+        for (int k_iter = 0; k_iter < total_k_iters; k_iter++) {
+            item.barrier(::sycl::access::fence_space::local_space);
+
+            int in_base = cur_buf * SLM_IN_BUF_SIZE;
+            int wt_base = cur_buf * SLM_WT_BUF_SIZE_WIDE;
+
+            int next_buf = 1 - cur_buf;
+            if (k_iter + 1 < total_k_iters) {
+                int next_iter = k_iter + 1;
+                int next_kernel_idx = next_iter * XMX_TILE_K / K_tile_padded;
+                int next_k_offset = (next_iter * XMX_TILE_K) % K_tile_padded;
+
+                load_input_tile_to_slm(slm_input,
+                    next_buf * SLM_IN_BUF_SIZE, local_id,
+                    out_row_start, M, K, k_vol,
+                    next_kernel_idx, next_k_offset, in_feats, out_in_map);
+                load_weight_tile_to_slm_wide(slm_weight,
+                    next_buf * SLM_WT_BUF_SIZE_WIDE, local_id,
+                    out_col_start, K, N,
+                    next_kernel_idx, next_k_offset, weights);
+            }
+
+            // Compute: input tile shared by all 4 SG columns
+            sycl_matrix::joint_matrix_load(sg, sub_a,
+                slm_input.template get_multi_ptr<::sycl::access::decorated::no>()
+                    + in_base + sg_slm_row * SLM_IN_STRIDE,
+                SLM_IN_STRIDE);
+
+            sycl_matrix::joint_matrix_load(sg, sub_b,
+                slm_weight.template get_multi_ptr<::sycl::access::decorated::no>()
+                    + wt_base + sg_slm_col_b,
+                SLM_WT_STRIDE_WIDE);
+
+            sycl_matrix::joint_matrix_mad(sg, sub_c, sub_a, sub_b, sub_c);
+
+            cur_buf = next_buf;
+        }
+    }
+
+store_results_wide:
+    // Store results with fused bias + ReLU
+    constexpr int elements_per_sg = XMX_TM * XMX_TN;
+    float* temp_c = slm_temp.get_multi_ptr<::sycl::access::decorated::no>().get_raw()
+                    + sg_id * elements_per_sg;
+
+    auto temp_c_ptr = ::sycl::address_space_cast<
+        ::sycl::access::address_space::local_space,
+        ::sycl::access::decorated::no>(temp_c);
+    sycl_matrix::joint_matrix_store(sg, sub_c, temp_c_ptr, XMX_TN,
+                                     sycl_matrix::layout::row_major);
+
+    float bias_cache[XMX_TN];
+    if (bias) {
+        for (int j = 0; j < XMX_TN; j++) {
+            int gc = sg_col_start + j;
+            bias_cache[j] = (gc < N) ? static_cast<float>(bias[gc]) : 0.0f;
+        }
+    }
+
+    const int sg_local_id = static_cast<int>(sg.get_local_id()[0]);
+    constexpr int elems_per_thread = elements_per_sg / XMX_SG_SIZE;
+    const int flat_start = sg_local_id * elems_per_thread;
+
+    for (int i = 0; i < elems_per_thread; i++) {
+        int flat = flat_start + i;
+        int row = flat / XMX_TN;
+        int col = flat % XMX_TN;
+        int global_row = sg_row_start + row;
+        int global_col = sg_col_start + col;
+        if (global_row < M && global_col < N) {
+            float val = temp_c[flat];
+            if (bias) val += bias_cache[col];
+            if (apply_relu) val = val > 0.0f ? val : 0.0f;
+            out_feats[global_row * N + global_col] = ::sycl::half(val);
+        }
+    }
+}
+
+/// Launch wide FP16 XMX implicit GEMM (TILE_N=64, 16 SGs, WG=256).
+static void run_implicit_gemm_fp16_xmx_wide(::sycl::queue& q,
+                                              const ::sycl::half* in_feats,
+                                              const ::sycl::half* weights,
+                                              const int32_t* out_in_map,
+                                              ::sycl::half* out_feats,
+                                              int M, int K, int N, int k_vol,
+                                              const ::sycl::half* bias,
+                                              bool apply_relu) {
+    const int num_groups_m = (M + XMX_TILE_M - 1) / XMX_TILE_M;
+    const int num_groups_n = (N + XMX_TILE_N_WIDE - 1) / XMX_TILE_N_WIDE;
+
+    const int slm_input_size = 2 * SLM_IN_BUF_SIZE;
+    const int slm_weight_size = 2 * SLM_WT_BUF_SIZE_WIDE;
+    const int slm_temp_size = XMX_NUM_SG_WIDE * XMX_TM * XMX_TN;
+
+    q.submit([&](::sycl::handler& cgh) {
+        auto slm_in = ::sycl::local_accessor<::sycl::half, 1>(slm_input_size, cgh);
+        auto slm_wt = ::sycl::local_accessor<::sycl::half, 1>(slm_weight_size, cgh);
+        auto slm_tmp = ::sycl::local_accessor<float, 1>(slm_temp_size, cgh);
+
+        cgh.parallel_for(
+            ::sycl::nd_range<2>(
+                ::sycl::range<2>(num_groups_m * XMX_NUM_SG_WIDE,
+                                  num_groups_n * XMX_SG_SIZE),
+                ::sycl::range<2>(XMX_NUM_SG_WIDE, XMX_SG_SIZE)),
+            [=](::sycl::nd_item<2> item) [[sycl::reqd_sub_group_size(16)]] {
+                conv_implicit_gemm_fp16_xmx_kernel_wide(
+                    item, slm_in, slm_wt, slm_tmp,
+                    M, K, N, k_vol,
+                    in_feats, weights, out_in_map, out_feats,
+                    bias, apply_relu);
+            });
+    });
+}
+
+// ===================================================================
+// Stage 2c-int8: INT8 XMX kernels (quant + GEMM + dequant)
+// ===================================================================
+//
+// PTQ path for SparseConvolution: symmetric per-tensor activation + symmetric
+// per-output-channel weight quantization, mirroring the NVIDIA
+// 3DSparseConvolution scheme (see ov_sparse_convolution_int8_optimization.md
+// §17.6 for the cross-reference).
+//
+// Activation scale comes from an online per-frame abs-max reduce (no static
+// PTQ calib scale — LPT keeps the Multiply dequant on the upstream Constant
+// path, so we recompute here to adapt to each frame's voxel distribution).
+// Weight scale is computed once per layer the first time the op executes
+// and cached in `s_int8_weight_cache` keyed by the weight Constant pointer.
+//
+// XMX tile (B580 / PVC int8):
+//   A [TM=8, TK=32]   int8    row-major
+//   B [TK=32, TN=16]  int8    row-major
+//   C [TM=8, TN=16]   int32   accumulator
+// Compared to FP16 XMX (TK=16) we trade half the tile K for 2x throughput.
+
+static constexpr int XMX_I8_TM = 8;
+static constexpr int XMX_I8_TN = 16;
+static constexpr int XMX_I8_TK = 32;  // int8 DPAS doubles K dimension vs FP16
+static constexpr int XMX_I8_TILE_M = XMX_I8_TM * 4;   // 32
+static constexpr int XMX_I8_TILE_N = XMX_I8_TN * 2;   // 32
+static constexpr int XMX_I8_TILE_K = XMX_I8_TK;        // 32
+static constexpr int XMX_I8_NUM_SG = 8;                // 4 rows × 2 cols
+static constexpr int XMX_I8_WG_SIZE = XMX_I8_NUM_SG * XMX_SG_SIZE;  // 128
+static constexpr int XMX_I8_SKEW = 8;                  // SLM bank-conflict skew (int8 elements)
+
+static constexpr int SLM_I8_IN_STRIDE = XMX_I8_TILE_K + XMX_I8_SKEW;   // 40
+static constexpr int SLM_I8_WT_STRIDE = XMX_I8_TILE_N + XMX_I8_SKEW;   // 40
+static constexpr int SLM_I8_IN_BUF_SIZE = XMX_I8_TILE_M * SLM_I8_IN_STRIDE;  // 32×40 = 1280
+static constexpr int SLM_I8_WT_BUF_SIZE = XMX_I8_TILE_K * SLM_I8_WT_STRIDE;  // 32×40 = 1280
+
+// Wide variant for layers with N ≥ 64: TILE_N=64, 16 sub-groups (4×4),
+// WG=256. Same TILE_M=32, TILE_K=32 as the standard kernel, but each
+// input tile is shared by 4 SG columns (vs 2 in standard), halving the
+// number of N-workgroups and the redundant input fetches.
+static constexpr int XMX_I8_TILE_N_WIDE = XMX_I8_TN * 4;                      // 64
+static constexpr int XMX_I8_NUM_SG_WIDE = 16;                                  // 4 rows × 4 cols
+static constexpr int XMX_I8_WG_SIZE_WIDE = XMX_I8_NUM_SG_WIDE * XMX_SG_SIZE;   // 256
+static constexpr int SLM_I8_WT_STRIDE_WIDE = XMX_I8_TILE_N_WIDE + XMX_I8_SKEW; // 72
+static constexpr int SLM_I8_WT_BUF_SIZE_WIDE = XMX_I8_TILE_K * SLM_I8_WT_STRIDE_WIDE;  // 32×72 = 2304
+
+/// Compute abs-max of a flat fp16 tensor via a tree reduction on device.
+/// Writes only `out_scales_device[0] = abs_max` (clamped to >= 1e-8).
+///
+/// The previous variant also populated scales[1]/[2] via a single_task
+/// finalise, but that was an extra kernel launch per SparseConv layer.
+/// Downstream kernels now derive scale / scale_inv on the fly from
+/// `out_scales_device[0]` — cheap arithmetic, bigger async win.
+static void reduce_abs_max_fp16(::sycl::queue& q,
+                                 const ::sycl::half* __restrict__ in,
+                                 float* __restrict__ out_abs_max_device,
+                                 int64_t count) {
+    // Reset and then reduce: we initialise to 0 inside the same submit so the
+    // queue's implicit dependency tracks the initialisation + reduce as a
+    // single logical op relative to the downstream consumer.
+    q.submit([&](::sycl::handler& cgh) {
+        cgh.single_task([=]() { out_abs_max_device[0] = 0.0f; });
+    });
+
+    constexpr int WG = 256;
+    const int64_t num_wgs = (count + WG - 1) / WG;
+    q.submit([&](::sycl::handler& cgh) {
+        auto slm = ::sycl::local_accessor<float, 1>(WG, cgh);
+        cgh.parallel_for(
+            ::sycl::nd_range<1>(::sycl::range<1>(num_wgs * WG), ::sycl::range<1>(WG)),
+            [=](::sycl::nd_item<1> item) {
+                const int lid = static_cast<int>(item.get_local_id(0));
+                const int64_t gid = item.get_global_id(0);
+                float v = 0.0f;
+                if (gid < count) v = ::sycl::fabs(static_cast<float>(in[gid]));
+                slm[lid] = v;
+                item.barrier(::sycl::access::fence_space::local_space);
+                for (int off = WG / 2; off > 0; off >>= 1) {
+                    if (lid < off) slm[lid] = ::sycl::fmax(slm[lid], slm[lid + off]);
+                    item.barrier(::sycl::access::fence_space::local_space);
+                }
+                if (lid == 0) {
+                    ::sycl::atomic_ref<float, ::sycl::memory_order::relaxed,
+                                        ::sycl::memory_scope::device,
+                                        ::sycl::access::address_space::global_space>
+                        ar(out_abs_max_device[0]);
+                    float cur = ar.load();
+                    while (slm[0] > cur && !ar.compare_exchange_weak(cur, slm[0])) {}
+                }
+            });
+    });
+}
+
+/// Quantize a flat fp16 tensor into int8 with symmetric per-tensor scale.
+/// `abs_max_device` is a pointer to the device-side abs_max written by
+/// `reduce_abs_max_fp16`. Each thread reloads it from global and derives
+/// `scale_inv = 127 / max(abs_max, 1e-8)` on the fly — the extra work
+/// per-thread is a single divide, cheaper than launching a separate
+/// single_task kernel to pre-compute scales.
+static void quantize_fp16_to_int8(::sycl::queue& q,
+                                   const ::sycl::half* __restrict__ in,
+                                   int8_t* __restrict__ out,
+                                   int64_t count,
+                                   const float* __restrict__ abs_max_device) {
+    q.parallel_for(::sycl::range<1>(count), [=](::sycl::id<1> i) {
+        float abs_max = abs_max_device[0];
+        if (abs_max < 1e-8f) abs_max = 1e-8f;
+        float scale_inv = 127.0f / abs_max;
+        float v = static_cast<float>(in[i]) * scale_inv;
+        int q_i = static_cast<int>(::sycl::round(v));
+        if (q_i > 127) q_i = 127;
+        if (q_i < -127) q_i = -127;
+        out[i] = static_cast<int8_t>(q_i);
+    });
+}
+
+/// One-time weight quantization: fp16 [k_vol, C_in, C_out] → int8 + per-C_out scales.
+/// Called the first time a given weight Constant pointer is seen; the result
+/// is cached in `s_int8_weight_cache` keyed by the raw weight pointer.
+///
+/// For each output channel `c_out`, scale[c_out] = max|w[:, :, c_out]| / 127.
+/// Weight is stored in the same [k_vol, C_in, C_out] layout, cast to int8.
+static void quantize_fp16_weights_to_int8(::sycl::queue& q,
+                                           const ::sycl::half* __restrict__ weights_f16,
+                                           int8_t* __restrict__ weights_i8,
+                                           float* __restrict__ per_channel_scale_inv,  // 127 / abs_max[c_out]
+                                           float* __restrict__ per_channel_abs_max,     // abs_max[c_out]
+                                           int k_vol, int c_in, int c_out) {
+    // Step 1: per-output-channel abs-max via work-group-per-c_out reduction
+    const int64_t weights_per_col = static_cast<int64_t>(k_vol) * c_in;
+    constexpr int WG = 256;
+    q.submit([&](::sycl::handler& cgh) {
+        auto slm = ::sycl::local_accessor<float, 1>(WG, cgh);
+        cgh.parallel_for(
+            ::sycl::nd_range<1>(::sycl::range<1>(c_out * WG), ::sycl::range<1>(WG)),
+            [=](::sycl::nd_item<1> item) {
+                const int c_out_id = static_cast<int>(item.get_group(0));
+                const int lid = static_cast<int>(item.get_local_id(0));
+                float local_max = 0.0f;
+                // Stride through [k_vol * c_in] elements, stepping by WG
+                for (int64_t t = lid; t < weights_per_col; t += WG) {
+                    // weights[t * c_out + c_out_id] — t iterates over (k_vol * c_in)
+                    float v = ::sycl::fabs(static_cast<float>(weights_f16[t * c_out + c_out_id]));
+                    if (v > local_max) local_max = v;
+                }
+                slm[lid] = local_max;
+                item.barrier(::sycl::access::fence_space::local_space);
+                for (int off = WG / 2; off > 0; off >>= 1) {
+                    if (lid < off) slm[lid] = ::sycl::fmax(slm[lid], slm[lid + off]);
+                    item.barrier(::sycl::access::fence_space::local_space);
+                }
+                if (lid == 0) {
+                    float abs_max = slm[0];
+                    if (abs_max < 1e-8f) abs_max = 1e-8f;  // Avoid div-by-zero for all-zero channels
+                    per_channel_abs_max[c_out_id] = abs_max;
+                    per_channel_scale_inv[c_out_id] = 127.0f / abs_max;
+                }
+            });
+    });
+
+    // Step 2: quantize weights using per-C_out scale_inv
+    const int64_t total = static_cast<int64_t>(k_vol) * c_in * c_out;
+    q.parallel_for(::sycl::range<1>(total), [=](::sycl::id<1> idx) {
+        int64_t i = idx[0];
+        int c_out_id = static_cast<int>(i % c_out);
+        float v = static_cast<float>(weights_f16[i]) * per_channel_scale_inv[c_out_id];
+        int q_i = static_cast<int>(::sycl::round(v));
+        if (q_i > 127) q_i = 127;
+        if (q_i < -127) q_i = -127;
+        weights_i8[i] = static_cast<int8_t>(q_i);
+    });
+}
+
+/// Load int8 input tile [TILE_M × TILE_K] into SLM via out_in_map.
+/// 128 threads load 32 rows × 32 cols = 1024 elements → 8 elements/thread.
+/// Each thread writes 8 contiguous columns of one row (row-based assignment
+/// → one `out_in_map` lookup per 4 threads, vectorised global load).
+static inline void load_int8_input_tile_to_slm(
+    ::sycl::local_accessor<int8_t, 1>& slm_input,
+    int slm_base,
+    int local_id,
+    int out_row_start,
+    int M, int K, int k_vol,
+    int kernel_idx, int k_offset_in_kernel,
+    const int8_t* __restrict__ in_feats,
+    const int32_t* __restrict__ out_in_map)
+{
+    // Row-based assignment: 128 threads × 8 elements = 1024 = TILE_M(32) × TILE_K(32).
+    // 4 threads cover one row; each does 8 cols. Lookup `map_idx` once per row
+    // (4 threads share the same assigned_row, but redundant loads are cheap).
+    const int assigned_row = local_id / 4;
+    const int col_start = (local_id % 4) * 8;  // 0, 8, 16, 24
+
+    if (assigned_row < XMX_I8_TILE_M) {
+        const int global_row = out_row_start + assigned_row;
+        const int slm_row_base = slm_base + assigned_row * SLM_I8_IN_STRIDE;
+
+        int map_idx = -1;
+        if (global_row < M) {
+            map_idx = out_in_map[global_row * k_vol + kernel_idx];
+        }
+
+        // Vectorised path: try to do one vec<int8_t,8> global load + 8 SLM stores.
+        const int k_start = k_offset_in_kernel + col_start;
+        if (map_idx >= 0 && col_start + 8 <= XMX_I8_TILE_K && k_start + 8 <= K) {
+            using char8 = ::sycl::vec<int8_t, 8>;
+            const int8_t* src = in_feats + map_idx * K + k_start;
+            char8 v;
+            v.load(0, ::sycl::address_space_cast<
+                ::sycl::access::address_space::global_space,
+                ::sycl::access::decorated::no>(src));
+            for (int j = 0; j < 8; j++) {
+                slm_input[slm_row_base + col_start + j] = v[j];
+            }
+        } else {
+            // Scalar fallback for partial tiles / out-of-bounds rows.
+            for (int j = 0; j < 8; j++) {
+                int col = col_start + j;
+                int8_t val = 0;
+                if (col < XMX_I8_TILE_K) {
+                    int k_idx = k_offset_in_kernel + col;
+                    if (map_idx >= 0 && k_idx < K)
+                        val = in_feats[map_idx * K + k_idx];
+                }
+                slm_input[slm_row_base + col] = val;
+            }
+        }
+    }
+}
+
+/// Load int8 weight tile [TILE_K × TILE_N] into SLM.
+/// 128 threads load 32 × 32 = 1024 elements → 8 elements/thread linearly.
+/// Each thread loads 8 contiguous N-elements of one K-row via vec<int8_t,8>
+/// (weights are contiguous in N, so 8-wide global loads are the natural path).
+static inline void load_int8_weight_tile_to_slm(
+    ::sycl::local_accessor<int8_t, 1>& slm_weight,
+    int slm_base,
+    int local_id,
+    int out_col_start,
+    int K, int N,
+    int kernel_idx, int k_offset_in_kernel,
+    const int8_t* __restrict__ weights)
+{
+    // 128 threads × (4 k_rows × 8 n_cols) = 4096? No — 128 × 8 = 1024 = 32×32 ✓
+    // Thread layout: per K-row use 4 threads, each covers 8 N-cols.
+    const int k_row  = local_id / 4;
+    const int n_base = (local_id % 4) * 8;  // 0, 8, 16, 24
+
+    if (k_row < XMX_I8_TILE_K) {
+        const int global_k = k_offset_in_kernel + k_row;
+        const int global_n = out_col_start + n_base;
+        int8_t* slm_ptr = &slm_weight[slm_base + k_row * SLM_I8_WT_STRIDE + n_base];
+
+        if (global_k < K && global_n + 8 <= N && n_base + 8 <= XMX_I8_TILE_N) {
+            using char8 = ::sycl::vec<int8_t, 8>;
+            const int8_t* src = weights + kernel_idx * K * N + global_k * N + global_n;
+            char8 v;
+            v.load(0, ::sycl::address_space_cast<
+                ::sycl::access::address_space::global_space,
+                ::sycl::access::decorated::no>(src));
+            for (int j = 0; j < 8; j++) slm_ptr[j] = v[j];
+        } else {
+            for (int j = 0; j < 8; j++) {
+                int n_idx = n_base + j;
+                int8_t val = 0;
+                if (global_k < K && n_idx < XMX_I8_TILE_N &&
+                    out_col_start + n_idx < N) {
+                    val = weights[kernel_idx * K * N + global_k * N
+                                  + out_col_start + n_idx];
+                }
+                slm_ptr[j] = val;
+            }
+        }
+    }
+}
+
+/// INT8 XMX implicit GEMM kernel with double-buffered SLM.
+///
+/// Tile layout: TILE_M=32, TILE_N=32, TILE_K=32, WG=128 (8 sub-groups).
+/// Each sub-group computes one TM×TN = 8×16 output fragment via
+/// joint_matrix_mad<int8, int8, int32>.
+///
+/// Follows the same double-buffer pattern as the FP16 XMX kernel:
+///   - SLM holds two copies of the input (2×SLM_I8_IN_BUF_SIZE) and weight
+///     (2×SLM_I8_WT_BUF_SIZE) tiles.
+///   - Before the main loop, prefetch tile 0 into buffer 0.
+///   - Each iteration: barrier to make `cur_buf` visible, then issue the
+///     next load into `next_buf` and compute from `cur_buf` in parallel.
+///     The load and compute hit disjoint SLM regions, so the scheduler
+///     can overlap them.
+///
+/// Dequantization is fused into the store phase — each thread dequantises
+/// the int32 accumulator to fp16 using the per-tensor act_scale and the
+/// per-output-channel weight scale as it writes the output. That avoids a
+/// separate dequant kernel with its own global round-trip.
+template <bool kEmitI8Out>
+static void conv_implicit_gemm_int8_xmx_kernel(
+    ::sycl::nd_item<2> item,
+    ::sycl::local_accessor<int8_t, 1> slm_input,
+    ::sycl::local_accessor<int8_t, 1> slm_weight,
+    ::sycl::local_accessor<int32_t, 1> slm_temp,
+    int M, int K, int N, int k_vol,
+    const int8_t* __restrict__ in_feats,
+    const int8_t* __restrict__ weights,
+    const int32_t* __restrict__ out_in_map,
+    ::sycl::half* __restrict__ out_feats,
+    const float*  __restrict__ act_scale_device,
+    const float*  __restrict__ per_channel_weight_scale,
+    const ::sycl::half* __restrict__ bias,  // nullptr if no bias
+    bool apply_relu,
+    // Path 1 (only used when kEmitI8Out=true): int8 output buffer +
+    // precomputed scale_inv. Compile-time switch so the non-handoff
+    // kernel variant doesn't carry these around in live registers.
+    int8_t* __restrict__ out_feats_i8,
+    float out_scale_inv_127)
+{
+    auto sg = item.get_sub_group();
+    const int sg_id = sg.get_group_linear_id();
+    const int local_id = item.get_local_linear_id();
+
+    const int group_id_m = item.get_group(0);
+    const int group_id_n = item.get_group(1);
+
+    const int out_row_start = group_id_m * XMX_I8_TILE_M;
+    const int out_col_start = group_id_n * XMX_I8_TILE_N;
+
+    // 8 sub-groups: 4 rows × 2 cols
+    const int sg_row_start = out_row_start + (sg_id / 2) * XMX_I8_TM;
+    const int sg_col_start = out_col_start + (sg_id % 2) * XMX_I8_TN;
+
+    sycl_matrix::joint_matrix<::sycl::sub_group, int8_t,
+                              sycl_matrix::use::a,
+                              XMX_I8_TM, XMX_I8_TK,
+                              sycl_matrix::layout::row_major> sub_a;
+    sycl_matrix::joint_matrix<::sycl::sub_group, int8_t,
+                              sycl_matrix::use::b,
+                              XMX_I8_TK, XMX_I8_TN,
+                              sycl_matrix::layout::row_major> sub_b;
+    sycl_matrix::joint_matrix<::sycl::sub_group, int32_t,
+                              sycl_matrix::use::accumulator,
+                              XMX_I8_TM, XMX_I8_TN> sub_c;
+
+    sycl_matrix::joint_matrix_fill(sg, sub_c, 0);
+
+    const int K_tile_padded = ((K + XMX_I8_TILE_K - 1) / XMX_I8_TILE_K) * XMX_I8_TILE_K;
+    const int K_implicit = K_tile_padded * k_vol;
+    const int total_k_iters = K_implicit / XMX_I8_TILE_K;
+
+    const int sg_slm_row = (sg_id / 2) * XMX_I8_TM;
+    const int sg_slm_col_b = (sg_id % 2) * XMX_I8_TN;
+
+    if (total_k_iters > 0) {
+        // Double-buffered main loop:
+        //   buf 0: SLM offset 0
+        //   buf 1: SLM offset SLM_I8_IN_BUF_SIZE / SLM_I8_WT_BUF_SIZE
+        int cur_buf = 0;
+
+        // Prefetch the first tile into buf 0
+        {
+            load_int8_input_tile_to_slm(slm_input, 0, local_id,
+                out_row_start, M, K, k_vol,
+                /*kernel_idx=*/0, /*k_offset=*/0, in_feats, out_in_map);
+            load_int8_weight_tile_to_slm(slm_weight, 0, local_id,
+                out_col_start, K, N,
+                /*kernel_idx=*/0, /*k_offset=*/0, weights);
+        }
+
+        for (int k_iter = 0; k_iter < total_k_iters; k_iter++) {
+            // Wait until the current buffer has been written.
+            item.barrier(::sycl::access::fence_space::local_space);
+
+            const int in_base = cur_buf * SLM_I8_IN_BUF_SIZE;
+            const int wt_base = cur_buf * SLM_I8_WT_BUF_SIZE;
+
+            // Start loading the next tile into the OTHER buffer while we
+            // compute from `cur_buf`. The two regions are disjoint, so the
+            // hardware scheduler can overlap the load with the MAD.
+            const int next_buf = 1 - cur_buf;
+            if (k_iter + 1 < total_k_iters) {
+                const int next_iter = k_iter + 1;
+                const int next_kernel_idx = next_iter * XMX_I8_TILE_K / K_tile_padded;
+                const int next_k_offset   = (next_iter * XMX_I8_TILE_K) % K_tile_padded;
+                load_int8_input_tile_to_slm(slm_input,
+                    next_buf * SLM_I8_IN_BUF_SIZE, local_id,
+                    out_row_start, M, K, k_vol,
+                    next_kernel_idx, next_k_offset, in_feats, out_in_map);
+                load_int8_weight_tile_to_slm(slm_weight,
+                    next_buf * SLM_I8_WT_BUF_SIZE, local_id,
+                    out_col_start, K, N,
+                    next_kernel_idx, next_k_offset, weights);
+            }
+
+            sycl_matrix::joint_matrix_load(sg, sub_a,
+                slm_input.template get_multi_ptr<::sycl::access::decorated::no>()
+                    + in_base + sg_slm_row * SLM_I8_IN_STRIDE,
+                SLM_I8_IN_STRIDE);
+
+            sycl_matrix::joint_matrix_load(sg, sub_b,
+                slm_weight.template get_multi_ptr<::sycl::access::decorated::no>()
+                    + wt_base + sg_slm_col_b,
+                SLM_I8_WT_STRIDE);
+
+            sycl_matrix::joint_matrix_mad(sg, sub_c, sub_a, sub_b, sub_c);
+
+            cur_buf = next_buf;
+        }
+    }
+
+    // Store-phase: dequantise int32 accumulator to fp16 with fused per-channel
+    // weight scale + per-tensor activation scale + optional bias + optional ReLU.
+    // Each thread handles elems_per_sg/SG_SIZE = 8 output elements; bias and
+    // per-channel weight scale are cached in registers per sub-group's column
+    // range to amortise the C_out indexing across the 8 elements.
+    constexpr int elements_per_sg = XMX_I8_TM * XMX_I8_TN;
+    int32_t* temp_c = slm_temp.get_multi_ptr<::sycl::access::decorated::no>().get_raw()
+                       + sg_id * elements_per_sg;
+    auto temp_c_ptr = ::sycl::address_space_cast<
+        ::sycl::access::address_space::local_space,
+        ::sycl::access::decorated::no>(temp_c);
+    sycl_matrix::joint_matrix_store(sg, sub_c, temp_c_ptr, XMX_I8_TN,
+                                     sycl_matrix::layout::row_major);
+
+    // Derive act_scale = abs_max / 127 on the fly (saves a single_task
+    // finalise kernel in the reduce path). Clamp matches the quantize kernel.
+    float act_abs_max_local = act_scale_device[0];
+    if (act_abs_max_local < 1e-8f) act_abs_max_local = 1e-8f;
+    const float act_scale = act_abs_max_local / 127.0f;
+
+    // Preload bias + weight_scale for this sub-group's column range.
+    float bias_cache[XMX_I8_TN];
+    float wscale_cache[XMX_I8_TN];
+    for (int j = 0; j < XMX_I8_TN; j++) {
+        int gc = sg_col_start + j;
+        wscale_cache[j] = (gc < N) ? per_channel_weight_scale[gc] : 0.0f;
+        bias_cache[j]   = (gc < N && bias) ? static_cast<float>(bias[gc]) : 0.0f;
+    }
+
+    const int sg_local_id = static_cast<int>(sg.get_local_id()[0]);
+    constexpr int elems_per_thread = elements_per_sg / XMX_SG_SIZE;  // 128/16 = 8
+    const int flat_start = sg_local_id * elems_per_thread;
+
+    for (int i = 0; i < elems_per_thread; i++) {
+        int flat = flat_start + i;
+        int row = flat / XMX_I8_TN;
+        int col = flat % XMX_I8_TN;
+        int global_row = sg_row_start + row;
+        int global_col = sg_col_start + col;
+        if (global_row < M && global_col < N) {
+            float val = static_cast<float>(temp_c[flat]) * act_scale * wscale_cache[col];
+            if (bias) val += bias_cache[col];
+            if (apply_relu) val = val > 0.0f ? val : 0.0f;
+            const int64_t out_idx = static_cast<int64_t>(global_row) * N + global_col;
+            out_feats[out_idx] = ::sycl::half(val);
+            if constexpr (kEmitI8Out) {
+                // Path 1 int8 handoff write — compiled out when kEmitI8Out=false.
+                float qv = val * out_scale_inv_127;
+                int qi = static_cast<int>(::sycl::round(qv));
+                if (qi > 127) qi = 127;
+                if (qi < -127) qi = -127;
+                out_feats_i8[out_idx] = static_cast<int8_t>(qi);
+            }
+        }
+    }
+}
+
+/// Launch the INT8 XMX implicit GEMM with fused dequantisation + bias + ReLU
+/// in the store phase. Writes fp16 directly to `out_feats` — no separate
+/// dequant kernel needed.
+static void run_implicit_gemm_int8_xmx(::sycl::queue& q,
+                                        const int8_t* in_feats,
+                                        const int8_t* weights,
+                                        const int32_t* out_in_map,
+                                        ::sycl::half* out_feats,
+                                        const float* act_scale_device,
+                                        const float* per_channel_weight_scale,
+                                        const ::sycl::half* bias,
+                                        bool apply_relu,
+                                        int M, int K, int N, int k_vol,
+                                        int8_t* out_feats_i8 = nullptr,
+                                        float out_scale_inv_127 = 0.0f) {
+    const int num_groups_m = (M + XMX_I8_TILE_M - 1) / XMX_I8_TILE_M;
+    const int num_groups_n = (N + XMX_I8_TILE_N - 1) / XMX_I8_TILE_N;
+
+    // Double-buffered SLM: 2 copies of input + 2 copies of weight buffers
+    const int slm_input_size  = 2 * SLM_I8_IN_BUF_SIZE;
+    const int slm_weight_size = 2 * SLM_I8_WT_BUF_SIZE;
+    const int slm_temp_size   = XMX_I8_NUM_SG * XMX_I8_TM * XMX_I8_TN;
+
+    if (out_feats_i8 != nullptr) {
+        q.submit([&](::sycl::handler& cgh) {
+            auto slm_in = ::sycl::local_accessor<int8_t, 1>(slm_input_size, cgh);
+            auto slm_wt = ::sycl::local_accessor<int8_t, 1>(slm_weight_size, cgh);
+            auto slm_tmp = ::sycl::local_accessor<int32_t, 1>(slm_temp_size, cgh);
+            cgh.parallel_for(
+                ::sycl::nd_range<2>(
+                    ::sycl::range<2>(num_groups_m * XMX_I8_NUM_SG,
+                                      num_groups_n * XMX_SG_SIZE),
+                    ::sycl::range<2>(XMX_I8_NUM_SG, XMX_SG_SIZE)),
+                [=](::sycl::nd_item<2> item) [[sycl::reqd_sub_group_size(16)]] {
+                    conv_implicit_gemm_int8_xmx_kernel<true>(
+                        item, slm_in, slm_wt, slm_tmp,
+                        M, K, N, k_vol,
+                        in_feats, weights, out_in_map,
+                        out_feats, act_scale_device, per_channel_weight_scale,
+                        bias, apply_relu,
+                        out_feats_i8, out_scale_inv_127);
+                });
+        });
+    } else {
+        q.submit([&](::sycl::handler& cgh) {
+            auto slm_in = ::sycl::local_accessor<int8_t, 1>(slm_input_size, cgh);
+            auto slm_wt = ::sycl::local_accessor<int8_t, 1>(slm_weight_size, cgh);
+            auto slm_tmp = ::sycl::local_accessor<int32_t, 1>(slm_temp_size, cgh);
+            cgh.parallel_for(
+                ::sycl::nd_range<2>(
+                    ::sycl::range<2>(num_groups_m * XMX_I8_NUM_SG,
+                                      num_groups_n * XMX_SG_SIZE),
+                    ::sycl::range<2>(XMX_I8_NUM_SG, XMX_SG_SIZE)),
+                [=](::sycl::nd_item<2> item) [[sycl::reqd_sub_group_size(16)]] {
+                    conv_implicit_gemm_int8_xmx_kernel<false>(
+                        item, slm_in, slm_wt, slm_tmp,
+                        M, K, N, k_vol,
+                        in_feats, weights, out_in_map,
+                        out_feats, act_scale_device, per_channel_weight_scale,
+                        bias, apply_relu,
+                        nullptr, 0.0f);
+                });
+        });
+    }
+}
+
+// -------------------------------------------------------------------
+// INT8 XMX wide variant: TILE_N=64, 16 sub-groups, WG=256
+// For layers with c_out >= 64. Same input tile (TILE_M=32, TILE_K=32)
+// but a 2x wider weight tile shared across 4 SG columns, halving the
+// number of N-workgroups and the redundant input SLM loads.
+// -------------------------------------------------------------------
+
+/// Load int8 weight tile [TILE_K × TILE_N_WIDE=64] into SLM.
+/// 256 threads × 8 cols = 2048 = 32×64 ✓
+static inline void load_int8_weight_tile_to_slm_wide(
+    ::sycl::local_accessor<int8_t, 1>& slm_weight,
+    int slm_base,
+    int local_id,
+    int out_col_start,
+    int K, int N,
+    int kernel_idx, int k_offset_in_kernel,
+    const int8_t* __restrict__ weights)
+{
+    // Thread layout: per K-row use 8 threads (wide TILE_N=64 / 8 cols each).
+    const int k_row  = local_id / 8;
+    const int n_base = (local_id % 8) * 8;  // 0,8,16,24,32,40,48,56
+
+    if (k_row < XMX_I8_TILE_K) {
+        const int global_k = k_offset_in_kernel + k_row;
+        const int global_n = out_col_start + n_base;
+        int8_t* slm_ptr = &slm_weight[slm_base + k_row * SLM_I8_WT_STRIDE_WIDE + n_base];
+
+        if (global_k < K && global_n + 8 <= N && n_base + 8 <= XMX_I8_TILE_N_WIDE) {
+            using char8 = ::sycl::vec<int8_t, 8>;
+            const int8_t* src = weights + kernel_idx * K * N + global_k * N + global_n;
+            char8 v;
+            v.load(0, ::sycl::address_space_cast<
+                ::sycl::access::address_space::global_space,
+                ::sycl::access::decorated::no>(src));
+            for (int j = 0; j < 8; j++) slm_ptr[j] = v[j];
+        } else {
+            for (int j = 0; j < 8; j++) {
+                int n_idx = n_base + j;
+                int8_t val = 0;
+                if (global_k < K && n_idx < XMX_I8_TILE_N_WIDE &&
+                    out_col_start + n_idx < N) {
+                    val = weights[kernel_idx * K * N + global_k * N
+                                  + out_col_start + n_idx];
+                }
+                slm_ptr[j] = val;
+            }
+        }
+    }
+}
+
+/// Load int8 input tile [TILE_M=32 × TILE_K=32] into SLM — wide-kernel variant.
+/// Same tile size as standard, but with 256 threads we have 2× the bandwidth:
+/// 256 × 4 elements = 1024 = 32×32 ✓. Thread layout:
+///   thread = row_idx * 8 + col_idx_8   (row 0..31, col_idx_8 0..7)
+/// Each thread writes 4 contiguous cols; 8 threads cover a full row.
+static inline void load_int8_input_tile_to_slm_wide(
+    ::sycl::local_accessor<int8_t, 1>& slm_input,
+    int slm_base,
+    int local_id,
+    int out_row_start,
+    int M, int K, int k_vol,
+    int kernel_idx, int k_offset_in_kernel,
+    const int8_t* __restrict__ in_feats,
+    const int32_t* __restrict__ out_in_map)
+{
+    const int assigned_row = local_id / 8;
+    const int col_start    = (local_id % 8) * 4;  // 0,4,8,12,16,20,24,28
+
+    if (assigned_row < XMX_I8_TILE_M) {
+        const int global_row  = out_row_start + assigned_row;
+        const int slm_row_base = slm_base + assigned_row * SLM_I8_IN_STRIDE;
+
+        int map_idx = -1;
+        if (global_row < M) {
+            map_idx = out_in_map[global_row * k_vol + kernel_idx];
+        }
+
+        const int k_start = k_offset_in_kernel + col_start;
+        if (map_idx >= 0 && col_start + 4 <= XMX_I8_TILE_K && k_start + 4 <= K) {
+            using char4 = ::sycl::vec<int8_t, 4>;
+            const int8_t* src = in_feats + map_idx * K + k_start;
+            char4 v;
+            v.load(0, ::sycl::address_space_cast<
+                ::sycl::access::address_space::global_space,
+                ::sycl::access::decorated::no>(src));
+            for (int j = 0; j < 4; j++) {
+                slm_input[slm_row_base + col_start + j] = v[j];
+            }
+        } else {
+            for (int j = 0; j < 4; j++) {
+                int col = col_start + j;
+                int8_t val = 0;
+                if (col < XMX_I8_TILE_K) {
+                    int k_idx = k_offset_in_kernel + col;
+                    if (map_idx >= 0 && k_idx < K)
+                        val = in_feats[map_idx * K + k_idx];
+                }
+                slm_input[slm_row_base + col] = val;
+            }
+        }
+    }
+}
+
+/// INT8 XMX wide implicit GEMM. TILE_N=64, 16 SGs (4 rows × 4 cols).
+/// Same double-buffering as standard; weight tile is 2x wider.
+/// Dequantisation + bias + ReLU fused into the store phase.
+template <bool kEmitI8Out>
+static void conv_implicit_gemm_int8_xmx_kernel_wide(
+    ::sycl::nd_item<2> item,
+    ::sycl::local_accessor<int8_t, 1> slm_input,
+    ::sycl::local_accessor<int8_t, 1> slm_weight,
+    ::sycl::local_accessor<int32_t, 1> slm_temp,
+    int M, int K, int N, int k_vol,
+    const int8_t* __restrict__ in_feats,
+    const int8_t* __restrict__ weights,
+    const int32_t* __restrict__ out_in_map,
+    ::sycl::half* __restrict__ out_feats,
+    const float*  __restrict__ act_scale_device,
+    const float*  __restrict__ per_channel_weight_scale,
+    const ::sycl::half* __restrict__ bias,
+    bool apply_relu,
+    int8_t* __restrict__ out_feats_i8,
+    float out_scale_inv_127)
+{
+    auto sg = item.get_sub_group();
+    const int sg_id = sg.get_group_linear_id();
+    const int local_id = item.get_local_linear_id();
+
+    const int group_id_m = item.get_group(0);
+    const int group_id_n = item.get_group(1);
+
+    const int out_row_start = group_id_m * XMX_I8_TILE_M;
+    const int out_col_start = group_id_n * XMX_I8_TILE_N_WIDE;
+
+    // 16 sub-groups: 4 rows × 4 cols
+    const int sg_row_start = out_row_start + (sg_id / 4) * XMX_I8_TM;
+    const int sg_col_start = out_col_start + (sg_id % 4) * XMX_I8_TN;
+
+    sycl_matrix::joint_matrix<::sycl::sub_group, int8_t,
+                              sycl_matrix::use::a,
+                              XMX_I8_TM, XMX_I8_TK,
+                              sycl_matrix::layout::row_major> sub_a;
+    sycl_matrix::joint_matrix<::sycl::sub_group, int8_t,
+                              sycl_matrix::use::b,
+                              XMX_I8_TK, XMX_I8_TN,
+                              sycl_matrix::layout::row_major> sub_b;
+    sycl_matrix::joint_matrix<::sycl::sub_group, int32_t,
+                              sycl_matrix::use::accumulator,
+                              XMX_I8_TM, XMX_I8_TN> sub_c;
+
+    sycl_matrix::joint_matrix_fill(sg, sub_c, 0);
+
+    const int K_tile_padded = ((K + XMX_I8_TILE_K - 1) / XMX_I8_TILE_K) * XMX_I8_TILE_K;
+    const int K_implicit = K_tile_padded * k_vol;
+    const int total_k_iters = K_implicit / XMX_I8_TILE_K;
+
+    const int sg_slm_row     = (sg_id / 4) * XMX_I8_TM;
+    const int sg_slm_col_b_w = (sg_id % 4) * XMX_I8_TN;
+
+    if (total_k_iters > 0) {
+        int cur_buf = 0;
+
+        load_int8_input_tile_to_slm_wide(slm_input, 0, local_id,
+            out_row_start, M, K, k_vol,
+            0, 0, in_feats, out_in_map);
+        load_int8_weight_tile_to_slm_wide(slm_weight, 0, local_id,
+            out_col_start, K, N,
+            0, 0, weights);
+
+        for (int k_iter = 0; k_iter < total_k_iters; k_iter++) {
+            item.barrier(::sycl::access::fence_space::local_space);
+
+            const int in_base = cur_buf * SLM_I8_IN_BUF_SIZE;
+            const int wt_base = cur_buf * SLM_I8_WT_BUF_SIZE_WIDE;
+
+            const int next_buf = 1 - cur_buf;
+            if (k_iter + 1 < total_k_iters) {
+                const int next_iter = k_iter + 1;
+                const int next_kernel_idx = next_iter * XMX_I8_TILE_K / K_tile_padded;
+                const int next_k_offset   = (next_iter * XMX_I8_TILE_K) % K_tile_padded;
+                load_int8_input_tile_to_slm_wide(slm_input,
+                    next_buf * SLM_I8_IN_BUF_SIZE, local_id,
+                    out_row_start, M, K, k_vol,
+                    next_kernel_idx, next_k_offset, in_feats, out_in_map);
+                load_int8_weight_tile_to_slm_wide(slm_weight,
+                    next_buf * SLM_I8_WT_BUF_SIZE_WIDE, local_id,
+                    out_col_start, K, N,
+                    next_kernel_idx, next_k_offset, weights);
+            }
+
+            sycl_matrix::joint_matrix_load(sg, sub_a,
+                slm_input.template get_multi_ptr<::sycl::access::decorated::no>()
+                    + in_base + sg_slm_row * SLM_I8_IN_STRIDE,
+                SLM_I8_IN_STRIDE);
+
+            sycl_matrix::joint_matrix_load(sg, sub_b,
+                slm_weight.template get_multi_ptr<::sycl::access::decorated::no>()
+                    + wt_base + sg_slm_col_b_w,
+                SLM_I8_WT_STRIDE_WIDE);
+
+            sycl_matrix::joint_matrix_mad(sg, sub_c, sub_a, sub_b, sub_c);
+
+            cur_buf = next_buf;
+        }
+    }
+
+    // Store-phase with fused dequant + bias + ReLU (same as standard kernel).
+    constexpr int elements_per_sg = XMX_I8_TM * XMX_I8_TN;
+    int32_t* temp_c = slm_temp.get_multi_ptr<::sycl::access::decorated::no>().get_raw()
+                       + sg_id * elements_per_sg;
+    auto temp_c_ptr = ::sycl::address_space_cast<
+        ::sycl::access::address_space::local_space,
+        ::sycl::access::decorated::no>(temp_c);
+    sycl_matrix::joint_matrix_store(sg, sub_c, temp_c_ptr, XMX_I8_TN,
+                                     sycl_matrix::layout::row_major);
+
+    // Derive act_scale = abs_max / 127 on the fly (saves a single_task
+    // finalise kernel in the reduce path). Clamp matches the quantize kernel.
+    float act_abs_max_local = act_scale_device[0];
+    if (act_abs_max_local < 1e-8f) act_abs_max_local = 1e-8f;
+    const float act_scale = act_abs_max_local / 127.0f;
+
+    float bias_cache[XMX_I8_TN];
+    float wscale_cache[XMX_I8_TN];
+    for (int j = 0; j < XMX_I8_TN; j++) {
+        int gc = sg_col_start + j;
+        wscale_cache[j] = (gc < N) ? per_channel_weight_scale[gc] : 0.0f;
+        bias_cache[j]   = (gc < N && bias) ? static_cast<float>(bias[gc]) : 0.0f;
+    }
+
+    const int sg_local_id = static_cast<int>(sg.get_local_id()[0]);
+    constexpr int elems_per_thread = elements_per_sg / XMX_SG_SIZE;  // 128/16 = 8
+    const int flat_start = sg_local_id * elems_per_thread;
+
+    for (int i = 0; i < elems_per_thread; i++) {
+        int flat = flat_start + i;
+        int row = flat / XMX_I8_TN;
+        int col = flat % XMX_I8_TN;
+        int global_row = sg_row_start + row;
+        int global_col = sg_col_start + col;
+        if (global_row < M && global_col < N) {
+            float val = static_cast<float>(temp_c[flat]) * act_scale * wscale_cache[col];
+            if (bias) val += bias_cache[col];
+            if (apply_relu) val = val > 0.0f ? val : 0.0f;
+            const int64_t out_idx = static_cast<int64_t>(global_row) * N + global_col;
+            out_feats[out_idx] = ::sycl::half(val);
+            if constexpr (kEmitI8Out) {
+                float qv = val * out_scale_inv_127;
+                int qi = static_cast<int>(::sycl::round(qv));
+                if (qi > 127) qi = 127;
+                if (qi < -127) qi = -127;
+                out_feats_i8[out_idx] = static_cast<int8_t>(qi);
+            }
+        }
+    }
+}
+
+/// Launch the wide INT8 XMX implicit GEMM (TILE_N=64, 16 SGs, WG=256) with
+/// fused dequantisation + bias + ReLU in the store phase.
+static void run_implicit_gemm_int8_xmx_wide(::sycl::queue& q,
+                                             const int8_t* in_feats,
+                                             const int8_t* weights,
+                                             const int32_t* out_in_map,
+                                             ::sycl::half* out_feats,
+                                             const float* act_scale_device,
+                                             const float* per_channel_weight_scale,
+                                             const ::sycl::half* bias,
+                                             bool apply_relu,
+                                             int M, int K, int N, int k_vol,
+                                             int8_t* out_feats_i8 = nullptr,
+                                             float out_scale_inv_127 = 0.0f) {
+    const int num_groups_m = (M + XMX_I8_TILE_M - 1) / XMX_I8_TILE_M;
+    const int num_groups_n = (N + XMX_I8_TILE_N_WIDE - 1) / XMX_I8_TILE_N_WIDE;
+
+    const int slm_input_size  = 2 * SLM_I8_IN_BUF_SIZE;
+    const int slm_weight_size = 2 * SLM_I8_WT_BUF_SIZE_WIDE;
+    const int slm_temp_size   = XMX_I8_NUM_SG_WIDE * XMX_I8_TM * XMX_I8_TN;
+
+    if (out_feats_i8 != nullptr) {
+        q.submit([&](::sycl::handler& cgh) {
+            auto slm_in  = ::sycl::local_accessor<int8_t, 1>(slm_input_size, cgh);
+            auto slm_wt  = ::sycl::local_accessor<int8_t, 1>(slm_weight_size, cgh);
+            auto slm_tmp = ::sycl::local_accessor<int32_t, 1>(slm_temp_size, cgh);
+            cgh.parallel_for(
+                ::sycl::nd_range<2>(
+                    ::sycl::range<2>(num_groups_m * XMX_I8_NUM_SG_WIDE,
+                                      num_groups_n * XMX_SG_SIZE),
+                    ::sycl::range<2>(XMX_I8_NUM_SG_WIDE, XMX_SG_SIZE)),
+                [=](::sycl::nd_item<2> item) [[sycl::reqd_sub_group_size(16)]] {
+                    conv_implicit_gemm_int8_xmx_kernel_wide<true>(
+                        item, slm_in, slm_wt, slm_tmp,
+                        M, K, N, k_vol,
+                        in_feats, weights, out_in_map,
+                        out_feats, act_scale_device, per_channel_weight_scale,
+                        bias, apply_relu,
+                        out_feats_i8, out_scale_inv_127);
+                });
+        });
+    } else {
+        q.submit([&](::sycl::handler& cgh) {
+            auto slm_in  = ::sycl::local_accessor<int8_t, 1>(slm_input_size, cgh);
+            auto slm_wt  = ::sycl::local_accessor<int8_t, 1>(slm_weight_size, cgh);
+            auto slm_tmp = ::sycl::local_accessor<int32_t, 1>(slm_temp_size, cgh);
+            cgh.parallel_for(
+                ::sycl::nd_range<2>(
+                    ::sycl::range<2>(num_groups_m * XMX_I8_NUM_SG_WIDE,
+                                      num_groups_n * XMX_SG_SIZE),
+                    ::sycl::range<2>(XMX_I8_NUM_SG_WIDE, XMX_SG_SIZE)),
+                [=](::sycl::nd_item<2> item) [[sycl::reqd_sub_group_size(16)]] {
+                    conv_implicit_gemm_int8_xmx_kernel_wide<false>(
+                        item, slm_in, slm_wt, slm_tmp,
+                        M, K, N, k_vol,
+                        in_feats, weights, out_in_map,
+                        out_feats, act_scale_device, per_channel_weight_scale,
+                        bias, apply_relu,
+                        nullptr, 0.0f);
+                });
+        });
+    }
+}
+
+
+/// Dequantize int32 accumulator to fp16 with fused per-channel weight scale,
+/// per-tensor activation scale, bias, and optional ReLU.
+///   out_feats[m, c] = (acc[m, c] * act_scale * weight_scale[c]) + bias[c]
+///   if apply_relu: max(0, ...)
+///
+/// `act_scale_device` points to the per-tensor activation scale written by
+/// `reduce_abs_max_and_scales_fp16` (out_scales_device[1]). Reading it
+/// inside the kernel keeps everything async — no host sync per layer.
+/// `per_channel_weight_scale` is the [C_out] device array built on the
+/// first call for a given weight Constant.
+static void dequantize_int32_to_fp16(::sycl::queue& q,
+                                      const int32_t* __restrict__ acc,
+                                      ::sycl::half* __restrict__ out_feats,
+                                      int M, int C_out,
+                                      const float* __restrict__ act_scale_device,
+                                      const float* __restrict__ per_channel_weight_scale,
+                                      const ::sycl::half* __restrict__ bias,  // nullptr if no bias
+                                      bool apply_relu) {
+    q.parallel_for(::sycl::range<2>(M, C_out), [=](::sycl::id<2> idx) {
+        int m = static_cast<int>(idx[0]);
+        int c = static_cast<int>(idx[1]);
+        float act_scale = act_scale_device[0];
+        float val = static_cast<float>(acc[m * C_out + c])
+                    * act_scale * per_channel_weight_scale[c];
+        if (bias) val += static_cast<float>(bias[c]);
+        if (apply_relu) val = val > 0.0f ? val : 0.0f;
+        out_feats[m * C_out + c] = ::sycl::half(val);
+    });
+}
+
+// ===================================================================
+// Stage 2b: FP16 ↔ FP32 conversion kernels
+// ===================================================================
+
+/// Convert f16 buffer to f32.
+static void convert_f16_to_f32(::sycl::queue& q,
+                                const ::sycl::half* __restrict__ src,
+                                float* __restrict__ dst,
+                                int64_t count) {
+    q.parallel_for(::sycl::range<1>(count), [=](::sycl::id<1> i) {
+        dst[i] = static_cast<float>(src[i]);
+    });
+}
+
+/// Convert f32 buffer to f16.
+static void convert_f32_to_f16(::sycl::queue& q,
+                                const float* __restrict__ src,
+                                ::sycl::half* __restrict__ dst,
+                                int64_t count) {
+    q.parallel_for(::sycl::range<1>(count), [=](::sycl::id<1> i) {
+        dst[i] = ::sycl::half(src[i]);
+    });
+}
+
+// ===================================================================
+// Stage 2c: Bias addition + optional ReLU kernel
+// ===================================================================
+
+/// out_feats[m, c] += bias[c], then optionally apply ReLU
+static void add_bias_and_relu_fp32(::sycl::queue& q,
+                                    float* __restrict__ feats,
+                                    const float* __restrict__ bias,
+                                    int M, int C, bool apply_relu) {
+    q.parallel_for(::sycl::range<2>(M, C), [=](::sycl::id<2> idx) {
+        float val = feats[idx[0] * C + idx[1]] + bias[idx[1]];
+        if (apply_relu)
+            val = val > 0.0f ? val : 0.0f;
+        feats[idx[0] * C + idx[1]] = val;
+    });
+}
+
+/// Standalone ReLU for the no-bias case
+static void apply_relu_fp32(::sycl::queue& q,
+                             float* __restrict__ feats,
+                             int M, int C) {
+    q.parallel_for(::sycl::range<2>(M, C), [=](::sycl::id<2> idx) {
+        float& val = feats[idx[0] * C + idx[1]];
+        val = val > 0.0f ? val : 0.0f;
+    });
+}
+
+// ===================================================================
+// RAII guard for SYCL device memory
+// ===================================================================
+
+template <typename T>
+struct DeviceBuf {
+    T* ptr = nullptr;
+    ::sycl::queue* q = nullptr;
+
+    DeviceBuf() = default;
+    DeviceBuf(int64_t count, ::sycl::queue& queue) : q(&queue) {
+        ptr = ::sycl::malloc_device<T>(count, queue);
+    }
+    ~DeviceBuf() { if (ptr && q) ::sycl::free(ptr, *q); }
+
+    DeviceBuf(const DeviceBuf&) = delete;
+    DeviceBuf& operator=(const DeviceBuf&) = delete;
+    DeviceBuf(DeviceBuf&& o) noexcept : ptr(o.ptr), q(o.q) { o.ptr = nullptr; }
+    DeviceBuf& operator=(DeviceBuf&& o) noexcept {
+        if (this != &o) {
+            if (ptr && q) ::sycl::free(ptr, *q);
+            ptr = o.ptr; q = o.q; o.ptr = nullptr;
+        }
+        return *this;
+    }
+
+    T* get() const { return ptr; }
+    operator T*() const { return ptr; }
+
+    void zero(int64_t count) { q->memset(ptr, 0, count * sizeof(T)); }
+};
+
+// ===================================================================
+// sparse_convolution_sycl — main execution class
+// ===================================================================
+
+struct sparse_convolution_sycl : public typed_primitive_sycl_impl<sparse_convolution> {
+    using parent = typed_primitive_sycl_impl<sparse_convolution>;
+    using parent::parent;
+
+    std::shared_ptr<::sycl::context> fallback_context;
+    std::shared_ptr<::sycl::queue> fallback_queue;
+    void* fallback_queue_handle = nullptr;
+
+    // High-watermark USM staging slots. Under dynamic shapes (M varies per
+    // frame) the previous implementation re-called engine.allocate_memory()
+    // whenever the layout changed. Keeping a single underlying USM allocation
+    // per slot (grown on high-watermark, never shrunk) and handing out cheap
+    // reinterpret_buffer views avoids the churn.
+    struct StagingSlot {
+        memory::ptr hw;    // underlying allocation, sized to max layout seen
+        memory::ptr view;  // reinterpret view at current layout (same USM)
+    };
+    StagingSlot feat_slot;
+    StagingSlot coord_slot;
+    StagingSlot weight_slot;
+    StagingSlot bias_slot;
+    StagingSlot out_feat_slot;
+    StagingSlot out_coord_slot;
+
+    // INT8 path: per-layer persistent USM buffers grown high-watermark, to
+    // avoid malloc_device / free churn across 21 SparseConv layers × per-frame.
+    // Reset to nullptr on first use; lifetime matches the impl object.
+    struct Int8Scratch {
+        int8_t*  feats_i8 = nullptr;        int64_t feats_cap = 0;
+        int32_t* acc_i32 = nullptr;         int64_t acc_cap = 0;
+        float*   scales_3 = nullptr;        // [abs_max, act_scale, act_scale_inv]
+        // Path 1: int8 copy of this layer's output, produced alongside the
+        // fp16 output when `output_abs_max > 0`. Consumer reads this
+        // directly via the `s_int8_handoff` map. Sized to the GEMM
+        // output (gemm_m * c_out); grown high-watermark.
+        int8_t*  out_feats_i8 = nullptr;    int64_t out_feats_cap = 0;
+        float    ptq_abs_max_written = -1.0f;  // remember last value written so we
+                                               // don't re-submit a single_task that
+                                               // writes the same PTQ constant every
+                                               // frame.
+        ::sycl::queue* q = nullptr;
+
+        // Non-transferable via copy: the underlying USM is owned by exactly
+        // one impl instance. clone() makes a shallow copy of the struct
+        // (POD), but we reset the new instance's pointers to null so it
+        // allocates fresh buffers on first use. Without this, clone()
+        // would share buffers with the source, and the destructor of
+        // whichever impl is destroyed first would invalidate the other.
+        Int8Scratch() = default;
+        Int8Scratch(const Int8Scratch&) noexcept { /* clean slate for clones */ }
+        Int8Scratch& operator=(const Int8Scratch&) noexcept { return *this; }
+    };
+    Int8Scratch i8_scratch;
+
+    // Persistent Stage 1 (downsample_generate_output_coords) scratch.
+    // Previously the downsample path allocated d_hash_keys / d_out_counter /
+    // d_compact per-frame with malloc_device + sycl::free. Per-frame churn
+    // for 4 Sparse layers × 3 buffers = 12 alloc+free cycles, ~0.3-0.5 ms.
+    // High-watermark pooled here, same pattern as Int8Scratch.
+    struct Stage1Scratch {
+        int64_t* hash_keys = nullptr;  int64_t hash_cap = 0;
+        int*     counter   = nullptr;  // always size 1
+        int64_t* compact   = nullptr;  int64_t compact_cap = 0;
+        ::sycl::queue* q = nullptr;
+
+        Stage1Scratch() = default;
+        Stage1Scratch(const Stage1Scratch&) noexcept {}  // clean slate for clone()
+        Stage1Scratch& operator=(const Stage1Scratch&) noexcept { return *this; }
+    };
+    Stage1Scratch stage1_scratch;
+
+    ~sparse_convolution_sycl() override {
+        // Release INT8 scratch if we own one — same constraint as the
+        // rulebook cache: skip if the SYCL runtime is already torn down.
+        // We don't know statically; free best-effort and swallow exceptions.
+        if (i8_scratch.q) {
+            try {
+                if (i8_scratch.feats_i8)     ::sycl::free(i8_scratch.feats_i8,     *i8_scratch.q);
+                if (i8_scratch.acc_i32)      ::sycl::free(i8_scratch.acc_i32,      *i8_scratch.q);
+                if (i8_scratch.scales_3)     ::sycl::free(i8_scratch.scales_3,     *i8_scratch.q);
+                if (i8_scratch.out_feats_i8) ::sycl::free(i8_scratch.out_feats_i8, *i8_scratch.q);
+            } catch (...) {}
+        }
+        if (stage1_scratch.q) {
+            try {
+                if (stage1_scratch.hash_keys) ::sycl::free(stage1_scratch.hash_keys, *stage1_scratch.q);
+                if (stage1_scratch.counter)   ::sycl::free(stage1_scratch.counter,   *stage1_scratch.q);
+                if (stage1_scratch.compact)   ::sycl::free(stage1_scratch.compact,   *stage1_scratch.q);
+            } catch (...) {}
+        }
+    }
+
+    static allocation_type get_staging_usm_type(engine& engine) {
+        if (engine.supports_allocation(allocation_type::usm_device))
+            return allocation_type::usm_device;
+        if (engine.supports_allocation(allocation_type::usm_shared))
+            return allocation_type::usm_shared;
+        return allocation_type::usm_host;
+    }
+
+    static memory::ptr ensure_usm(memory::ptr mem,
+                                  StagingSlot& slot,
+                                  stream& stream,
+                                  engine& engine,
+                                  bool is_output,
+                                  bool blocking) {
+        OPENVINO_ASSERT(mem != nullptr, "SparseConvolution: null memory");
+        if (memory_capabilities::is_usm_type(mem->get_allocation_type()))
+            return mem;
+
+        const auto required = get_staging_usm_type(engine);
+        const auto& need_layout = mem->get_layout();
+        const auto need_bytes = need_layout.bytes_count();
+
+        // Grow the backing allocation only when the new layout needs more
+        // bytes than what we already hold (or the allocation type changed).
+        if (slot.hw == nullptr ||
+            slot.hw->get_allocation_type() != required ||
+            slot.hw->size() < need_bytes) {
+            slot.hw = engine.allocate_memory(need_layout, required, false);
+            slot.view = slot.hw;
+        } else if (slot.view == nullptr || slot.view->get_layout() != need_layout) {
+            // Reuse the existing USM, just retarget the layout.
+            slot.view = engine.reinterpret_buffer(*slot.hw, need_layout);
+        }
+
+        if (!is_output)
+            slot.view->copy_from(stream, *mem, blocking);
+        return slot.view;
+    }
+
+    DECLARE_OBJECT_TYPE_SERIALIZATION(cldnn::sycl::sparse_convolution_sycl)
+
+    std::unique_ptr<primitive_impl> clone() const override {
+        return std::make_unique<sparse_convolution_sycl>(*this);
+    }
+
+    // -------------------------------------------------------------------
+    // execute_impl — main entry, called once per inference
+    // -------------------------------------------------------------------
+
+    event::ptr execute_impl(const std::vector<event::ptr>& events,
+                            typed_primitive_inst<sparse_convolution>& instance) override {
+        auto& network = instance.get_network();
+        auto& stream = downcast<ocl::ocl_stream>(network.get_stream());
+        auto& engine = network.get_engine();
+        auto desc = instance.get_typed_desc<sparse_convolution>();
+
+        // --- Obtain SYCL queue ---
+        ::sycl::queue* q = nullptr;
+        if (auto* s = dynamic_cast<ocl::sycl_stream*>(&stream)) {
+            q = &s->get_sycl_queue();
+        } else {
+            auto& ocl_eng = downcast<ocl::ocl_engine>(engine);
+            auto cur = static_cast<void*>(stream.get_cl_queue().get());
+            if (!fallback_queue || fallback_queue_handle != cur) {
+                fallback_context = std::make_shared<::sycl::context>(
+                    ::sycl::make_context<::sycl::backend::opencl>(
+                        ocl_eng.get_cl_context().get()));
+                fallback_queue = std::make_shared<::sycl::queue>(
+                    ::sycl::make_queue<::sycl::backend::opencl>(
+                        stream.get_cl_queue().get(), *fallback_context));
+                fallback_queue_handle = cur;
+            }
+            q = fallback_queue.get();
+        }
+
+        // --- Get input/output memory ---
+        auto feat_mem = instance.input_memory_ptr(0);
+        auto coord_mem = instance.input_memory_ptr(1);
+        auto weight_mem = instance.input_memory_ptr(2);
+        memory::ptr bias_mem = nullptr;
+        if (instance.inputs_memory_count() > 3)
+            bias_mem = instance.input_memory_ptr(3);
+        auto out_feat_mem = instance.output_memory_ptr(0);
+        auto out_coord_mem = instance.output_memory_ptr(1);
+
+        // --- Wait + USM staging ---
+        stream.wait_for_events(events);
+        const bool blocking = stream.get_queue_type() == QueueTypes::out_of_order;
+
+        feat_mem = ensure_usm(feat_mem, feat_slot, stream, engine, false, blocking);
+        coord_mem = ensure_usm(coord_mem, coord_slot, stream, engine, false, blocking);
+        weight_mem = ensure_usm(weight_mem, weight_slot, stream, engine, false, blocking);
+        if (bias_mem)
+            bias_mem = ensure_usm(bias_mem, bias_slot, stream, engine, false, blocking);
+        auto kern_out_feat = ensure_usm(out_feat_mem, out_feat_slot, stream, engine, true, blocking);
+        auto kern_out_coord = ensure_usm(out_coord_mem, out_coord_slot, stream, engine, true, blocking);
+
+        // --- Extract shapes ---
+        const auto& feat_layout = feat_mem->get_layout();
+        const auto& feat_shape = feat_layout.get_shape();
+        // Prefer coord_mem->shape[0] as the row count. feat_mem may have been
+        // pre-grown past the real M by the GPU plugin's ShapePredictor; coord
+        // tensor is not, so it's the authoritative M. Defensive: the
+        // ShapePredictor fix in shape_predictor.cpp also prevents the
+        // inflation upstream, but this cap keeps SparseConvolution robust
+        // against any future preallocation surprises.
+        const auto& coord_shape = coord_mem->get_layout().get_shape();
+        int m_in = static_cast<int>(std::min<size_t>(feat_shape[0], coord_shape[0]));
+        const int c_in = static_cast<int>(feat_shape[1]);
+        const int c_out = static_cast<int>(desc->out_channels);
+        const bool is_subm = desc->subm;
+        const bool is_f16 = (feat_layout.data_type == data_types::f16);
+
+        int k_vol = 1;
+        for (auto k : desc->kernel_size) k_vol *= static_cast<int>(k);
+
+        const bool apply_relu = (desc->activation == "ReLU");
+        const std::string& rulebook = desc->rulebook;
+        const bool use_rulebook = !rulebook.empty() && is_subm;
+
+        // Lightweight profiling: set env SPCONV_PERF_TRACE=1 to enable
+        static const bool perf_trace = (std::getenv("SPCONV_PERF_TRACE") != nullptr);
+        auto t0 = std::chrono::steady_clock::now();
+
+        // ---------------------------------------------------------------
+        // Stage 1: Kernel Map Building (with rulebook cache)
+        // ---------------------------------------------------------------
+
+        auto* coord_raw = static_cast<const int32_t*>(coord_mem->buffer_ptr());
+
+        // Override m_in with actual voxel count from predecessor's output
+        // (buffer may be larger than actual data for stride>1 convolutions)
+        auto actual_m_it = s_actual_m_map.find(coord_raw);
+        if (actual_m_it != s_actual_m_map.end()) {
+            m_in = actual_m_it->second;
+        }
+
+        // Check rulebook cache for SubMConv kernel map reuse
+        bool cache_hit = false;
+        const int32_t* cached_out_in_map_ptr = nullptr;
+        int m_out = 0;
+
+        if (use_rulebook) {
+            auto it = s_rulebook_cache.find(rulebook);
+            if (it != s_rulebook_cache.end() &&
+                it->second.matches(m_in, k_vol, coord_raw)) {
+                cache_hit = true;
+                m_out = m_in;  // SubMConv: M_out == M_in
+                cached_out_in_map_ptr = it->second.out_in_map;
+            }
+        }
+
+        // Local DeviceBuf objects (only used when cache miss)
+        DeviceBuf<int32_t> reordered_in(0, *q);
+        DeviceBuf<int64_t> hash_keys(0, *q);
+        DeviceBuf<int> hash_vals(0, *q);
+        DeviceBuf<int32_t> out_coords_xyzb(0, *q);
+        DeviceBuf<int32_t> out_coords_bxyz_buf(0, *q);
+        DeviceBuf<int32_t> out_in_map(0, *q);
+        int hash_cap = 0;
+
+        const int32_t* out_in_map_ptr = nullptr;
+
+        if (cache_hit) {
+            out_in_map_ptr = cached_out_in_map_ptr;
+        } else {
+            // 1a. Reorder input coords: [batch,x,y,z] → [x,y,z,batch]
+            reordered_in = DeviceBuf<int32_t>(m_in * 4, *q);
+            reorder_bxyz_to_xyzb(*q, coord_raw, reordered_in, m_in);
+
+            // 1b. Build hash table from input coords (xyzb)
+            hash_cap = std::max(512, 2 * m_in);
+            hash_keys = DeviceBuf<int64_t>(hash_cap, *q);
+            hash_vals = DeviceBuf<int>(hash_cap, *q);
+            hash_keys.zero(hash_cap);
+            hash_vals.zero(hash_cap);
+            hash_insert_coords(*q, hash_keys, hash_vals, hash_cap, reordered_in, m_in);
+
+            // 1c. Determine output coordinates
+            if (is_subm) {
+                m_out = m_in;
+            } else {
+                int max_possible = k_vol * m_in;
+                out_coords_bxyz_buf = DeviceBuf<int32_t>(max_possible * 4, *q);
+
+                m_out = downsample_generate_output_coords(
+                    *q,
+                    coord_raw,
+                    m_in,
+                    desc->kernel_size.data(),
+                    desc->stride.data(),
+                    desc->padding.data(),
+                    desc->input_spatial_shape.data(),
+                    out_coords_bxyz_buf,
+                    max_possible,
+                    stage1_scratch);
+
+                OPENVINO_ASSERT(m_out > 0, "SparseConvolution: downsample produced 0 output voxels");
+
+                out_coords_xyzb = DeviceBuf<int32_t>(m_out * 4, *q);
+                reorder_bxyz_to_xyzb(*q, out_coords_bxyz_buf, out_coords_xyzb, m_out);
+            }
+
+            const int32_t* out_xyzb_ptr = is_subm
+                ? reordered_in.get()
+                : out_coords_xyzb.get();
+
+            // 1d. Build kernel map: out_in_map [m_out, k_vol]
+            out_in_map = DeviceBuf<int32_t>(static_cast<int64_t>(m_out) * k_vol, *q);
+            q->memset(out_in_map.get(), 0xFF,
+                      static_cast<int64_t>(m_out) * k_vol * sizeof(int32_t));
+
+            hash_lookup_build_kmap(
+                *q,
+                hash_keys, hash_vals, hash_cap,
+                out_xyzb_ptr, m_out,
+                desc->kernel_size.data(),
+                desc->stride.data(),
+                desc->padding.data(),
+                k_vol,
+                out_in_map);
+
+            out_in_map_ptr = out_in_map.get();
+
+            // Cache the results if rulebook is set
+            if (use_rulebook) {
+                auto& entry = s_rulebook_cache[rulebook];
+                entry.clear();
+                entry.q = q;
+                entry.m_points = m_in;
+                entry.k_vol = k_vol;
+                entry.last_coord_ptr = coord_raw;
+
+                entry.hash_cap = hash_cap;
+                entry.hash_keys = ::sycl::malloc_device<int64_t>(hash_cap, *q);
+                entry.hash_vals = ::sycl::malloc_device<int>(hash_cap, *q);
+                q->memcpy(entry.hash_keys, hash_keys.get(), hash_cap * sizeof(int64_t));
+                q->memcpy(entry.hash_vals, hash_vals.get(), hash_cap * sizeof(int));
+
+                entry.reordered_in = ::sycl::malloc_device<int32_t>(m_in * 4, *q);
+                q->memcpy(entry.reordered_in, reordered_in.get(),
+                           m_in * 4 * sizeof(int32_t));
+
+                entry.out_in_map = ::sycl::malloc_device<int32_t>(
+                    static_cast<int64_t>(m_in) * k_vol, *q);
+                q->memcpy(entry.out_in_map, out_in_map.get(),
+                           static_cast<int64_t>(m_in) * k_vol * sizeof(int32_t));
+            }
+        }
+
+        // ---------------------------------------------------------------
+        // Stage 2: Implicit GEMM Convolution
+        // ---------------------------------------------------------------
+
+        auto* weight_raw = static_cast<const void*>(weight_mem->buffer_ptr());
+        auto* feat_raw = static_cast<const void*>(feat_mem->buffer_ptr());
+        const void* bias_raw = bias_mem ? bias_mem->buffer_ptr() : nullptr;
+
+        // INT8 path: auto-enabled when the model is quantised (NNCF+PTQ).
+        // Detection: EatSparseConvInputFakeQuantize sets desc->input_abs_max > 0
+        // at compile time when a FakeQuantize(levels=256) sits on port 0.
+        // Symmetric per-tensor activation quantization + symmetric per-output-
+        // channel weight quantization. Requires fp16 input.
+        //
+        // Override env vars:
+        //   SPCONV_FORCE_INT8=1    → force INT8 even without FakeQuantize
+        //   SPCONV_DISABLE_INT8=1  → force FP16 even on quantised models
+        static const bool s_force_int8 = [] {
+            const char* e = std::getenv("SPCONV_FORCE_INT8");
+            return e != nullptr && e[0] != '0' && e[0] != '\0';
+        }();
+        static const bool s_disable_int8 = [] {
+            const char* e = std::getenv("SPCONV_DISABLE_INT8");
+            return e != nullptr && e[0] != '0' && e[0] != '\0';
+        }();
+        const bool model_is_quantised = (desc->input_abs_max > 0.0f);
+        const bool use_int8 = is_f16 && !s_disable_int8
+                              && (model_is_quantised || s_force_int8);
+
+        if (perf_trace) {
+            fprintf(stderr, "[SparseConv] %s: %s (input_abs_max=%.4f%s%s)\n",
+                    desc->id.c_str(),
+                    use_int8 ? "INT8" : (is_f16 ? "FP16" : "FP32"),
+                    desc->input_abs_max,
+                    s_force_int8 ? " FORCE_INT8" : "",
+                    s_disable_int8 ? " DISABLE_INT8" : "");
+        }
+
+        if (use_int8) {
+            auto* out_feat_ptr = static_cast<::sycl::half*>(kern_out_feat->buffer_ptr());
+            const auto& out_layout = kern_out_feat->get_layout();
+            int out_buf_m = static_cast<int>(out_layout.get_shape()[0]);
+            int gemm_m = std::min(m_out, out_buf_m);
+
+            // Zero only the TAIL rows [gemm_m, out_buf_m). GEMM writes rows
+            // 0..gemm_m; tail rows must be zero so downstream residual Add
+            // doesn't accumulate garbage. For SubM layers gemm_m == out_buf_m
+            // → skipped entirely. For stride>1 (spconv_down2) gemm_m ≪
+            // out_buf_m → big savings. Roll back with SPCONV_MEMSET_FULL=1.
+            static const bool s_memset_full = []() {
+                const char* e = std::getenv("SPCONV_MEMSET_FULL");
+                return e != nullptr && e[0] != '0' && e[0] != '\0';
+            }();
+            if (out_buf_m > 0) {
+                if (s_memset_full) {
+                    q->memset(out_feat_ptr, 0,
+                              static_cast<int64_t>(out_buf_m) * c_out * sizeof(::sycl::half));
+                } else if (gemm_m < out_buf_m) {
+                    q->memset(out_feat_ptr + static_cast<int64_t>(gemm_m) * c_out, 0,
+                              static_cast<int64_t>(out_buf_m - gemm_m) * c_out * sizeof(::sycl::half));
+                }
+            }
+
+            if (gemm_m > 0) {
+                // Prime the per-impl INT8 scratch. Buffers grow high-watermark;
+                // never shrink. This avoids per-frame malloc_device / free.
+                if (i8_scratch.q == nullptr) i8_scratch.q = q;
+                const int64_t feat_count = static_cast<int64_t>(m_in) * c_in;
+                const int64_t acc_count  = static_cast<int64_t>(gemm_m) * c_out;
+                // `feats_i8` is the pre-quantised input buffer — needed for
+                // the default split-kernel path (see Step 2 comment).
+                if (i8_scratch.feats_cap < feat_count) {
+                    if (i8_scratch.feats_i8) ::sycl::free(i8_scratch.feats_i8, *q);
+                    i8_scratch.feats_i8 = ::sycl::malloc_device<int8_t>(feat_count, *q);
+                    i8_scratch.feats_cap = feat_count;
+                }
+                if (i8_scratch.acc_cap < acc_count) {
+                    if (i8_scratch.acc_i32) ::sycl::free(i8_scratch.acc_i32, *q);
+                    i8_scratch.acc_i32 = ::sycl::malloc_device<int32_t>(acc_count, *q);
+                    i8_scratch.acc_cap = acc_count;
+                }
+                if (i8_scratch.scales_3 == nullptr) {
+                    i8_scratch.scales_3 = ::sycl::malloc_device<float>(3, *q);
+                }
+
+                // Step 1: obtain the per-tensor activation abs-max.
+                //
+                // Two modes:
+                //   (a) PTQ path — desc->input_abs_max > 0. The GPU plugin's
+                //       EatSparseConvInputFakeQuantize pass copied this value
+                //       from the upstream FakeQuantize at compile time. We
+                //       just fill scales_3[0] with that constant and skip
+                //       the online reduce entirely — saves 2 kernel launches
+                //       (reduce-init + reduce-reduce) per SparseConvolution.
+                //   (b) Fallback path — no calibrated scale. Run the on-line
+                //       reduce to derive abs_max for the current frame.
+                const float ptq_abs_max = desc->input_abs_max;
+                if (ptq_abs_max > 0.0f) {
+                    // PTQ scale is compile-time constant. The first time we
+                    // see this layer (or if IR changes) we submit a
+                    // single_task to push it into scales_3[0]; on subsequent
+                    // frames the value is already there, so skip the kernel
+                    // launch entirely. Saves 21 × ~20 μs per frame.
+                    if (i8_scratch.ptq_abs_max_written != ptq_abs_max) {
+                        float* scales_ptr = i8_scratch.scales_3;
+                        const float v = ptq_abs_max;
+                        q->submit([&](::sycl::handler& cgh) {
+                            cgh.single_task([=]() { scales_ptr[0] = v; });
+                        });
+                        i8_scratch.ptq_abs_max_written = ptq_abs_max;
+                    }
+                } else {
+                    reduce_abs_max_fp16(*q,
+                                         static_cast<const ::sycl::half*>(feat_raw),
+                                         i8_scratch.scales_3,
+                                         feat_count);
+                }
+                const float* abs_max_dev_ptr = i8_scratch.scales_3;
+
+                // Step 2: quantize features with a stand-alone kernel
+                // (or skip entirely if a Path 1 handoff is available).
+                //
+                // Path 1 consumer check: if the upstream SparseConv already
+                // produced an int8 copy of this layer's input (via its
+                // fused i8-output store), reuse that buffer and skip our
+                // own quantize kernel.
+                static const bool s_disable_path1 = []() {
+                    const char* e = std::getenv("SPCONV_DISABLE_PATH1");
+                    return e != nullptr && e[0] != '0' && e[0] != '\0';
+                }();
+                const int8_t* handoff_i8 = nullptr;
+                if (!s_disable_path1 && ptq_abs_max > 0.0f
+                    && !desc->input_handoff_producer.empty()) {
+                    auto it = s_int8_handoff.find(desc->input_handoff_producer);
+                    if (it != s_int8_handoff.end() &&
+                        it->second.C == c_in &&
+                        it->second.M >= m_in) {
+                        handoff_i8 = it->second.data_i8;
+                    }
+                    static const bool s_path1_trace = std::getenv("SPCONV_PATH1_TRACE") != nullptr;
+                    if (s_path1_trace) {
+                        fprintf(stderr,
+                            "[Path1-consumer] desc=%s <- producer=%s  handoff=%s  "
+                            "cin=%d m_in=%d (map M=%d C=%d)\n",
+                            desc->id.c_str(),
+                            desc->input_handoff_producer.c_str(),
+                            handoff_i8 ? "USE" : "MISS",
+                            c_in, m_in,
+                            it != s_int8_handoff.end() ? it->second.M : -1,
+                            it != s_int8_handoff.end() ? it->second.C : -1);
+                    }
+                }
+
+                if (!handoff_i8) {
+                    quantize_fp16_to_int8(*q,
+                                           static_cast<const ::sycl::half*>(feat_raw),
+                                           i8_scratch.feats_i8,
+                                           feat_count,
+                                           abs_max_dev_ptr);
+                }
+
+                // Step 3: get/build the int8 weight cache for this weight Constant.
+                auto weight_it = s_int8_weight_cache.find(weight_raw);
+                if (weight_it == s_int8_weight_cache.end()) {
+                    Int8WeightCache cache;
+                    cache.q = q;
+                    cache.c_out = c_out;
+                    cache.total = static_cast<int64_t>(k_vol) * c_in * c_out;
+                    cache.weights_i8 = ::sycl::malloc_device<int8_t>(cache.total, *q);
+                    cache.per_channel_scale_inv = ::sycl::malloc_device<float>(c_out, *q);
+                    cache.per_channel_abs_max   = ::sycl::malloc_device<float>(c_out, *q);
+                    cache.per_channel_scale     = ::sycl::malloc_device<float>(c_out, *q);
+                    quantize_fp16_weights_to_int8(*q,
+                        static_cast<const ::sycl::half*>(weight_raw),
+                        cache.weights_i8,
+                        cache.per_channel_scale_inv,
+                        cache.per_channel_abs_max,
+                        k_vol, c_in, c_out);
+                    // Pre-compute per_channel_scale = abs_max / 127 so the
+                    // dequant kernel reads a ready-to-use scale. This runs
+                    // once per layer, chained async after the weight quantize.
+                    float* w_abs_max_src = cache.per_channel_abs_max;
+                    float* w_scale_dst   = cache.per_channel_scale;
+                    int    c_out_cap     = c_out;
+                    q->parallel_for(::sycl::range<1>(c_out_cap), [=](::sycl::id<1> i) {
+                        w_scale_dst[i] = w_abs_max_src[i] / 127.0f;
+                    });
+                    weight_it = s_int8_weight_cache.emplace(weight_raw, std::move(cache)).first;
+                }
+                const int8_t* weights_i8_ptr   = weight_it->second.weights_i8;
+                const float*  w_scale_dev_ptr  = weight_it->second.per_channel_scale;
+
+                // Step 4: INT8 XMX implicit GEMM with fused dequant + bias +
+                // ReLU. Writes fp16 directly to `out_feat_ptr`. Pick the wide
+                // kernel (TILE_N=64, 16 SGs) for layers with c_out ≥ 64 —
+                // same heuristic the FP16 path uses.
+                //
+                // Input feats source: either the Path 1 handoff buffer (when
+                // upstream SparseConv produced int8 for us) or the scratch
+                // buffer populated by the stand-alone quantize kernel above.
+                const auto* bias_f16 = bias_raw
+                    ? static_cast<const ::sycl::half*>(bias_raw) : nullptr;
+                const int8_t* feat_i8_input =
+                    handoff_i8 ? handoff_i8 : i8_scratch.feats_i8;
+
+                // Path 1 producer prep: if this layer's output feeds another
+                // SparseConv through a direct FakeQuantize, allocate an int8
+                // scratch sized to the GEMM output and compute scale_inv. The
+                // GEMM's store phase will write both fp16 (for fallback
+                // downstream consumers) and int8 (for the fast handoff path).
+                const float out_abs_max = desc->output_abs_max;
+                int8_t* out_i8_scratch = nullptr;
+                float   out_scale_inv_127 = 0.0f;
+                if (!s_disable_path1 && out_abs_max > 0.0f) {
+                    const int64_t out_buf_count =
+                        static_cast<int64_t>(out_buf_m) * c_out;
+                    if (i8_scratch.out_feats_cap < out_buf_count) {
+                        if (i8_scratch.out_feats_i8)
+                            ::sycl::free(i8_scratch.out_feats_i8, *q);
+                        i8_scratch.out_feats_i8 =
+                            ::sycl::malloc_device<int8_t>(out_buf_count, *q);
+                        i8_scratch.out_feats_cap = out_buf_count;
+                    }
+                    out_i8_scratch = i8_scratch.out_feats_i8;
+                    out_scale_inv_127 =
+                        127.0f / std::max(out_abs_max, 1e-8f);
+                }
+
+                if (c_out >= 64) {
+                    run_implicit_gemm_int8_xmx_wide(*q,
+                                                     feat_i8_input,
+                                                     weights_i8_ptr,
+                                                     out_in_map_ptr,
+                                                     out_feat_ptr,
+                                                     abs_max_dev_ptr,
+                                                     w_scale_dev_ptr,
+                                                     bias_f16, apply_relu,
+                                                     gemm_m, c_in, c_out, k_vol,
+                                                     out_i8_scratch,
+                                                     out_scale_inv_127);
+                } else {
+                    run_implicit_gemm_int8_xmx(*q,
+                                                feat_i8_input,
+                                                weights_i8_ptr,
+                                                out_in_map_ptr,
+                                                out_feat_ptr,
+                                                abs_max_dev_ptr,
+                                                w_scale_dev_ptr,
+                                                bias_f16, apply_relu,
+                                                gemm_m, c_in, c_out, k_vol,
+                                                out_i8_scratch,
+                                                out_scale_inv_127);
+                }
+
+                // Publish the int8 handoff for the downstream SparseConv.
+                // Keyed by producer friendly-name (not buffer pointer — LPT's
+                // dequant Multiply rewrites the edge pointer, see §8.7.4).
+                if (out_i8_scratch) {
+                    // Publish under this impl's own producer ID. The consumer
+                    // matcher pass stored this name on its input_handoff_producer
+                    // attribute — friendly name, stripped of the "sparseconvolution:"
+                    // prefix that the plugin adds when it builds the primitive ID.
+                    // Strip only if present.
+                    const std::string& id = desc->id;
+                    const std::string prefix = "sparseconvolution:";
+                    std::string handoff_key = (id.rfind(prefix, 0) == 0)
+                        ? id.substr(prefix.size()) : id;
+                    Int8Handoff h;
+                    h.data_i8 = out_i8_scratch;
+                    h.M = gemm_m;
+                    h.C = c_out;
+                    s_int8_handoff[handoff_key] = h;
+                    static const bool s_path1_trace = std::getenv("SPCONV_PATH1_TRACE") != nullptr;
+                    if (s_path1_trace) {
+                        fprintf(stderr,
+                            "[Path1-producer] desc=%s key='%s' M=%d C=%d\n",
+                            desc->id.c_str(), handoff_key.c_str(),
+                            gemm_m, c_out);
+                    }
+                }
+            }
+        } else if (is_f16) {
+            // FP16 XMX path: native FP16 GEMM with fused bias + ReLU (single kernel)
+            auto* out_feat_ptr = static_cast<::sycl::half*>(kern_out_feat->buffer_ptr());
+            const auto& out_layout = kern_out_feat->get_layout();
+            int out_buf_m = static_cast<int>(out_layout.get_shape()[0]);
+            int gemm_m = std::min(m_out, out_buf_m);
+
+            // Zero only tail rows [gemm_m, out_buf_m). See INT8 path above
+            // for the rationale + env flag.
+            static const bool s_memset_full_fp16 = []() {
+                const char* e = std::getenv("SPCONV_MEMSET_FULL");
+                return e != nullptr && e[0] != '0' && e[0] != '\0';
+            }();
+            if (out_buf_m > 0) {
+                if (s_memset_full_fp16) {
+                    q->memset(out_feat_ptr, 0,
+                              static_cast<int64_t>(out_buf_m) * c_out * sizeof(::sycl::half));
+                } else if (gemm_m < out_buf_m) {
+                    q->memset(out_feat_ptr + static_cast<int64_t>(gemm_m) * c_out, 0,
+                              static_cast<int64_t>(out_buf_m - gemm_m) * c_out * sizeof(::sycl::half));
+                }
+            }
+
+            const auto* bias_f16 = bias_raw
+                ? static_cast<const ::sycl::half*>(bias_raw) : nullptr;
+
+            if (gemm_m > 0) {
+                if (c_out >= 64) {
+                    // Wide kernel: TILE_N=64, 16 SGs — better input reuse
+                    run_implicit_gemm_fp16_xmx_wide(
+                        *q,
+                        static_cast<const ::sycl::half*>(feat_raw),
+                        static_cast<const ::sycl::half*>(weight_raw),
+                        out_in_map_ptr,
+                        out_feat_ptr,
+                        gemm_m, c_in, c_out, k_vol,
+                        bias_f16, apply_relu);
+                } else {
+                    // Standard kernel: TILE_N=32, 8 SGs
+                    run_implicit_gemm_fp16_xmx(
+                        *q,
+                        static_cast<const ::sycl::half*>(feat_raw),
+                        static_cast<const ::sycl::half*>(weight_raw),
+                        out_in_map_ptr,
+                        out_feat_ptr,
+                        gemm_m, c_in, c_out, k_vol,
+                        bias_f16, apply_relu);
+                }
+            }
+
+        } else {
+            // FP32 path: allocate intermediate FP32 buffer
+            DeviceBuf<float> f32_out(static_cast<int64_t>(m_out) * c_out, *q);
+            f32_out.zero(static_cast<int64_t>(m_out) * c_out);
+
+            run_implicit_gemm_fp32(*q,
+                                   static_cast<const float*>(feat_raw),
+                                   static_cast<const float*>(weight_raw),
+                                   out_in_map_ptr, f32_out,
+                                   m_out, c_in, c_out, k_vol);
+
+            // Add bias + optional ReLU
+            if (bias_raw) {
+                add_bias_and_relu_fp32(*q, f32_out,
+                                       static_cast<const float*>(bias_raw),
+                                       m_out, c_out, apply_relu);
+            } else if (apply_relu) {
+                apply_relu_fp32(*q, f32_out, m_out, c_out);
+            }
+
+            // Copy to output buffer — zero only tail rows [copy_m, out_buf_m).
+            // The subsequent copy_from writes rows [0, copy_m); tail rows need
+            // to be zero so downstream Add doesn't see garbage.
+            auto* out_feat_ptr = static_cast<float*>(kern_out_feat->buffer_ptr());
+            const auto& out_layout = kern_out_feat->get_layout();
+            int out_buf_m = static_cast<int>(out_layout.get_shape()[0]);
+            int copy_m = std::min(m_out, out_buf_m);
+            static const bool s_memset_full_fp32 = []() {
+                const char* e = std::getenv("SPCONV_MEMSET_FULL");
+                return e != nullptr && e[0] != '0' && e[0] != '\0';
+            }();
+            if (out_buf_m > 0) {
+                if (s_memset_full_fp32) {
+                    q->memset(out_feat_ptr, 0,
+                              static_cast<int64_t>(out_buf_m) * c_out * sizeof(float));
+                } else if (copy_m < out_buf_m) {
+                    q->memset(out_feat_ptr + static_cast<int64_t>(copy_m) * c_out, 0,
+                              static_cast<int64_t>(out_buf_m - copy_m) * c_out * sizeof(float));
+                }
+            }
+            if (copy_m > 0) {
+                q->memcpy(out_feat_ptr, f32_out.get(),
+                          static_cast<int64_t>(copy_m) * c_out * sizeof(float));
+            }
+        }
+
+        // ---------------------------------------------------------------
+        // Stage 3: Write output coordinates
+        // ---------------------------------------------------------------
+
+        auto* out_coord_ptr = static_cast<int32_t*>(kern_out_coord->buffer_ptr());
+        const auto& out_coord_layout = kern_out_coord->get_layout();
+        int out_coord_buf_m = static_cast<int>(out_coord_layout.get_shape()[0]);
+        int copy_coord_m = std::min(m_out, out_coord_buf_m);
+
+        if (is_subm) {
+            // Output coords = input coords (already in bxyz)
+            if (copy_coord_m > 0) {
+                q->memcpy(out_coord_ptr, coord_raw,
+                          static_cast<int64_t>(copy_coord_m) * 4 * sizeof(int32_t));
+            }
+        } else {
+            // Convert output coords from xyzb → bxyz
+            if (copy_coord_m > 0) {
+                reorder_xyzb_to_bxyz(*q, out_coords_xyzb, out_coord_ptr, copy_coord_m);
+            }
+        }
+
+        // Store actual M_out so downstream layers know real voxel count
+        s_actual_m_map[out_coord_ptr] = m_out;
+
+        // ---------------------------------------------------------------
+        // Synchronize: single wait for all async GPU work before
+        // DeviceBufs go out of scope and staging copy-back
+        // ---------------------------------------------------------------
+        auto t1 = std::chrono::steady_clock::now();
+        q->wait();
+        auto t2 = std::chrono::steady_clock::now();
+
+        if (perf_trace) {
+            double submit_ms = std::chrono::duration<double, std::milli>(t1 - t0).count();
+            double wait_ms = std::chrono::duration<double, std::milli>(t2 - t1).count();
+            fprintf(stderr, "[SPCONV] %s M=%d C_in=%d C_out=%d k=%d %s%s %s  submit=%.2fms wait=%.2fms total=%.2fms\n",
+                    desc->rulebook.empty() ? "nobook" : desc->rulebook.c_str(),
+                    m_out, c_in, c_out, k_vol,
+                    is_subm ? "SubM" : "Sparse",
+                    cache_hit ? " (cached)" : "",
+                    use_int8 ? "INT8" : (is_f16 ? "FP16" : "FP32"),
+                    submit_ms, wait_ms, submit_ms + wait_ms);
+        }
+
+        if (kern_out_feat.get() != out_feat_mem.get())
+            out_feat_mem->copy_from(stream, *kern_out_feat, blocking);
+        if (kern_out_coord.get() != out_coord_mem.get()) {
+            out_coord_mem->copy_from(stream, *kern_out_coord, blocking);
+            // Also store actual M for the final output coord buffer
+            s_actual_m_map[out_coord_mem->buffer_ptr()] = m_out;
+        }
+
+        // Return an event wrapping the synchronization
+        return stream.create_user_event(true);
+    }
+};
+
+// ===================================================================
+// Factory method
+// ===================================================================
+
+std::unique_ptr<primitive_impl> SparseConvolutionV15SyclImpl::create_impl(
+    const program_node& node,
+    const kernel_impl_params& params) const {
+    auto& engine = node.get_program().get_engine();
+    auto& config = node.get_program().get_config();
+    return std::make_unique<sparse_convolution_sycl>(engine, config);
+}
