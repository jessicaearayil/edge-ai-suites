+#!/usr/bin/env python3
+"""
+Per-layer validation of OpenVINO SparseConvolution against spconv reference data.
+
+Loads the 21-layer dumped data from BEVFusion's sparse encoder, builds per-layer
+ONNX models with org.openvinotoolkit::SparseConvolution, runs inference on Intel
+GPU via OpenVINO, and compares output features/coordinates against the spconv
+reference.
+
+Usage:
+    # Preferred: use the wrapper, which sets PYTHONPATH / LD_LIBRARY_PATH to
+    # the locally built OpenVINO so the SparseConvolution / SparseToDense
+    # ONNX translators are picked up (the pip-installed openvino does not
+    # have them).
+    ./run_validation.sh
+
+    # Manual invocation (all env vars on ONE line — no `\` line continuations):
+    OV_DIR=/home/jie/workspace/openvino/bin/intel64/Release \
+        PYTHONPATH="$OV_DIR/python:$PYTHONPATH" \
+        LD_LIBRARY_PATH="$OV_DIR:$LD_LIBRARY_PATH" \
+        /home/jie/env/spconvEnv/bin/python test_sparse_encoder_validation.py \
+        --dump-dir /home/jie/workspace/openvino/test_data/sparse_conv_dump
+"""
+
+import argparse
+import json
+import os
+import sys
+import tempfile
+from dataclasses import dataclass
+from typing import Optional
+
+import numpy as np
+import onnx
+from onnx import TensorProto, helper
+
+
+def resolve_gpu_device(ov_core, requested_device: str) -> tuple[str, str]:
+    """Resolve logical GPU device to a concrete OpenVINO target.
+
+    If requested_device is exactly "GPU", this picks a concrete GPU.x device.
+    Preference order: Arc/B580-like discrete devices first, then fallback to GPU.0.
+    Returns (device_name_to_use, human_readable_device_name).
+    """
+    if requested_device != "GPU":
+        return requested_device, requested_device
+
+    gpu_devices = [d for d in ov_core.available_devices if d.startswith("GPU")]
+    if not gpu_devices:
+        available = ", ".join(ov_core.available_devices)
+        raise RuntimeError(
+            "No Intel GPU device found in OpenVINO runtime. "
+            f"Available devices: [{available}]"
+        )
+
+    detailed = []
+    for dev in gpu_devices:
+        try:
+            full_name = str(ov_core.get_property(dev, "FULL_DEVICE_NAME"))
+        except Exception:
+            full_name = "Unknown GPU"
+        detailed.append((dev, full_name))
+
+    preferred_keywords = ("arc", "b580", "discrete", "max")
+    for dev, full_name in detailed:
+        lowered = full_name.lower()
+        if any(k in lowered for k in preferred_keywords):
+            return dev, full_name
+
+    return detailed[0][0], detailed[0][1]
+
+
+# ---------------------------------------------------------------------------
+# Layer configuration extracted from manifest + npz
+# ---------------------------------------------------------------------------
+
+@dataclass
+class LayerConfig:
+    name: str
+    file: str
+    layer_type: str
+    in_channels: int
+    out_channels: int
+    kernel_size: list[int]
+    stride: list[int]
+    padding: list[int]
+    dilation: list[int]
+    input_nnz: int
+    output_nnz: int
+    input_spatial_shape: list[int]
+    output_spatial_shape: list[int]
+    is_subm: bool
+
+
+# Execution order matching the real BEVFusion sparse encoder dataflow.
+# (file_index in filename-sorted list, human-readable description)
+EXEC_ORDER = [
+    (0,  "conv_input           SubMConv3d"),
+    (2,  "layer1.block0.conv1  SubMConv3d"),
+    (3,  "layer1.block0.conv2  SubMConv3d"),
+    (4,  "layer1.block1.conv1  SubMConv3d"),
+    (5,  "layer1.block1.conv2  SubMConv3d"),
+    (6,  "layer1.downsample    SparseConv3d  s=2"),
+    (7,  "layer2.block0.conv1  SubMConv3d"),
+    (8,  "layer2.block0.conv2  SubMConv3d"),
+    (9,  "layer2.block1.conv1  SubMConv3d"),
+    (10, "layer2.block1.conv2  SubMConv3d"),
+    (11, "layer2.downsample    SparseConv3d  s=2"),
+    (12, "layer3.block0.conv1  SubMConv3d"),
+    (13, "layer3.block0.conv2  SubMConv3d"),
+    (14, "layer3.block1.conv1  SubMConv3d"),
+    (15, "layer3.block1.conv2  SubMConv3d"),
+    (16, "layer3.downsample    SparseConv3d  s=2"),
+    (17, "layer4.block0.conv1  SubMConv3d"),
+    (18, "layer4.block0.conv2  SubMConv3d"),
+    (19, "layer4.block1.conv1  SubMConv3d"),
+    (20, "layer4.block1.conv2  SubMConv3d"),
+    (1,  "conv_out             SparseConv3d  s=[1,1,2]"),
+]
+
+
+# ---------------------------------------------------------------------------
+# ONNX model builder
+# ---------------------------------------------------------------------------
+
+
+def build_single_layer_onnx(
+    cfg: LayerConfig,
+    weight_3d: np.ndarray,
+    m_in: int,
+    output_bound: int,
+    use_fp16: bool = True,
+) -> onnx.ModelProto:
+    """Build a single-op ONNX model for one SparseConvolution layer."""
+    dtype = TensorProto.FLOAT16 if use_fp16 else TensorProto.FLOAT
+    np_dtype = np.float16 if use_fp16 else np.float32
+
+    weight_np = weight_3d.astype(np_dtype)
+
+    # Graph inputs
+    features_input = helper.make_tensor_value_info(
+        "features", dtype, [m_in, cfg.in_channels]
+    )
+    indices_input = helper.make_tensor_value_info(
+        "indices", TensorProto.INT32, [m_in, 4]
+    )
+
+    # Weight initializer
+    weight_init = helper.make_tensor(
+        "weight", dtype, list(weight_np.shape), weight_np.flatten().tolist()
+    )
+
+    # Output shapes: for SubM → [m_in, C_out]; for Sparse → [output_bound, C_out]
+    m_out_dim = m_in if cfg.is_subm else output_bound
+    out_features = helper.make_tensor_value_info(
+        "out_features", dtype, [m_out_dim, cfg.out_channels]
+    )
+    out_indices = helper.make_tensor_value_info(
+        "out_indices", TensorProto.INT32, [m_out_dim, 4]
+    )
+
+    # SparseConvolution node
+    node = helper.make_node(
+        "SparseConvolution",
+        inputs=["features", "indices", "weight"],
+        outputs=["out_features", "out_indices"],
+        domain="org.openvinotoolkit",
+        kernel_size=cfg.kernel_size,
+        stride=cfg.stride,
+        padding=cfg.padding,
+        dilation=cfg.dilation,
+        submanifold_i=1 if cfg.is_subm else 0,
+        out_channels_i=cfg.out_channels,
+        in_channels_i=cfg.in_channels,
+        input_spatial_shape=cfg.input_spatial_shape,
+        output_spatial_shape=cfg.output_spatial_shape,
+        activation_s="None",
+        output_bound_i=output_bound,
+        rulebook_s="",
+    )
+
+    graph = helper.make_graph(
+        [node],
+        f"layer_{cfg.name}",
+        [features_input, indices_input],
+        [out_features, out_indices],
+        initializer=[weight_init],
+    )
+
+    opset = helper.make_opsetid("org.openvinotoolkit", 1)
+    model = helper.make_model(graph, opset_imports=[opset, helper.make_opsetid("", 13)])
+    model.ir_version = 8
+    return model
+
+
+# ---------------------------------------------------------------------------
+# Comparison utilities
+# ---------------------------------------------------------------------------
+
+@dataclass
+class ComparisonResult:
+    """Per-layer comparison metrics."""
+    ov_nnz: int
+    ref_nnz: int
+    common_count: int
+    ov_only: int
+    ref_only: int
+    voxel_exact: bool
+    max_abs_err: float
+    mean_abs_err: float
+    fp32_bound: float
+    feat_close: bool
+
+
+def compare_outputs(
+    ov_feats: np.ndarray,
+    ov_coords: np.ndarray,
+    ref_feats: np.ndarray,
+    ref_coords: np.ndarray,
+    in_channels: int,
+    kernel_size: list[int],
+) -> ComparisonResult:
+    """Compare OpenVINO output against spconv reference."""
+    ov_set = set(map(tuple, ov_coords))
+    ref_set = set(map(tuple, ref_coords))
+
+    common = ov_set & ref_set
+    ov_only_set = ov_set - ref_set
+    ref_only_set = ref_set - ov_set
+
+    voxel_exact = ov_set == ref_set
+
+    if len(common) > 0:
+        ref_dict = {tuple(ref_coords[i]): ref_feats[i] for i in range(len(ref_coords))}
+        ov_dict = {tuple(ov_coords[i]): ov_feats[i] for i in range(len(ov_coords))}
+        common_sorted = sorted(common)
+        matched_ref = np.stack([ref_dict[c] for c in common_sorted])
+        matched_ov = np.stack([ov_dict[c] for c in common_sorted])
+
+        abs_diff = np.abs(matched_ov.astype(np.float32) - matched_ref.astype(np.float32))
+        max_abs = float(abs_diff.max())
+        mean_abs = float(abs_diff.mean())
+
+        k_vol = int(np.prod(kernel_size))
+        ref_abs_max = float(np.abs(matched_ref).max())
+        fp32_bound = 40 * in_channels * k_vol * 1.2e-7 * ref_abs_max
+        feat_close = max_abs <= max(1e-3, fp32_bound)
+    else:
+        max_abs = float("inf")
+        mean_abs = float("inf")
+        fp32_bound = 0.0
+        feat_close = False
+
+    return ComparisonResult(
+        ov_nnz=len(ov_set),
+        ref_nnz=len(ref_set),
+        common_count=len(common),
+        ov_only=len(ov_only_set),
+        ref_only=len(ref_only_set),
+        voxel_exact=voxel_exact,
+        max_abs_err=max_abs,
+        mean_abs_err=mean_abs,
+        fp32_bound=fp32_bound,
+        feat_close=feat_close,
+    )
+
+
+# ---------------------------------------------------------------------------
+# OpenVINO inference runner
+# ---------------------------------------------------------------------------
+
+def run_layer_openvino(
+    ov_core,
+    cfg: LayerConfig,
+    npz_data: dict,
+    device: str,
+    use_fp16: bool,
+    tmp_dir: str,
+) -> tuple[np.ndarray, np.ndarray, int]:
+    """Run one layer through OpenVINO, return (features, coords, actual_m_out)."""
+
+    weight_5d = npz_data["weight"]
+    kx, ky, kz, c_in, c_out = weight_5d.shape
+    weight_3d = weight_5d.reshape(kx * ky * kz, c_in, c_out)
+
+    m_in = cfg.input_nnz
+
+    # For SparseConv, output_bound provides static shape for buffer allocation.
+    if cfg.is_subm:
+        output_bound = m_in
+    else:
+        output_bound = max(cfg.output_nnz * 2, m_in)
+
+    model = build_single_layer_onnx(cfg, weight_3d, m_in, output_bound, use_fp16)
+
+    onnx_path = os.path.join(tmp_dir, f"layer_{cfg.name.replace('.', '_')}.onnx")
+    onnx.save(model, onnx_path)
+
+    ov_model = ov_core.read_model(onnx_path)
+    compiled = ov_core.compile_model(ov_model, device)
+
+    np_dtype = np.float16 if use_fp16 else np.float32
+    features = npz_data["input_features"].astype(np_dtype)
+    indices = npz_data["input_indices"].astype(np.int32)
+
+    result = compiled({0: features, 1: indices})
+    out_feats = result[0]
+    out_coords = result[1]
+
+    # For SparseConv layers, the output buffer is pre-allocated to output_bound.
+    # Trim trailing zero-rows (coords = [0,0,0,0] with zero features).
+    if not cfg.is_subm:
+        actual_m = _find_actual_m(out_coords)
+        out_feats = out_feats[:actual_m]
+        out_coords = out_coords[:actual_m]
+    else:
+        actual_m = m_in
+
+    return out_feats, out_coords, actual_m
+
+
+def _find_actual_m(coords: np.ndarray) -> int:
+    """Find actual number of valid output voxels by detecting trailing zeros."""
+    # Valid coords have non-zero spatial components or batch=0 with spatial > 0.
+    # Look for first row where all coords are zero from the end.
+    n = len(coords)
+    if n == 0:
+        return 0
+
+    # Check from the end: find the last non-zero row
+    row_sums = np.abs(coords).sum(axis=1)
+    nonzero_mask = row_sums > 0
+    if not nonzero_mask.any():
+        return 0
+
+    # The last nonzero row index + 1
+    last_nonzero = np.where(nonzero_mask)[0][-1]
+    return int(last_nonzero + 1)
+
