index 0000000000..45dbf9542d
--- /dev/null
+++ b/src/plugins/intel_gpu/src/graph/impls/sycl/sparse_to_dense_sycl.cpp
@@ -0,0 +1,348 @@
+// Copyright (C) 2018-2026 Intel Corporation
+// SPDX-License-Identifier: Apache-2.0
+//
+// SparseToDense SYCL kernel implementation.
+//
+// Scatter sparse features into a dense output tensor. Supports two modes:
+//   - Non-fused (5D output): equivalent to SparseConvTensor.dense()
+//   - Fused (4D output): dense + permute(0,1,4,2,3) + view(N,C*D,H,W) in one kernel
+//
+// Work distribution: 1D NDRange, total_work = M * C
+//   point   = global_id / C
+//   channel = global_id % C
+
+#include "sparse_to_dense_sycl.hpp"
+#include "sparse_actual_m_map.h"
+
+#include "ocl/ocl_stream.hpp"
+#include "ocl/sycl_stream.hpp"
+#include "primitive_sycl_base.h"
+
+#include "intel_gpu/runtime/memory.hpp"
+
+#include <algorithm>
+#include <cstdint>
+#include <memory>
+
+#include "sycl/sycl.hpp"
+
+namespace cldnn {
+namespace sycl {
+
+static constexpr int WG_SIZE = 256;
+
+// ===================================================================
+// SYCL Kernel: scatter sparse features → dense output
+// ===================================================================
+
+template <typename TFeat, bool ChannelsFirst, bool FusePermuteReshape>
+static ::sycl::event launch_kernel(::sycl::queue& q,
+                                   const TFeat* __restrict__ features,
+                                   const int32_t* __restrict__ indices,
+                                   TFeat* __restrict__ output,
+                                   uint32_t M,
+                                   uint32_t C,
+                                   uint32_t B,
+                                   uint32_t Z,
+                                   uint32_t Y,
+                                   uint32_t X,
+                                   size_t out_len) {
+    const size_t total_work = static_cast<size_t>(M) * C;
+    if (total_work == 0)
+        return {};
+
+    const size_t wg = WG_SIZE;
+    const size_t global = ((total_work + wg - 1) / wg) * wg;
+
+    // Pre-compute fused channel dim
+    const uint32_t CX = C * X;
+
+    return q.submit([&](::sycl::handler& cgh) {
+        cgh.parallel_for(
+            ::sycl::nd_range<1>({global}, {wg}),
+            [=](::sycl::nd_item<1> item) {
+                const size_t gid = item.get_global_id(0);
+                if (gid >= total_work)
+                    return;
+
+                const uint32_t point = static_cast<uint32_t>(gid / C);
+                const uint32_t channel = static_cast<uint32_t>(gid % C);
+
+                // Read sparse point coordinates: [batch, z, y, x]
+                const int32_t b = indices[point * 4 + 0];
+                const int32_t z = indices[point * 4 + 1];
+                const int32_t y = indices[point * 4 + 2];
+                const int32_t x = indices[point * 4 + 3];
+
+                // Bounds check
+                if (b < 0 || b >= static_cast<int32_t>(B) ||
+                    z < 0 || z >= static_cast<int32_t>(Z) ||
+                    y < 0 || y >= static_cast<int32_t>(Y) ||
+                    x < 0 || x >= static_cast<int32_t>(X))
+                    return;
+
+                const size_t ub = static_cast<size_t>(b);
+                const size_t uz = static_cast<size_t>(z);
+                const size_t uy = static_cast<size_t>(y);
+                const size_t ux = static_cast<size_t>(x);
+                const size_t uc = static_cast<size_t>(channel);
+
+                size_t out_idx;
+
+                if constexpr (FusePermuteReshape) {
+                    if constexpr (ChannelsFirst) {
+                        // output[b, c*X+x, z, y]  shape: [B, C*X, Z, Y]
+                        out_idx = ((ub * CX + uc * X + ux) * Z + uz) * Y + uy;
+                    } else {
+                        // output[b, z, y, c*X+x]  shape: [B, Z, Y, C*X]
+                        out_idx = ((ub * Z + uz) * Y + uy) * CX + uc * X + ux;
+                    }
+                } else {
+                    if constexpr (ChannelsFirst) {
+                        // output[b, c, z, y, x]  shape: [B, C, Z, Y, X]
+                        out_idx = ((((ub * C + uc) * Z + uz) * Y + uy) * X + ux);
+                    } else {
+                        // output[b, z, y, x, c]  shape: [B, Z, Y, X, C]
+                        out_idx = ((((ub * Z + uz) * Y + uy) * X + ux) * C + uc);
+                    }
+                }
+
+                if (out_idx < out_len) {
+                    output[out_idx] = features[point * C + channel];
+                }
+            });
+    });
+}
+
+// ===================================================================
+// USM memory management (same pattern as SparseConvolution)
+// ===================================================================
+
+static allocation_type get_staging_usm_type(engine& engine) {
+    if (engine.supports_allocation(allocation_type::usm_device))
+        return allocation_type::usm_device;
+    if (engine.supports_allocation(allocation_type::usm_shared))
+        return allocation_type::usm_shared;
+    return allocation_type::usm_host;
+}
+
+// High-watermark staging slot: underlying USM grows on demand but never
+// shrinks; per-frame views are cheap reinterpret_buffer wrappers. See the
+// matching comment in sparse_convolution_sycl.cpp for the motivation.
+struct StagingSlot {
+    memory::ptr hw;
+    memory::ptr view;
+};
+
+static memory::ptr ensure_usm(memory::ptr mem,
+                               StagingSlot& slot,
+                               stream& stream,
+                               engine& engine,
+                               bool is_output,
+                               bool blocking) {
+    OPENVINO_ASSERT(mem != nullptr, "SparseToDense: null memory");
+    if (memory_capabilities::is_usm_type(mem->get_allocation_type()))
+        return mem;
+
+    const auto required = get_staging_usm_type(engine);
+    const auto& need_layout = mem->get_layout();
+    const auto need_bytes = need_layout.bytes_count();
+
+    if (slot.hw == nullptr ||
+        slot.hw->get_allocation_type() != required ||
+        slot.hw->size() < need_bytes) {
+        slot.hw = engine.allocate_memory(need_layout, required, false);
+        slot.view = slot.hw;
+    } else if (slot.view == nullptr || slot.view->get_layout() != need_layout) {
+        slot.view = engine.reinterpret_buffer(*slot.hw, need_layout);
+    }
+
+    if (!is_output)
+        slot.view->copy_from(stream, *mem, blocking);
+    return slot.view;
+}
+
+// ===================================================================
+// sparse_to_dense_sycl — main execution class
+// ===================================================================
+
+struct sparse_to_dense_sycl : public typed_primitive_sycl_impl<sparse_to_dense> {
+    using parent = typed_primitive_sycl_impl<sparse_to_dense>;
+    using parent::parent;
+
+    // Fallback SYCL queue (for non-native-SYCL streams)
+    std::shared_ptr<::sycl::context> fallback_context;
+    std::shared_ptr<::sycl::queue> fallback_queue;
+    void* fallback_queue_handle = nullptr;
+
+    // Cached staging buffers
+    StagingSlot feat_slot;
+    StagingSlot idx_slot;
+    StagingSlot out_slot;
+
+    DECLARE_OBJECT_TYPE_SERIALIZATION(cldnn::sycl::sparse_to_dense_sycl)
+
+    std::unique_ptr<primitive_impl> clone() const override {
+        return std::make_unique<sparse_to_dense_sycl>(*this);
+    }
+
+    event::ptr execute_impl(const std::vector<event::ptr>& events,
+                            typed_primitive_inst<sparse_to_dense>& instance) override {
+        auto& network = instance.get_network();
+        auto& stream = downcast<ocl::ocl_stream>(network.get_stream());
+        auto& engine = network.get_engine();
+        auto desc = instance.get_typed_desc<sparse_to_dense>();
+
+        // --- Obtain SYCL queue ---
+        ::sycl::queue* q = nullptr;
+        if (auto* s = dynamic_cast<ocl::sycl_stream*>(&stream)) {
+            q = &s->get_sycl_queue();
+        } else {
+            auto& ocl_eng = downcast<ocl::ocl_engine>(engine);
+            auto cur = static_cast<void*>(stream.get_cl_queue().get());
+            if (!fallback_queue || fallback_queue_handle != cur) {
+                fallback_context = std::make_shared<::sycl::context>(
+                    ::sycl::make_context<::sycl::backend::opencl>(
+                        ocl_eng.get_cl_context().get()));
+                fallback_queue = std::make_shared<::sycl::queue>(
+                    ::sycl::make_queue<::sycl::backend::opencl>(
+                        stream.get_cl_queue().get(), *fallback_context));
+                fallback_queue_handle = cur;
+            }
+            q = fallback_queue.get();
+        }
+
+        // --- Get input/output memory ---
+        auto feat_mem = instance.input_memory_ptr(0);
+        auto idx_mem = instance.input_memory_ptr(1);
+        auto out_mem = instance.output_memory_ptr(0);
+
+        // --- Read spatial_shape [Z, Y, X] and batch_size B ---
+        // Prefer primitive attributes (compile-time constants).
+        // Fall back to reading from input memory (inputs 2, 3) for the
+        // 4-input ONNX variant where spatial_shape is a parameter.
+        uint32_t Z, Y, X, B;
+        if (desc->spatial_shape.size() >= 3) {
+            Z = static_cast<uint32_t>(desc->spatial_shape[0]);
+            Y = static_cast<uint32_t>(desc->spatial_shape[1]);
+            X = static_cast<uint32_t>(desc->spatial_shape[2]);
+            B = static_cast<uint32_t>(desc->batch_size);
+        } else {
+            auto ss_mem = instance.input_memory_ptr(2);
+            auto bs_mem = instance.input_memory_ptr(3);
+            mem_lock<int32_t, mem_lock_type::read> ss_lock(ss_mem, stream);
+            Z = static_cast<uint32_t>(ss_lock[0]);
+            Y = static_cast<uint32_t>(ss_lock[1]);
+            X = static_cast<uint32_t>(ss_lock[2]);
+            mem_lock<int32_t, mem_lock_type::read> bs_lock(bs_mem, stream);
+            B = static_cast<uint32_t>(bs_lock[0]);
+        }
+
+        // --- Extract M, C from features layout ---
+        // Cap M by idx shape[0] because feat_mem may be pre-grown by the GPU
+        // plugin's ShapePredictor (see matching comment in
+        // sparse_convolution_sycl.cpp).
+        const auto& feat_layout = feat_mem->get_layout();
+        const auto& feat_shape = feat_layout.get_shape();
+        const auto& idx_shape = idx_mem->get_layout().get_shape();
+        uint32_t M = static_cast<uint32_t>(std::min<size_t>(feat_shape[0], idx_shape[0]));
+        const uint32_t C = static_cast<uint32_t>(feat_shape[1]);
+        const bool is_f16 = (feat_layout.data_type == data_types::f16);
+
+        // Override M with actual voxel count from upstream SparseConvolution.
+        // The coord buffer may be larger than actual data for stride>1
+        // convolutions.  Without this override, SparseToDense would iterate
+        // over garbage coordinates beyond m_out, corrupting the dense output.
+        {
+            auto* idx_raw = idx_mem->buffer_ptr();
+            auto it = sparse_actual_m_map().find(idx_raw);
+            if (it != sparse_actual_m_map().end() && it->second > 0) {
+                M = static_cast<uint32_t>(it->second);
+            }
+        }
+
+        // --- Compute output length ---
+        size_t out_len;
+        if (desc->fuse_permute_reshape) {
+            out_len = static_cast<size_t>(B) * C * X * Z * Y;
+        } else {
+            out_len = static_cast<size_t>(B) * C * Z * Y * X;
+        }
+
+        // --- Wait + USM staging ---
+        stream.wait_for_events(events);
+        const bool blocking = stream.get_queue_type() == QueueTypes::out_of_order;
+
+        feat_mem = ensure_usm(feat_mem, feat_slot, stream, engine, false, blocking);
+        idx_mem = ensure_usm(idx_mem, idx_slot, stream, engine, false, blocking);
+        auto kern_out = ensure_usm(out_mem, out_slot, stream, engine, true, blocking);
+
+        // --- Zero-initialize output ---
+        auto* out_raw = kern_out->buffer_ptr();
+        size_t out_bytes = out_len * (is_f16 ? 2 : 4);
+        q->memset(out_raw, 0, out_bytes);  // in-order queue serializes with subsequent kernels
+
+        // --- Early exit if nothing to scatter ---
+        if (M == 0 || C == 0) {
+            if (kern_out != out_mem) {
+                out_mem->copy_from(stream, *kern_out, true);
+            }
+            return stream.create_base_event();
+        }
+
+        // --- Type dispatch and kernel launch ---
+        auto* idx_ptr = static_cast<const int32_t*>(idx_mem->buffer_ptr());
+        ::sycl::event ev;
+
+        const bool cf = desc->channels_first;
+        const bool fuse = desc->fuse_permute_reshape;
+
+        // Dispatch macro: 4 layout combinations x 2 data types = 8 paths
+        #define LAUNCH(TFeat, CF, FUSE) \
+            ev = launch_kernel<TFeat, CF, FUSE>( \
+                *q, \
+                static_cast<const TFeat*>(feat_mem->buffer_ptr()), \
+                idx_ptr, \
+                static_cast<TFeat*>(kern_out->buffer_ptr()), \
+                M, C, B, Z, Y, X, out_len)
+
+        if (is_f16) {
+            using f16 = ::sycl::half;
+            if (fuse && cf)       { LAUNCH(f16, true,  true);  }
+            else if (fuse && !cf) { LAUNCH(f16, false, true);  }
+            else if (!fuse && cf) { LAUNCH(f16, true,  false); }
+            else                  { LAUNCH(f16, false, false); }
+        } else {
+            if (fuse && cf)       { LAUNCH(float, true,  true);  }
+            else if (fuse && !cf) { LAUNCH(float, false, true);  }
+            else if (!fuse && cf) { LAUNCH(float, true,  false); }
+            else                  { LAUNCH(float, false, false); }
+        }
+
+        #undef LAUNCH
+
+        // --- Copy staging back if needed ---
+        if (kern_out != out_mem) {
+            ev.wait_and_throw();
+            out_mem->copy_from(stream, *kern_out, true);
+            return stream.create_base_event();
+        }
+
+        return to_ocl_event(stream, ev);
+    }
+};
+
+// ===================================================================
+// Factory
+// ===================================================================
+
+std::unique_ptr<primitive_impl> SparseToDenseSyclImpl::create_impl(const program_node& node,
+                                                                    const kernel_impl_params& params) const {
+    return std::make_unique<sparse_to_dense_sycl>();
+}
