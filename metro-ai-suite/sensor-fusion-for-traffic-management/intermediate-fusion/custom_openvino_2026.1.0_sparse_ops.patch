+// Copyright (C) 2018-2026 Intel Corporation
+// SPDX-License-Identifier: Apache-2.0
+//
+
+#include "openvino/op/sparse_to_dense.hpp"
+
+#include "intel_gpu/plugin/common_utils.hpp"
+#include "intel_gpu/plugin/program_builder.hpp"
+#include "intel_gpu/primitives/sparse_to_dense.hpp"
+#include "openvino/op/constant.hpp"
+
+namespace ov::intel_gpu {
+
+static void CreateSparseToDenseOp(ProgramBuilder& p,
+                                  const std::shared_ptr<ov::op::v15::SparseToDense>& op) {
+    validate_inputs_count(op, {4});
+    auto inputs = p.GetInputInfo(op);
+
+    // Extract spatial_shape [Z, Y, X] from input 2 (compile-time constant)
+    std::vector<int32_t> spatial_shape;
+    if (auto ss_const = ov::as_type_ptr<ov::op::v0::Constant>(op->get_input_node_shared_ptr(2))) {
+        spatial_shape = ss_const->cast_vector<int32_t>();
+    }
+
+    // Extract batch_size B from input 3 (compile-time constant)
+    int32_t batch_size = 0;
+    if (auto bs_const = ov::as_type_ptr<ov::op::v0::Constant>(op->get_input_node_shared_ptr(3))) {
+        auto vals = bs_const->cast_vector<int32_t>();
+        if (!vals.empty()) batch_size = vals[0];
+    }
+
+    auto prim = cldnn::sparse_to_dense(layer_type_name_ID(op),
+                                       inputs,
+                                       op->get_channels_first(),
+                                       op->get_fuse_permute_reshape(),
+                                       spatial_shape,
+                                       batch_size);
+    p.add_primitive(*op, prim);
+}
+
+REGISTER_FACTORY_IMPL(v15, SparseToDense);
+
+}  // namespace ov::intel_gpu
