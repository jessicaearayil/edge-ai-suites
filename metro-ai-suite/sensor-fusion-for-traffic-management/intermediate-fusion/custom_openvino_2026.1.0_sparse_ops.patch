+//
+
+#pragma once
+
+#include "openvino/op/op.hpp"
+
+namespace ov {
+namespace op {
+namespace v15 {
+
+/// @brief SparseToDense — converts sparse voxel features to a dense tensor.
+///
+/// Implements the bridge between sparse convolution output and dense downstream
+/// networks (e.g., BEV feature maps in BEVFusion).
+///
+/// When fuse_permute_reshape=false (default):
+///   Equivalent to SparseConvTensor.dense() — outputs a 5D tensor.
+///   channels_first=true:  [B, C, Z, Y, X]
+///   channels_first=false: [B, Z, Y, X, C]
+///
+/// When fuse_permute_reshape=true:
+///   Fuses dense() + permute(0,1,4,2,3) + view(N, C*D, H, W) into a single
+///   scatter kernel — outputs a 4D BEV tensor with no intermediate allocation.
+///   channels_first=true:  [B, C*X, Z, Y]
+///   channels_first=false: [B, Z, Y, C*X]
+///
+/// Inputs:
+///   0 (features)      — [M, C]   f16/f32   sparse point features
+///   1 (indices)        — [M, 4]   i32       coords [batch, z, y, x]
+///   2 (spatial_shape)  — [3]      i32       spatial dims [Z, Y, X]
+///   3 (batch_size)     — []       i32       batch size B
+///
+/// Outputs:
+///   0 (output)         — 5D or 4D tensor depending on fuse_permute_reshape
+class OPENVINO_API SparseToDense : public Op {
+public:
+    OPENVINO_OP("SparseToDense", "opset15");
+    SparseToDense() = default;
+
+    SparseToDense(const Output<Node>& features,
+                  const Output<Node>& indices,
+                  const Output<Node>& spatial_shape,
+                  const Output<Node>& batch_size,
+                  bool channels_first = true,
+                  bool fuse_permute_reshape = false);
+
+    bool visit_attributes(AttributeVisitor& visitor) override;
+    void validate_and_infer_types() override;
+    std::shared_ptr<Node> clone_with_new_inputs(const OutputVector& new_args) const override;
+    bool evaluate(TensorVector& outputs, const TensorVector& inputs) const override;
+    bool has_evaluate() const override;
+
+    bool get_channels_first() const { return m_channels_first; }
+    bool get_fuse_permute_reshape() const { return m_fuse_permute_reshape; }
+
+private:
+    bool m_channels_first = true;
+    bool m_fuse_permute_reshape = false;
+};
+
+}  // namespace v15
+}  // namespace op
+}  // namespace ov
