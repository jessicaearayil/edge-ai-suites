+++ b/src/plugins/intel_gpu/src/graph/impls/sycl/sparse_to_dense_sycl.hpp
@@ -0,0 +1,68 @@
+// Copyright (C) 2018-2026 Intel Corporation
+// SPDX-License-Identifier: Apache-2.0
+//
+
+#pragma once
+
+#include "sparse_to_dense_inst.h"
+#include "registry/implementation_manager.hpp"
+
+namespace cldnn {
+namespace sycl {
+
+struct SparseToDenseSyclImpl : public ImplementationManager {
+    OV_GPU_PRIMITIVE_IMPL("sycl::sparse_to_dense")
+
+    SparseToDenseSyclImpl(shape_types shape_type, ValidateFunc vf = nullptr)
+        : ImplementationManager(impl_types::sycl, shape_type, vf) {}
+
+    std::unique_ptr<primitive_impl> create_impl(const program_node& node, const kernel_impl_params& params) const override;
+
+    bool validate_impl(const program_node& node) const override {
+        assert(node.is_type<sparse_to_dense>());
+
+        if (node.has_fused_primitives())
+            return false;
+
+        if (node.get_input_layouts().size() != 4 || node.get_output_layouts().size() != 1)
+            return false;
+
+        // Input 0: features [M, C] — f16 or f32, bfyx, no padding
+        const auto& feat_layout = node.get_input_layout(0);
+        if (feat_layout.data_type != data_types::f32 && feat_layout.data_type != data_types::f16)
+            return false;
+        if (feat_layout.format != format::bfyx || feat_layout.data_padding)
+            return false;
+
+        // Input 1: indices [M, 4] — i32, bfyx, no padding
+        const auto& idx_layout = node.get_input_layout(1);
+        if (idx_layout.data_type != data_types::i32)
+            return false;
+        if (idx_layout.format != format::bfyx || idx_layout.data_padding)
+            return false;
+
+        // Input 2: spatial_shape [3] — integer, bfyx, no padding
+        const auto& ss_layout = node.get_input_layout(2);
+        if (ss_layout.data_type != data_types::i32 && ss_layout.data_type != data_types::i64)
+            return false;
+        if (ss_layout.format != format::bfyx || ss_layout.data_padding)
+            return false;
+
+        // Input 3: batch_size — integer
+        const auto& bs_layout = node.get_input_layout(3);
+        if (bs_layout.data_type != data_types::i32 && bs_layout.data_type != data_types::i64)
+            return false;
+
+        // Output: same type as features, no padding
+        const auto& out_layout = node.get_output_layout(0);
+        if (out_layout.data_type != feat_layout.data_type)
+            return false;
+        if (out_layout.data_padding)
+            return false;
+
+        return true;
+    }
+};
+
+}  // namespace sycl
+}  // namespace cldnn
