+#!/bin/bash
+# Run SparseEncoder end-to-end validation against spconv reference.
+# Requires: custom-built OpenVINO with SparseConvolution + SparseToDense support.
+#
+# Usage:
+#   ./run_e2e.sh                # default: FP16, 3 iterations
+#   ./run_e2e.sh --fp32         # FP32 precision
+#   ./run_e2e.sh --niter 10     # 10 timed iterations
+set -euo pipefail
+
+SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
+OV_DIR="$SCRIPT_DIR/bin/intel64/Release"
+PYTHON="/home/jie/env/spconvEnv/bin/python"
+DUMP_DIR="$SCRIPT_DIR/test_data/sparse_encoder_dump"
+ONNX_MODEL="$SCRIPT_DIR/test_data/sparse_encoder_new.onnx"
+
+export PYTHONPATH="$OV_DIR/python:${PYTHONPATH:-}"
+export LD_LIBRARY_PATH="$OV_DIR:${LD_LIBRARY_PATH:-}"
+
+exec "$PYTHON" "$SCRIPT_DIR/test_sparse_encoder_e2e.py" \
+    --dump-dir "$DUMP_DIR" \
+    --onnx "$ONNX_MODEL" \
+    "$@"
