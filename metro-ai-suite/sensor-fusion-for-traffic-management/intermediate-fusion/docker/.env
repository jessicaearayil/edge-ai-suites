# proxy settings
https_proxy=
http_proxy=
# base image settings
BASE=ubuntu
BASE_VERSION=24.04
# custom OpenVINO install directory on the host; must contain setupvars.sh
CUSTOM_OPENVINO_INSTALL_DIR=/absolute/path/to/custom_openvino/install
# group IDs for various services
VIDEO_GROUP_ID=44
RENDER_GROUP_ID=110
# display settings
DISPLAY=$DISPLAY